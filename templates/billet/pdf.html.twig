<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export PDF - Billets</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            color: #1f2937;
            margin: 0;
            padding: 24px;
        }

        h1 {
            margin: 0 0 6px;
            font-size: 24px;
            color: #111827;
        }

        .meta {
            margin-bottom: 20px;
            color: #6b7280;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #d1d5db;
            padding: 8px 10px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #f3f4f6;
            font-weight: 700;
        }

        tbody tr:nth-child(even) {
            background: #fafafa;
        }
    </style>
</head>
<body>
    {# This title clarifies the exported dataset for the admin and for presentations. #}
    <h1>Liste des billets</h1>

    {# The generation timestamp helps identify which export version was downloaded. #}
    <div class="meta">
        Export gťnťrť le {{ generatedAt|date('d/m/Y H:i') }}
    </div>

    <table>
        <thead>
            <tr>
                <th>Type transport</th>
                <th>Numťro billet</th>
                <th>Date dťpart</th>
                <th>Date arrivťe</th>
                <th>Prix</th>
                <th>Statut</th>
                <th>Rťservation liťe</th>
            </tr>
        </thead>
        <tbody>
        {% for billet in billets %}
            <tr>
                <td>{{ billet.typeTransport }}</td>
                <td>{{ billet.numeroBillet }}</td>
                <td>{{ billet.dateDepart ? billet.dateDepart|date('Y-m-d H:i') : '' }}</td>
                <td>{{ billet.dateArrivee ? billet.dateArrivee|date('Y-m-d H:i') : '' }}</td>
                <td>{{ billet.prix }}</td>
                <td>{{ billet.statut }}</td>
                <td>{{ billet.reservation ? billet.reservation.id : '' }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Aucun billet disponible.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</body>
</html>
