{% extends 'base.html.twig' %}

{% block title %}Travelia — Cinematic Luxury Discovery{% endblock %}

{% block body %}
    <!-- ═══════════════ SECTION 0: HERO ═══════════════ -->
    <section class="panel" id="hero">
        <video class="panel-vid" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&q=85">
            <source src="https://cdn.coverr.co/videos/coverr-a-green-mountain-4652/1080p.mp4" type="video/mp4"/>
        </video>
        <div class="panel-overlay panel-overlay--hero"></div>
        <div class="hero-wrap">
            <div class="hero-eyebrow">✦ AI-Powered Travel Curation</div>
            <h1 class="hero-h1">Travel Beyond<br/><em>The Horizon.</em></h1>
            <p class="hero-lead">Discover the world's most extraordinary destinations,<br/>handpicked by AI and curated for you.</p>
            
            <!-- 3-Field Search Glass -->
            <div class="search-glass">
                <div class="search-field">
                    <label>Where</label>
                    <input type="text" placeholder="Destination or hotel" id="s-dest"/>
                </div>
                <div class="search-sep"></div>
                <div class="search-field">
                    <label>When</label>
                    <input type="text" placeholder="Dates"/>
                </div>
                <div class="search-sep"></div>
                <div class="search-field">
                    <label>Who</label>
                    <input type="text" placeholder="Guests"/>
                </div>
                <button class="search-go">Explore</button>
            </div>

            <div class="hero-chips">
                <span class="chip">🏝 Maldives</span>
                <span class="chip">🗻 Kyoto</span>
                <span class="chip">🌅 Santorini</span>
                <span class="chip">🗻 Patagonia</span>
            </div>
        </div>

        <!-- Hero Stats (Bottom Left) -->
        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-val">2.4M+</span>
                <span class="stat-lab">Travelers</span>
            </div>
            <div class="stat-item">
                <span class="stat-val">190+</span>
                <span class="stat-lab">Countries</span>
            </div>
            <div class="stat-item">
                <span class="stat-val">98%</span>
                <span class="stat-lab">Satisfaction</span>
            </div>
            <div class="scroll-ind">
                <span>SCROLL</span>
                <div class="scroll-line"></div>
            </div>
        </div>
    </section>

    <!-- ═══════════════ SECTION 1: HOTELS ═══════════════ -->
    <section class="panel" id="hotels">
        <video class="panel-vid" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1540541338287-41700207dee6?w=1800&q=85">
            <source src="https://cdn.coverr.co/videos/coverr-coastline-of-islands-3714/1080p.mp4" type="video/mp4"/>
        </video>
        <div class="panel-overlay panel-overlay--warm"></div>
        <div class="panel-content">
            <div class="section-label">🏨 HOTELS</div>
            <h2 class="section-h2">Legendary <em>Stays</em></h2>
            <p class="section-lead">Where luxury meets the extraordinary</p>
            
            <div class="cards-row">
                <!-- Amanjiwo -->
                <div class="hotel-card glass-card">
                    <img src="https://images.unsplash.com/photo-1544124499-58b29294f99f?w=600&q=80" alt="Resort" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="card-cat">RESORT</span>
                        <h3 class="card-title">Amanjiwo Resort</h3>
                        <p class="card-loc">📍 Java, Indonesia</p>
                        <div class="card-footer">
                            <span class="card-pricing">€480<small>/night</small></span>
                            <button class="add-btn">ADD +</button>
                        </div>
                    </div>
                </div>
                <!-- Soneva Fushi -->
                <div class="hotel-card glass-card">
                    <img src="https://images.unsplash.com/photo-1573843225233-9336d3c3d3dd?w=600&q=80" alt="Villa" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="card-cat">VILLA</span>
                        <h3 class="card-title">Soneva Fushi</h3>
                        <p class="card-loc">📍 Baa Atoll, Maldives</p>
                        <div class="card-footer">
                            <span class="card-pricing">€890<small>/night</small></span>
                            <button class="add-btn">ADD +</button>
                        </div>
                    </div>
                </div>
                <!-- Burj Al Arab -->
                <div class="hotel-card glass-card">
                    <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=600&q=80" alt="Luxury" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="card-cat">LUXURY</span>
                        <h3 class="card-title">Burj Al Arab</h3>
                        <p class="card-loc">📍 Dubai, UAE</p>
                        <div class="card-footer">
                            <span class="card-pricing">€1,200<small>/night</small></span>
                            <button class="add-btn">ADD +</button>
                        </div>
                    </div>
                </div>
                <!-- Amangiri -->
                <div class="hotel-card glass-card">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&q=80" alt="Desert" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="card-cat">DESERT</span>
                        <h3 class="card-title">Amangiri</h3>
                        <p class="card-loc">📍 Utah, USA</p>
                        <div class="card-footer">
                            <span class="card-pricing">€950<small>/night</small></span>
                            <button class="add-btn">ADD +</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════ SECTION 2: FLIGHTS ═══════════════ -->
    <section class="panel" id="flights">
        <video class="panel-vid" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1436491865332-7a61a109c055?w=1800&q=85">
            <source src="https://cdn.coverr.co/videos/coverr-flying-above-clouds-1100/1080p.mp4" type="video/mp4"/>
        </video>
        <div class="panel-overlay panel-overlay--sky"></div>
        <div class="panel-content">
            <div class="section-label">✈ FLIGHTS</div>
            <h2 class="section-h2">Premium <em>Routes</em></h2>
            <p class="section-lead">First-class and business flights to everywhere</p>
            
            <div class="flights-list">
                <!-- CDG -> DXB -->
                <div class="flight-row glass-card">
                    <div class="flight-main">
                        <span class="f-icon">✈</span>
                        <div class="f-dest-box">
                            <h4 class="f-code">CDG</h4>
                            <p class="f-city">Paris</p>
                        </div>
                        <div class="f-trail">
                            <small>6h 45m</small>
                            <div class="f-arrow"></div>
                            <span class="f-tag">BUSINESS</span>
                        </div>
                        <div class="f-dest-box">
                            <h4 class="f-code">DXB</h4>
                            <p class="f-city">Dubai</p>
                        </div>
                    </div>
                    <div class="f-actions">
                        <div class="f-price">€2,140</div>
                        <small class="f-seats">🔴 3 left</small>
                        <button class="f-btn">BOOK</button>
                    </div>
                </div>
                <!-- LHR -> MLE -->
                <div class="flight-row glass-card">
                    <div class="flight-main">
                        <span class="f-icon">✈</span>
                        <div class="f-dest-box">
                            <h4 class="f-code">LHR</h4>
                            <p class="f-city">London</p>
                        </div>
                        <div class="f-trail">
                            <small>9h 20m</small>
                            <div class="f-arrow"></div>
                            <span class="f-tag gold">FIRST CLASS</span>
                        </div>
                        <div class="f-dest-box">
                            <h4 class="f-code">MLE</h4>
                            <p class="f-city">Malé</p>
                        </div>
                    </div>
                    <div class="f-actions">
                        <div class="f-price">€3,890</div>
                        <small class="f-seats">🔴 1 left</small>
                        <button class="f-btn">BOOK</button>
                    </div>
                </div>
                <!-- JFK -> NRT -->
                <div class="flight-row glass-card">
                    <div class="flight-main">
                        <span class="f-icon">✈</span>
                        <div class="f-dest-box">
                            <h4 class="f-code">JFK</h4>
                            <p class="f-city">New York</p>
                        </div>
                        <div class="f-trail">
                            <small>13h 10m</small>
                            <div class="f-arrow"></div>
                            <span class="f-tag">BUSINESS</span>
                        </div>
                        <div class="f-dest-box">
                            <h4 class="f-code">NRT</h4>
                            <p class="f-city">Tokyo</p>
                        </div>
                    </div>
                    <div class="f-actions">
                        <div class="f-price">€1,960</div>
                        <small class="f-seats">🟢 5 left</small>
                        <button class="f-btn">BOOK</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════ SECTION 3: ACTIVITIES ═══════════════ -->
    <section class="panel" id="activities">
        <video class="panel-vid" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1530789253388-582c481c54b0?w=1800&q=85">
            <source src="https://cdn.coverr.co/videos/coverr-man-looking-at-mountain-sky-8228/1080p.mp4" type="video/mp4"/>
        </video>
        <div class="panel-overlay panel-overlay--forest"></div>
        <div class="panel-content">
            <div class="section-label">🛶 ACTIVITIES</div>
            <h2 class="section-h2">Epic <em>Experiences</em></h2>
            <p class="section-lead">Curated adventures you will never forget</p>
            
            <div class="cards-row activities-grid">
                <!-- Balloon -->
                <div class="activity-card tall glass-card">
                    <img src="https://images.unsplash.com/photo-1520440229334-962aae45c55d?w=600&q=80" alt="Hot Air Balloon" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="country-badge">📍 TÜRKİYE</span>
                        <h3 class="card-title">Hot Air Balloon</h3>
                        <div class="act-details">
                            <span>🕒 3h</span>
                            <span>€180</span>
                        </div>
                        <button class="add-trip-btn">ADD TO TRIP</button>
                    </div>
                </div>
                <!-- Reef -->
                <div class="activity-card tall glass-card">
                    <img src="https://images.unsplash.com/photo-1525183334951-24d9d424368b?w=600&q=80" alt="Reef" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="country-badge">📍 AUSTRALIA</span>
                        <h3 class="card-title">Great Barrier Reef</h3>
                        <div class="act-details">
                            <span>🕒 5h</span>
                            <span>€220</span>
                        </div>
                        <button class="add-trip-btn">ADD TO TRIP</button>
                    </div>
                </div>
                <!-- Aurora -->
                <div class="activity-card tall glass-card">
                    <img src="https://images.unsplash.com/photo-1483366774565-c783b9f70e2c?w=600&q=80" alt="Aurora" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="country-badge">📍 NORWAY</span>
                        <h3 class="card-title">Northern Lights</h3>
                        <div class="act-details">
                            <span>🕒 6h</span>
                            <span>€340</span>
                        </div>
                        <button class="add-trip-btn">ADD TO TRIP</button>
                    </div>
                </div>
                <!-- Machu Picchu -->
                <div class="activity-card tall glass-card">
                    <img src="https://images.unsplash.com/photo-1526392060635-9d6019884377?w=600&q=80" alt="Trek" class="card-img" />
                    <div class="card-grad"></div>
                    <div class="card-info">
                        <span class="country-badge">📍 PERU</span>
                        <h3 class="card-title">Machu Picchu Trek</h3>
                        <div class="act-details">
                            <span>🕒 Full day</span>
                            <span>€290</span>
                        </div>
                        <button class="add-trip-btn">ADD TO TRIP</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════ SECTION 4: REVIEWS ═══════════════ -->
    <section class="panel" id="reviews">
        <video class="panel-vid" autoplay muted loop playsinline poster="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1800&q=85">
            <source src="https://cdn.coverr.co/videos/coverr-friends-toasting-with-glasses-at-beach-sunset-9040/1080p.mp4" type="video/mp4"/>
        </video>
        <div class="panel-overlay panel-overlay--deep"></div>
        <div class="panel-content panel-content--center">
            <div class="section-label">✦ REVIEWS</div>
            <h2 class="section-h2">Traveler <em>Stories</em></h2>
            
            <div class="reviews-row">
                <div class="review-card glass-card">
                    <div class="stars">★★★★★</div>
                    <p class="quote">"Horizon AI completely transformed how I travel. The AI matched me with a resort I'd never have found — it was paradise."</p>
                    <div class="user">
                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80" alt="Avatar" class="avatar" />
                        <div class="user-info">
                            <strong>Sophie Martin</strong>
                            <span>📍 Paris, France</span>
                        </div>
                    </div>
                </div>
                <div class="review-card glass-card">
                    <div class="stars">★★★★★</div>
                    <p class="quote">"The search experience is unlike anything I've used. I felt like I was already at my destination before even booking."</p>
                    <div class="user">
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80" alt="Avatar" class="avatar" />
                        <div class="user-info">
                            <strong>James Chen</strong>
                            <span>📍 Singapore</span>
                        </div>
                    </div>
                </div>
                <div class="review-card glass-card">
                    <div class="stars">★★★★★</div>
                    <p class="quote">"From flights to activities, flawlessly planned. My Northern Lights trip was a dream — all in one beautiful platform."</p>
                    <div class="user">
                        <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80" alt="Avatar" class="avatar" />
                        <div class="user-info">
                            <strong>Emma Dubois</strong>
                            <span>📍 Geneva, Switzerland</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Global Rating Pill -->
            <div class="global-rating">
                <span class="rating-n">4.9</span>
                <span class="rating-stars">★★★★★</span>
                <span class="rating-txt">Based on 48,291 reviews</span>
            </div>
        </div>
    </section>
{% endblock %}
