<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Travelia — Luxury Travel Platform</title>
  <meta name="description" content="Travelia — Discover the world's finest hotels, flights and experiences with AI-powered curation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="horizon.css?v=5" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>

  <!-- Live canvas particle FX — fixed overlay -->
  <canvas id="live-canvas"></canvas>

  <!-- NAV -->
  {% include 'front/_site_nav.html.twig' with { active_nav: 'home', home_shell: true } %}

  <!-- USER PROFILE PANEL -->
  {% if app.user %}
  <div id="user-panel-mask" onclick="closeUserPanel()" style="
    display:none; position:fixed; inset:0; z-index:1998;
    background:rgba(0,0,0,0.55); backdrop-filter:blur(4px);
  "></div>
  <aside id="user-panel" style="
    position:fixed; top:0; right:-360px; width:320px; height:100vh; z-index:1999;
    background:rgba(8,12,24,0.97); border-left:1px solid rgba(232,201,126,0.15);
    box-shadow:-20px 0 60px rgba(0,0,0,0.6); display:flex; flex-direction:column;
    transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
    font-family:'Inter',sans-serif;
  ">
    <!-- Header -->
    <div style="padding:2rem 1.8rem 1.2rem; border-bottom:1px solid rgba(255,255,255,0.07); display:flex; align-items:center; justify-content:space-between;">
      <div>
        <div style="font-family:'Cormorant Garamond',serif; font-size:1.5rem; color:#e8c97e; font-weight:400;">Bienvenue</div>
        <div style="color:#fff; font-size:1rem; font-weight:600; margin-top:0.2rem;">{{ app.user.prenom }} {{ app.user.nom }}</div>
        <div style="color:rgba(255,255,255,0.4); font-size:0.78rem; margin-top:0.15rem;">{{ app.user.email }}</div>
      </div>
      <button onclick="closeUserPanel()" style="
        background:rgba(255,255,255,0.06); border:none; color:rgba(255,255,255,0.6);
        width:36px; height:36px; border-radius:50%; cursor:pointer; font-size:1rem;
        display:flex; align-items:center; justify-content:center;
        transition:background 0.2s;
      " onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">✕</button>
    </div>
    <!-- Avatar -->
    <div style="padding:1.5rem 1.8rem; display:flex; align-items:center; gap:1rem;">
      <div style="
        width:54px; height:54px; border-radius:50%; background:linear-gradient(135deg,#e8c97e,#c9a050);
        display:flex; align-items:center; justify-content:center;
        font-family:'Cormorant Garamond',serif; font-size:1.6rem; color:#000; font-weight:600;
        flex-shrink:0;
      ">{{ app.user.prenom|first|upper }}</div>
      <div>
        <div style="color:rgba(255,255,255,0.5); font-size:0.72rem; text-transform:uppercase; letter-spacing:1px;">Niveau fidélité</div>
        <div style="color:#e8c97e; font-size:0.9rem; font-weight:600;">{{ app.user.niveauFidelite ?? 'BRONZE' }} — {{ app.user.pointsFidelite ?? 0 }} pts</div>
      </div>
    </div>
    <!-- Actions -->
    <div style="padding:0.5rem 1.2rem; flex:1;">
      <a href="{{ path('app_profile') }}" style="
        display:flex; align-items:center; gap:0.9rem;
        padding:0.9rem 1rem; border-radius:12px; margin-bottom:0.5rem;
        color:#fff; text-decoration:none; font-size:0.9rem; font-weight:500;
        background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06);
        transition:all 0.2s;
      " onmouseover="this.style.background='rgba(232,201,126,0.08)'; this.style.borderColor='rgba(232,201,126,0.25)';"
         onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(255,255,255,0.06)';">
        <span style="font-size:1.2rem;">👤</span> Mon Profil
      </a>
      <a href="{{ path('app_user_reservations') }}" style="
        display:flex; align-items:center; gap:0.9rem;
        padding:0.9rem 1rem; border-radius:12px; margin-bottom:0.5rem;
        color:#fff; text-decoration:none; font-size:0.9rem; font-weight:500;
        background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06);
        transition:all 0.2s;
      " onmouseover="this.style.background='rgba(232,201,126,0.08)'; this.style.borderColor='rgba(232,201,126,0.25)';"
         onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(255,255,255,0.06)';">
        <span style="font-size:1.2rem;">🗂️</span> Mes Réservations
      </a>
      {% if 'ROLE_ADMIN' in app.user.roles %}
      <a href="{{ path('app_admin_dashboard') }}" style="
        display:flex; align-items:center; gap:0.9rem;
        padding:0.9rem 1rem; border-radius:12px; margin-bottom:0.5rem;
        color:#6ee7b7; text-decoration:none; font-size:0.9rem; font-weight:500;
        background:rgba(110,231,183,0.05); border:1px solid rgba(110,231,183,0.12);
        transition:all 0.2s;
      " onmouseover="this.style.background='rgba(110,231,183,0.1)';"
         onmouseout="this.style.background='rgba(110,231,183,0.05)';">
        <span style="font-size:1.2rem;">⚙️</span> Tableau de Bord Admin
      </a>
      {% endif %}
    </div>
    <!-- Logout -->
    <div style="padding:1.2rem 1.2rem 2rem;">
      <a href="{{ path('app_logout') }}" style="
        display:flex; align-items:center; justify-content:center; gap:0.6rem;
        padding:0.95rem; border-radius:12px;
        background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2);
        color:#f87171; text-decoration:none; font-size:0.88rem; font-weight:600;
        text-transform:uppercase; letter-spacing:0.5px;
        transition:all 0.2s;
      " onmouseover="this.style.background='rgba(239,68,68,0.16)';"
         onmouseout="this.style.background='rgba(239,68,68,0.08)';">
        <span>⏻</span> Déconnexion
      </a>
    </div>
  </aside>
  <script>
    function openUserPanel() {
      document.getElementById('user-panel').style.right = '0';
      document.getElementById('user-panel-mask').style.display = 'block';
    }
    function closeUserPanel() {
      document.getElementById('user-panel').style.right = '-360px';
      document.getElementById('user-panel-mask').style.display = 'none';
    }
    // Close on Escape key
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeUserPanel(); });
  </script>
  {% endif %}

  <!-- SIDEBAR -->
  <div class="sidebar-mask" id="sidebar-mask"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-top">
      <div class="sidebar-title">Sign in</div>
      <button class="sidebar-x" id="sidebar-x">✕</button>
    </div>
    <div class="sidebar-content" id="sidebar-content">
      <div class="sidebar-empty" id="sidebar-empty">
        <div class="sidebar-empty-icon">✈</div>
        <p>Nothing added yet.<br/>Explore and add hotels, flights &amp; activities.</p>
      </div>
      <div id="sidebar-list"></div>
    </div>
    <div class="sidebar-bottom" id="sidebar-bottom" style="display:none">
      <div class="sidebar-total-row">
        <span>Estimated total</span>
        <strong id="sidebar-total">€0</strong>
      </div>
      <button class="cta-btn full">Proceed to Book →</button>
    </div>
  </aside>

  <!-- SCROLL CONTAINER -->
  <main class="scroll-wrap" id="scroll-wrap">

    <!-- ═══════════════ SECTION 0: HERO ═══════════════ -->
    <section class="panel" id="panel-0">
      <!-- VIDEO BG: aerial mountain/landscape -->
      <video class="panel-vid" autoplay muted loop playsinline
        poster="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&q=85">
        <source src="https://cdn.coverr.co/videos/coverr-a-green-mountain-4652/1080p.mp4" type="video/mp4"/>
        <source src="https://cdn.coverr.co/videos/coverr-mountain-tops-tcmng2orss/1080p.mp4" type="video/mp4"/>
      </video>
      <div class="panel-overlay panel-overlay--hero"></div>
      <div class="hero-wrap">
        <div class="hero-eyebrow">✦ AI-Powered Travel Curation</div>
        <h1 class="hero-h1">Travel Beyond<br/><em>The Horizon.</em></h1>
        <p class="hero-lead">Discover the world's most extraordinary destinations,<br/>handpicked by AI and curated for you.</p>
        <div class="hero-stats">
          <div class="stat-item"><span class="stat-n">2.4M+</span><span class="stat-l">Travelers</span></div>
          <div class="stat-div"></div>
          <div class="stat-item"><span class="stat-n">190+</span><span class="stat-l">Countries</span></div>
          <div class="stat-div"></div>
          <div class="stat-item"><span class="stat-n">98%</span><span class="stat-l">Satisfaction</span></div>
        </div>
      </div>
      <div class="scroll-cue"><span>Scroll</span><div class="scroll-line"></div></div>
    </section>

    <!-- ═══════════════ SECTION 1: HOTELS ═══════════════ -->
    <section class="panel" id="panel-1">
      <!-- VIDEO BG: beach resort / tropical water -->
      <video class="panel-vid" autoplay muted loop playsinline preload="none"
        poster="https://images.unsplash.com/photo-1582719508461-905c673771fd?w=1800&q=85">
        <source src="https://cdn.coverr.co/videos/coverr-beach-to-the-ocean-170/1080p.mp4" type="video/mp4"/>
        <source src="https://cdn.coverr.co/videos/coverr-beach-to-the-ocean-170/720p.mp4" type="video/mp4"/>
      </video>
      <div class="panel-overlay panel-overlay--warm"></div>
      <div class="panel-content">
        <div class="section-label">🏨 Hotels</div>
        <h2 class="section-h2">Legendary<br/><em>Stays</em></h2>
        <p class="section-lead">Where luxury meets the extraordinary</p>
        <div class="slider-wrapper">
          <button class="slider-arrow slider-prev" id="hotel-prev">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="cards-row" id="hotels-row" data-api-url="{{ path('api_hebergements_all') }}"></div>
          <button class="slider-arrow slider-next" id="hotel-next">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- SECTION 2: FLIGHTS -->
    <section class="panel" id="panel-2">
      <!-- VIDEO BG: above clouds, aerial sky -->
      <video class="panel-vid" autoplay muted loop playsinline preload="none"
        poster="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1800&q=85">
        <source src="https://cdn.coverr.co/videos/coverr-airplane-flying-through-the-clouds-1025/1080p.mp4" type="video/mp4"/>
        <source src="https://cdn.coverr.co/videos/coverr-airplane-flying-through-the-clouds-1025/720p.mp4" type="video/mp4"/>
      </video>
      <div class="panel-overlay panel-overlay--sky"></div>
      <div class="panel-content">
        <div class="section-label">Flights</div>
        <h2 class="section-h2">Book Real<br/><em>Flights</em></h2>
        <p class="section-lead">Search live flight offers, reserve your ticket, and activate AI recommendations.</p>
        <a href="{{ path('app_flights_search') }}" class="trip-btn" style="width:max-content; text-decoration:none; margin-top:1rem;">
          Open flight booking
        </a>
      </div>
    </section>

    <!-- ═══════════════ SECTION 3: ACTIVITIES ═══════════════ -->
    <section class="panel" id="panel-3">
      <!-- VIDEO BG: mountain hiking / landscape -->
      <video class="panel-vid" autoplay muted loop playsinline preload="none"
        poster="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1800&q=85">
        <source src="https://cdn.coverr.co/videos/coverr-walking-to-the-mountain-top-8360/1080p.mp4" type="video/mp4"/>
        <source src="https://cdn.coverr.co/videos/coverr-walking-to-the-mountain-top-8360/720p.mp4" type="video/mp4"/>
      </video>
      <div class="panel-overlay panel-overlay--forest"></div>
      <div class="panel-content">
        <div class="section-label">🗺 Activities</div>
        <h2 class="section-h2">Epic<br/><em>Experiences</em></h2>
        <p class="section-lead">Curated adventures you will never forget</p>
        <div class="cards-row act-grid" id="acts-row"></div>
      </div>
    </section>

    <!-- ═══════════════ SECTION 4: REVIEWS ═══════════════ -->
    <section class="panel" id="panel-4">
      <!-- VIDEO BG: serene lake / night sky -->
      <video class="panel-vid" autoplay muted loop playsinline preload="none"
        poster="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1800&q=85">
        <source src="https://cdn.coverr.co/videos/coverr-sunset-in-indonesia-3381/1080p.mp4" type="video/mp4"/>
        <source src="https://cdn.coverr.co/videos/coverr-sunset-in-indonesia-3381/720p.mp4" type="video/mp4"/>
      </video>
      <div class="panel-overlay panel-overlay--deep"></div>
      <div class="panel-content panel-content--center">
        <div class="section-label">★ Reviews</div>
        <h2 class="section-h2">Traveler<br/><em>Stories</em></h2>
        <div class="reviews-grid" id="reviews-grid"></div>
        <div class="rating-pill">
          <div class="rating-n">4.9</div>
          <div class="rating-stars">★★★★★</div>
          <div class="rating-sub">Based on 48,291 reviews</div>
        </div>
      </div>
    </section>

  </main>

  <script src="horizon-3d.js?v=24"></script>
    <style>
        /* Extract from friend's results.html.twig - Global Overlays */
        .payment-modal-overlay {
            position: fixed; inset: 0; z-index: 9999; display: none; align-items: center; justify-content: center; padding: 24px;
            background: rgba(3, 7, 18, 0.7); backdrop-filter: blur(28px) saturate(180%);
        }
        .payment-modal-overlay.active { display: flex; }
        .payment-modal-box {
            width: min(660px, 94%); max-height: 88vh; overflow-y: auto; overflow-x: hidden; border-radius: 32px;
            border: 1px solid rgba(255, 255, 255, 0.18); background: rgba(10, 15, 30, 0.95);
            box-shadow: 0 50px 100px rgba(0, 0, 0, 0.7); padding: 44px; color: #fff;
            transform-origin: center;
        }
        .payment-modal-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 28px; }
        .payment-modal-title { margin: 0; font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; font-weight: 500; color: #fff; }
        .payment-modal-close {
            width: 44px; height: 44px; border: none; border-radius: 50%; cursor: pointer; color: #fff;
            background: rgba(255, 255, 255, 0.1); display: flex; align-items: center; justify-content: center;
        }
        .payment-summary { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 24px; }
        .payment-summary-card { border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); padding: 20px; }
        .payment-summary-label { display: block; margin-bottom: 4px; color: rgba(255,255,255,0.4); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
        .payment-summary-value { color: #fff; font-size: 1.1rem; font-weight: 700; }
        .payment-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .payment-field.full { grid-column: 1 / -1; }
        .payment-field label { display: block; color: #fff; font-weight: 600; font-size: 0.85rem; margin-bottom: 8px; }
        .payment-field input, .payment-field select {
            width: 100%; height: 50px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.1); color: #fff; padding: 0 16px; outline: none;
        }
        .payment-actions { display: grid; grid-template-columns: 1fr 1.2fr; gap: 16px; margin-top: 30px; }
        .payment-cancel-btn { height: 54px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; cursor: pointer; }
        .payment-submit-btn { height: 54px; border: none; border-radius: 14px; background: #e8c97e; color: #000; font-weight: 800; cursor: pointer; }
    </style>

    <!-- FRIEND'S MODAL HTML MOVED TO END OF BODY -->
    <div class="payment-modal-overlay" id="paymentModal">
        <div class="payment-modal-box">
            <div class="payment-modal-header">
                <h2 class="payment-modal-title">Paiement du billet</h2>
                <button type="button" class="payment-modal-close" id="closePaymentModal">✕</button>
            </div>

            <div class="payment-summary">
                <div class="payment-summary-card">
                    <span class="payment-summary-label">Référence</span>
                    <span class="payment-summary-value" id="paymentReference">-</span>
                </div>
                <div class="payment-summary-card">
                    <span class="payment-summary-label">Prix</span>
                    <span class="payment-summary-value" id="paymentPrice">-</span>
                </div>
                <div class="payment-summary-card">
                    <span class="payment-summary-label">Trajet</span>
                    <span class="payment-summary-value" id="paymentRoute">-</span>
                </div>
                <div class="payment-summary-card">
                    <span class="payment-summary-label">Transport</span>
                    <span class="payment-summary-value" id="paymentTransport">-</span>
                </div>
            </div>

            <form id="paymentForm" method="post" action="/vols/paiement">
                <input type="hidden" name="billet_id" id="paymentBilletId">
                <input type="hidden" name="reservation_id" id="paymentReservationId">
                <input type="hidden" name="selected_price" id="paymentSelectedPrice">

                <div class="payment-form-grid">
                    <div class="payment-field full">
                        <label for="paymentMethod">Mode de paiement</label>
                        <select id="paymentMethod" name="payment_method" required>
                            <option value="">Choisir</option>
                            <option value="carte">Carte bancaire</option>
                            <option value="paypal">PayPal</option>
                            <option value="virement">Virement</option>
                        </select>
                    </div>
                    <div class="payment-field full">
                        <label for="cardName">Nom du titulaire</label>
                        <input type="text" id="cardName" name="card_name" placeholder="Nom complet" required>
                    </div>
                    <div class="payment-field full">
                        <label for="cardNumber">Numéro de carte</label>
                        <input type="text" id="cardNumber" name="card_number" placeholder="1234 5678 9012 3456" required>
                    </div>
                    <div class="payment-field">
                        <label for="cardExpiry">Date d’expiration</label>
                        <input type="text" id="cardExpiry" name="card_expiry" placeholder="MM/AA" required>
                    </div>
                    <div class="payment-field">
                        <label for="cardCvv">CVV</label>
                        <input type="text" id="cardCvv" name="card_cvv" placeholder="123" required>
                    </div>
                </div>

                <div class="payment-actions">
                    <button type="button" class="payment-cancel-btn" id="cancelPaymentBtn">Annuler</button>
                    <button type="submit" class="payment-submit-btn">Payer maintenant</button>
                </div>
            </form>
        </div>
    </div>

  <!-- ═══════════════ AI CHATBOT WIDGET ═══════════════ -->
  <style>
    /* ── Floating button ── */
    #chatbot-fab {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: linear-gradient(135deg, #e8c97e, #c9a050);
      border: none;
      cursor: pointer;
      z-index: 9000;
      box-shadow: 0 8px 32px rgba(232,201,126,0.4), 0 2px 8px rgba(0,0,0,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
      animation: fab-pulse 3s ease-in-out infinite;
    }
    #chatbot-fab:hover {
      transform: scale(1.12);
      box-shadow: 0 12px 40px rgba(232,201,126,0.55), 0 2px 8px rgba(0,0,0,0.5);
    }
    #chatbot-fab svg { width: 28px; height: 28px; fill: #0a0f1e; transition: opacity 0.2s; }
    #chatbot-fab .fab-close { display: none; }
    #chatbot-fab.open .fab-open  { display: none; }
    #chatbot-fab.open .fab-close { display: block; }
    @keyframes fab-pulse {
      0%,100% { box-shadow: 0 8px 32px rgba(232,201,126,0.4), 0 2px 8px rgba(0,0,0,0.5); }
      50%      { box-shadow: 0 8px 48px rgba(232,201,126,0.65), 0 2px 8px rgba(0,0,0,0.5); }
    }
    /* ── Badge ── */
    #chatbot-badge {
      position: absolute;
      top: -4px; right: -4px;
      width: 20px; height: 20px;
      background: #ef4444;
      border-radius: 50%;
      border: 2px solid #0a0f1e;
      font-size: 0.65rem;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      animation: badge-pop 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes badge-pop { from { transform: scale(0); } to { transform: scale(1); } }

    /* ── Chat panel ── */
    #chatbot-panel {
      position: fixed;
      bottom: 5.5rem;
      right: 2rem;
      width: 370px;
      max-height: 560px;
      background: rgba(8,12,24,0.97);
      border: 1px solid rgba(232,201,126,0.2);
      border-radius: 24px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(232,201,126,0.05);
      backdrop-filter: blur(24px);
      z-index: 8999;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transform: translateY(20px) scale(0.95);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s;
      font-family: 'Inter', sans-serif;
    }
    #chatbot-panel.open {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: all;
    }

    /* ── Panel header ── */
    .cb-header {
      padding: 1.1rem 1.3rem;
      background: linear-gradient(135deg, rgba(232,201,126,0.12), rgba(201,160,80,0.06));
      border-bottom: 1px solid rgba(232,201,126,0.12);
      display: flex;
      align-items: center;
      gap: 0.8rem;
      flex-shrink: 0;
    }
    .cb-avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, #e8c97e, #c9a050);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .cb-header-info { flex: 1; }
    .cb-title { color: #e8c97e; font-weight: 700; font-size: 0.92rem; letter-spacing: 0.3px; }
    .cb-subtitle { color: rgba(255,255,255,0.4); font-size: 0.72rem; margin-top: 1px; }
    .cb-status-dot {
      width: 8px; height: 8px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 6px #22c55e;
      flex-shrink: 0;
    }

    /* ── Messages area ── */
    #cb-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(232,201,126,0.2) transparent;
    }
    #cb-messages::-webkit-scrollbar { width: 4px; }
    #cb-messages::-webkit-scrollbar-thumb { background: rgba(232,201,126,0.2); border-radius: 2px; }

    .cb-msg {
      max-width: 84%;
      padding: 0.7rem 0.95rem;
      border-radius: 16px;
      font-size: 0.85rem;
      line-height: 1.5;
      animation: msg-in 0.25s ease;
    }
    @keyframes msg-in { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
    .cb-msg.bot {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.88);
      align-self: flex-start;
      border-bottom-left-radius: 4px;
    }
    .cb-msg.user {
      background: linear-gradient(135deg, rgba(232,201,126,0.22), rgba(201,160,80,0.15));
      border: 1px solid rgba(232,201,126,0.2);
      color: #e8c97e;
      align-self: flex-end;
      border-bottom-right-radius: 4px;
    }

    /* ── Typing indicator ── */
    .cb-typing {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 0.7rem 0.95rem;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      border-bottom-left-radius: 4px;
      align-self: flex-start;
      width: fit-content;
    }
    .cb-typing span {
      width: 6px; height: 6px;
      background: rgba(232,201,126,0.6);
      border-radius: 50%;
      animation: typing-dot 1.2s ease-in-out infinite;
    }
    .cb-typing span:nth-child(2) { animation-delay: 0.2s; }
    .cb-typing span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typing-dot {
      0%,80%,100% { transform: scale(0.7); opacity: 0.4; }
      40%          { transform: scale(1);   opacity: 1;   }
    }

    /* ── Input area ── */
    .cb-input-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem;
      border-top: 1px solid rgba(255,255,255,0.07);
      flex-shrink: 0;
    }
    #cb-input {
      flex: 1;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 0.65rem 0.9rem;
      color: #fff;
      font-size: 0.85rem;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s;
      resize: none;
    }
    #cb-input:focus { border-color: rgba(232,201,126,0.4); }
    #cb-input::placeholder { color: rgba(255,255,255,0.3); }
    #cb-send {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: linear-gradient(135deg, #e8c97e, #c9a050);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: opacity 0.2s, transform 0.15s;
    }
    #cb-send:hover { opacity: 0.85; transform: scale(1.05); }
    #cb-send:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    #cb-send svg { width: 16px; height: 16px; fill: #0a0f1e; }

    /* ── Responsive ── */
    @media (max-width: 440px) {
      #chatbot-panel { width: calc(100vw - 2rem); right: 1rem; }
      #chatbot-fab   { right: 1rem; bottom: 1rem; }
    }
  </style>

  <!-- Floating Action Button -->
  <button id="chatbot-fab" aria-label="Open AI Travel Assistant" onclick="cbToggle()">
    <div id="chatbot-badge">1</div>
    <!-- Chat icon (open state) -->
    <svg class="fab-open" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-2 10H6v-2h12v2zm0-3H6V7h12v2z"/>
    </svg>
    <!-- Close icon (close state) -->
    <svg class="fab-close" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>

  <!-- Chat Panel -->
  <div id="chatbot-panel" role="dialog" aria-label="Travelia AI Assistant">
    <div class="cb-header">
      <div class="cb-avatar">🤖</div>
      <div class="cb-header-info">
        <div class="cb-title">Travelia Assistant</div>
        <div class="cb-subtitle">Powered by Groq AI · LLaMA</div>
      </div>
      <div class="cb-status-dot" title="Online"></div>
    </div>

    <div id="cb-messages">
      <!-- Welcome message -->
      <div class="cb-msg bot">
        Bonjour ! 👋 Je suis l'assistant IA de <strong>Travelia</strong>.<br>
        Je peux vous aider avec les hôtels, vols, réservations et paiements.<br>
        Comment puis-je vous aider aujourd'hui ?
      </div>
    </div>

    <div class="cb-input-row">
      <input
        id="cb-input"
        type="text"
        placeholder="Posez votre question..."
        maxlength="500"
        autocomplete="off"
        onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); cbSend(); }"
      />
      <button id="cb-send" onclick="cbSend()" aria-label="Send">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>

  <script>
    // ── State ──────────────────────────────────────────────────────────────────
    const cbHistory  = [];          // conversation turns sent to API
    let   cbOpen     = false;
    let   cbBusy     = false;
    const CHAT_URL   = '{{ path("app_chatbot_chat") }}';

    // ── Toggle panel ──────────────────────────────────────────────────────────
    function cbToggle() {
      cbOpen = !cbOpen;
      document.getElementById('chatbot-panel').classList.toggle('open', cbOpen);
      document.getElementById('chatbot-fab').classList.toggle('open', cbOpen);
      // Hide badge when opened
      if (cbOpen) {
        const badge = document.getElementById('chatbot-badge');
        if (badge) badge.style.display = 'none';
        document.getElementById('cb-input').focus();
      }
    }

    // ── Send message ───────────────────────────────────────────────────────────
    async function cbSend() {
      if (cbBusy) return;
      const input = document.getElementById('cb-input');
      const text  = input.value.trim();
      if (!text) return;

      // Append user bubble
      cbAppend('user', text);
      cbHistory.push({ role: 'user', content: text });
      input.value = '';
      input.disabled = true;
      document.getElementById('cb-send').disabled = true;
      cbBusy = true;

      // Show typing indicator
      const typing = cbShowTyping();

      try {
        const res  = await fetch(CHAT_URL, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ message: text, history: cbHistory.slice(-20) }),
        });
        const data = await res.json();
        const reply = data.reply || data.error || 'Désolé, une erreur est survenue.';

        typing.remove();
        cbAppend('bot', reply);
        cbHistory.push({ role: 'assistant', content: reply });

      } catch (e) {
        typing.remove();
        cbAppend('bot', '❌ Impossible de contacter l\'assistant. Vérifiez votre connexion.');
      } finally {
        cbBusy = false;
        input.disabled = false;
        document.getElementById('cb-send').disabled = false;
        input.focus();
      }
    }

    // ── Append a message bubble ───────────────────────────────────────────────
    function cbAppend(role, text) {
      const msgs = document.getElementById('cb-messages');
      const div  = document.createElement('div');
      div.className = 'cb-msg ' + role;
      div.innerHTML = cbEscape(text).replace(/\n/g, '<br>');
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
    }

    // ── Show typing dots ──────────────────────────────────────────────────────
    function cbShowTyping() {
      const msgs = document.getElementById('cb-messages');
      const div  = document.createElement('div');
      div.className = 'cb-typing';
      div.innerHTML = '<span></span><span></span><span></span>';
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
      return div;
    }

    // ── XSS-safe text escape ──────────────────────────────────────────────────
    function cbEscape(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
    }

    // ── Close panel on Escape ─────────────────────────────────────────────────
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && cbOpen) cbToggle();
    });
  </script>

</body>
</html>

