{{ form_start(form, {
    'action': form_action|default(form.vars.action),
    'attr': form.vars.attr|merge({'novalidate': 'novalidate'})
}) }}

<style>
    .travelia-form {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        position: relative;
    }

    .field-group label {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.88);
        font-weight: 700;
    }

    .field-group input {
        width: 100%;
        padding: 1.05rem 1.2rem;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.08);
        color: #fff;
        outline: none;
        font-size: 0.95rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        backdrop-filter: blur(10px);
        min-height: 56px;
        box-sizing: border-box;
    }

    .field-group select {
        width: 100%;
        padding: 1.05rem 1.2rem;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.08);
        color: #fff;
        outline: none;
        font-size: 0.95rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        backdrop-filter: blur(10px);
        min-height: 56px;
        box-sizing: border-box;
    }

    .field-group input:focus,
    .field-group select:focus {
        border-color: rgba(201, 168, 76, 0.45);
        box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.08);
    }

    .field-group option {
        color: #111;
    }

    .field-group input::placeholder {
        color: rgba(255,255,255,0.40);
    }

    .date-group {
        position: relative;
        overflow: hidden;
    }

    .date-group::after {
        content: "📅";
        position: absolute;
        right: 1.15rem;
        top: 2.9rem;
        font-size: 1.05rem;
        opacity: 0.85;
        pointer-events: none;
    }

    .date-group::after {
        content: none;
    }

    .date-group input[type="date"] {
        padding-right: 3.75rem;
        appearance: none;
        -webkit-appearance: none;
        position: relative;
    }

    .date-group input[type="date"]::-webkit-calendar-picker-indicator {
        opacity: 0.92;
        cursor: pointer;
        padding: 0.65rem 0.85rem 0.65rem 1rem;
        margin-right: -0.45rem;
        border-left: 1px solid rgba(255,255,255,0.10);
        filter: invert(84%) sepia(19%) saturate(560%) hue-rotate(358deg) brightness(98%) contrast(89%);
    }

    .date-group input[type="date"]::-webkit-datetime-edit,
    .date-group input[type="date"]::-webkit-datetime-edit-fields-wrapper {
        color: #fff;
    }

    .date-group input[type="date"]::-webkit-date-and-time-value {
        text-align: left;
    }

    .field-errors {
        color: #ef4444;
        font-size: 0.78rem;
        margin-top: 0.2rem;
    }

    .global-errors {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.25);
        color: #ef4444;
        padding: 1rem 1.2rem;
        border-radius: 14px;
        margin-bottom: 0.5rem;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }

    .save-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.95rem 1.5rem;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        background: linear-gradient(135deg, #d7b85a, #e7c86e);
        color: #111;
        box-shadow: 0 8px 25px rgba(201, 168, 76, 0.25);
        min-width: 180px;
    }

    .save-btn:hover {
        opacity: 0.95;
    }
</style>

<div class="travelia-form">
    {% if form_errors(form) %}
        <div class="global-errors">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="field-group date-group">
        {{ form_label(form.dateReservation) }}
        {{ form_widget(form.dateReservation, {
            attr: (form.dateReservation.vars.attr|default({}))|merge({
                class: ((form.dateReservation.vars.attr.class|default('')) ~ ' js-travelia-datepicker')|trim
            })
        }) }}
        <div class="field-errors">{{ form_errors(form.dateReservation) }}</div>
    </div>

    <div class="field-group">
        {{ form_label(form.statut) }}
        {{ form_widget(form.statut) }}
        <div class="field-errors">{{ form_errors(form.statut) }}</div>
    </div>

    <div class="field-group">
        {{ form_label(form.modalitesPaiement) }}
        {{ form_widget(form.modalitesPaiement) }}
        <div class="field-errors">{{ form_errors(form.modalitesPaiement) }}</div>
    </div>

    <div class="field-group">
        {{ form_label(form.clientId) }}
        {{ form_widget(form.clientId) }}
        <div class="field-errors">{{ form_errors(form.clientId) }}</div>
    </div>

    {% if form.paysDestination is defined %}
        <div class="field-group">
            {{ form_label(form.paysDestination) }}
            {{ form_widget(form.paysDestination) }}
            <div class="field-errors">{{ form_errors(form.paysDestination) }}</div>
        </div>
    {% endif %}

    <div class="form-actions">
        <button type="submit" class="save-btn">
            {{ button_label|default('Créer') }}
        </button>
    </div>
</div>

{{ form_end(form) }}
