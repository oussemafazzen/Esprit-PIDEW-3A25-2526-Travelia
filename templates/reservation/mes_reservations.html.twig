    {% else %}
      <div class="res-list">
        {% for reservation in reservations %}
          {% set statutClass = reservation.statut|lower starts with 'confirm' ? 'confirme' : (reservation.statut|lower starts with 'annul' ? 'annule' : 'attente') %}
          <div class="res-card">
            <div class="res-card-top">
              <div class="res-card-left">
                <div class="res-icon">✈</div>
                <div>
                  <div class="res-title">Réservation #{{ reservation.id }}</div>
                  <div class="res-date">{{ reservation.dateReservation ? reservation.dateReservation|date('d/m/Y') : '' }}</div>
                </div>
              </div>
              <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
                <span class="res-dots">— —</span>
                <span class="status-pill {{ statutClass }}">{{ reservation.statut }}</span>
