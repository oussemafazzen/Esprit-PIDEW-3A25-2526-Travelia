    {# ── Build calendar data ── #}
    {% set calItems = [] %}
    {% for r in reservations %}
      {% if r.dateReservation %}
        {% set calItems = calItems|merge([{
          id: r.id,
          date: r.dateReservation|date('Y-m-d'),
          destination: r.paysDestination ?? 'Destination inconnue',
          status: r.statut ?? ''
        }]) %}
