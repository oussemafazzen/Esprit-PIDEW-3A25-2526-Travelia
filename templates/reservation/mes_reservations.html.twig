    <script id="res-cal-data" type="application/json">{{ calItems|json_encode|raw }}</script>

    {# ── Calendar toggle button ── #}
    <button type="button" class="cal-toggle-btn" id="calToggleBtn"
            aria-controls="resCal" aria-expanded="false">
      📅 Calendrier
    </button>

    {# ── Calendar card ── #}
    <section class="res-calendar-card" id="resCal" hidden>
      <div class="res-cal-top">
        <div>
          <p class="res-cal-kicker">Calendrier</p>
          <h2 class="res-cal-title">Dates <em>réservées</em></h2>
        </div>
        <div class="res-cal-nav-wrap">
          <button type="button" class="res-cal-nav" id="calPrev" aria-label="Mois précédent">‹</button>
          <div class="res-cal-month-label" id="calMonthLabel"></div>
          <button type="button" class="res-cal-nav" id="calNext" aria-label="Mois suivant">›</button>
        </div>
      </div>
      <div class="res-cal-weekdays" aria-hidden="true">
        <span>Lun</span><span>Mar</span><span>Mer</span>
        <span>Jeu</span><span>Ven</span><span>Sam</span><span>Dim</span>
