  <script>
    /* ─── CALENDAR ENGINE ─── */
    (function() {
      const toggleBtn   = document.getElementById('calToggleBtn');
      const calSection  = document.getElementById('resCal');
      const calGrid     = document.getElementById('calGrid');
      const calMonthLbl = document.getElementById('calMonthLabel');
      const calPrev     = document.getElementById('calPrev');
      const calNext     = document.getElementById('calNext');
      const calDetails  = document.getElementById('calDetails');

      const rawData = JSON.parse(document.getElementById('res-cal-data').textContent || '[]');
      const byDate  = rawData.reduce((acc, r) => {
        if (!r.date) return acc;
        (acc[r.date] = acc[r.date] || []).push(r);
        return acc;
      }, {});

      let curDate  = new Date();
      let selected = null;

      const pad = n => String(n).padStart(2, '0');
      const key = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;

      function safeDate(y, m, d) {
        const dt = new Date(y, m, d);
        if (isNaN(dt.getTime())) { console.error('Invalid date', y, m, d); return new Date(); }
        return dt;
      }

      function renderCalDetails(dateKey) {
        const items = byDate[dateKey] || [];
        if (!dateKey || items.length === 0) {
          calDetails.innerHTML = '<p style="color:rgba(255,255,255,0.35);font-size:0.85rem;">Cliquez sur un jour surligné pour voir vos réservations.</p>';
          return;
        }
        calDetails.innerHTML = '<p class="res-cal-details-title">Réservations du ' + dateKey + '</p>'
          + '<div style="display:flex;flex-wrap:wrap;gap:8px;">' + items.map(r =>
            `<span class="res-cal-pill">✈ Réservation #<strong>${r.id}</strong> — ${r.destination}</span>`
          ).join('') + '</div>';
      }

      function render() {
        const y = curDate.getFullYear();
        const m = curDate.getMonth();
        calMonthLbl.textContent = new Date(y, m, 1).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
        calGrid.innerHTML = '';

        const firstDay = safeDate(y, m, 1);
        const totalDays = new Date(y, m + 1, 0).getDate();
        const today = key(new Date());

        // Mon=1 → offset 0, Sun=0 → offset 6
        let startOffset = firstDay.getDay() - 1;
        if (startOffset < 0) startOffset = 6;

        // Prev month filler
        const prevMonthDays = new Date(y, m, 0).getDate();
        for (let i = startOffset - 1; i >= 0; i--) {
          const d = document.createElement('div');
          d.className = 'res-cal-day is-muted';
          d.textContent = prevMonthDays - i;
          calGrid.appendChild(d);
        }

        // Current month days
        for (let d = 1; d <= totalDays; d++) {
          const dateKey = `${y}-${pad(m+1)}-${pad(d)}`;
          const reservations = byDate[dateKey];
          const btn = document.createElement('div');
          btn.className = 'res-cal-day';
          if (dateKey === today) btn.classList.add('is-today');
          if (dateKey === selected) btn.classList.add('is-selected');
          if (reservations) btn.classList.add('has-res');
          btn.textContent = d;
          if (reservations) {
            const badge = document.createElement('span');
            badge.className = 'res-cal-count';
            badge.textContent = reservations.length;
            btn.appendChild(badge);
            btn.addEventListener('click', () => {
              selected = dateKey;
              render();
              renderCalDetails(dateKey);
            });
          }
          calGrid.appendChild(btn);
        }

        // Next month filler
        const totalCells = startOffset + totalDays;
        const remaining = (7 - (totalCells % 7)) % 7;
        for (let d = 1; d <= remaining; d++) {
          const el = document.createElement('div');
          el.className = 'res-cal-day is-muted';
          el.textContent = d;
          calGrid.appendChild(el);
        }

        if (!selected) renderCalDetails('');
      }

      toggleBtn.addEventListener('click', function() {
        const hidden = calSection.hasAttribute('hidden');
        if (hidden) { calSection.removeAttribute('hidden'); this.setAttribute('aria-expanded','true'); render(); }
        else         { calSection.setAttribute('hidden','hidden'); this.setAttribute('aria-expanded','false'); }
      });

      calPrev.addEventListener('click', () => { curDate = safeDate(curDate.getFullYear(), curDate.getMonth()-1, 1); selected=null; render(); });
      calNext.addEventListener('click', () => { curDate = safeDate(curDate.getFullYear(), curDate.getMonth()+1, 1); selected=null; render(); });
    })();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let formToSubmit = null;
      const deleteModal = document.getElementById('deleteModal');
      const editModal = document.getElementById('editModal');
      const updateForm = document.getElementById('quickUpdateForm');

      // ─── EDIT LOGIC ───
      document.querySelectorAll('.js-edit-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          document.getElementById('editRid').value = btn.dataset.rid;
          document.getElementById('editDest').value = btn.dataset.dest;
          document.getElementById('editDate').value = btn.dataset.date;
          
          editModal.classList.add('active');
          gsap.fromTo(editModal.querySelector('.payment-modal-box'), 
            { scale: 0.9, opacity: 0, y: 20 },
            { scale: 1, opacity: 1, y: 0, duration: 0.4, ease: "expo.out" }
          );
        });
      });

      updateForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const rid = document.getElementById('editRid').value;
        const formData = new FormData(updateForm);
        try {
          const resp = await fetch(`/reservation/${rid}/quick-update`, { method: 'POST', body: formData });
          if (resp.ok) location.reload();
          else alert("Erreur lors de la mise à jour.");
        } catch(e) { alert("Erreur réseau."); }
      });

      const closeEdit = () => {
        gsap.to(editModal.querySelector('.payment-modal-box'), {
          scale: 0.9, opacity: 0, y: 10, duration: 0.3, ease: "power2.in",
          onComplete: () => editModal.classList.remove('active')
        });
      };
      document.querySelector('.js-close-edit').addEventListener('click', closeEdit);
      editModal.addEventListener('click', (e) => { if(e.target === editModal) closeEdit(); });

      // ─── DELETE LOGIC ───
      document.querySelectorAll('.js-delete-trigger').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          formToSubmit = btn.closest('form');
          deleteModal.classList.add('active');
          gsap.fromTo(deleteModal.querySelector('.payment-modal-box'), 
            { scale: 0.9, opacity: 0 },
            { scale: 1, opacity: 1, duration: 0.4, ease: "expo.out" }
          );
        });
      });

      document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
        if (formToSubmit) formToSubmit.submit();
      });

      const closeDelete = () => {
        gsap.to(deleteModal.querySelector('.payment-modal-box'), {
          scale: 0.9, opacity: 0, duration: 0.3, ease: "power2.in",
          onComplete: () => deleteModal.classList.remove('active')
        });
      };
      document.querySelector('.js-close-delete').addEventListener('click', closeDelete);
      deleteModal.addEventListener('click', (e) => { if(e.target === deleteModal) closeDelete(); });
    });
  </script>

  <!-- LIVE CANVAS ANIMATION (Bokeh + Streaks, identical to Reservations branch) -->
  <script>
  (function() {
    const canvas = document.getElementById('live-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    window.addEventListener('resize', () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });

    let mouseX = W/2, mouseY = H/2, targetMX = W/2, targetMY = H/2;
    window.addEventListener('mousemove', e => { targetMX = e.clientX; targetMY = e.clientY; });
    function lerp(a,b,t){ return a+(b-a)*t; }
    function rand(a,b){ return a+Math.random()*(b-a); }

    /* ── Drifting gold bokeh orbs ── */
    const bokeh = Array.from({length:55}, () => ({
      x: rand(0,W), y: rand(0,H),
      r: rand(8,48),
      vx: rand(-0.18,0.18), vy: rand(-0.32,-0.06),
      a: rand(0.03,0.14),
      hue: rand(28,52),
      phase: rand(0,Math.PI*2)
    }));

    /* ── Light streaks (flight trails) ── */
    const streaks = Array.from({length:10}, () => ({
      x: rand(-200,W+200), y: rand(H*0.05, H*0.85),
      vx: rand(1.8,4.5), vy: rand(-0.4,0.4),
      len: rand(100,340),
      a: rand(0.05,0.15),
      width: rand(0.5,1.8),
      phase: rand(0,Math.PI*2),
      hue: rand(195,235)
    }));

    let t = 0;
    function tick() {
      requestAnimationFrame(tick);
      t += 0.016;
      mouseX = lerp(mouseX, targetMX, 0.04);
      mouseY = lerp(mouseY, targetMY, 0.04);
      ctx.clearRect(0, 0, W, H);

      /* Bokeh orbs */
      bokeh.forEach(p => {
        p.phase += 0.011;
        p.x += p.vx + Math.sin(p.phase*0.5)*0.13;
        p.y += p.vy;
        if (p.y < -p.r*2) { p.y = H+p.r; p.x = rand(0,W); }
        const a = p.a*(0.5+0.5*Math.sin(p.phase));
        const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r);
        g.addColorStop(0,`hsla(${p.hue},88%,72%,${a})`);
        g.addColorStop(1,'transparent');
        ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx.fillStyle=g; ctx.fill();
      });

      /* Light streaks */
      streaks.forEach(s => {
        s.phase += 0.014;
        s.x += s.vx; s.y += s.vy;
        if (s.x > W+400) { s.x = -400; s.y = rand(H*0.05, H*0.85); }
        const opacity = s.a*(0.45+0.55*Math.sin(s.phase));
        const grad = ctx.createLinearGradient(s.x-s.len, s.y, s.x, s.y);
        grad.addColorStop(0,'transparent');
        grad.addColorStop(0.6,`hsla(${s.hue},85%,85%,${opacity*0.5})`);
        grad.addColorStop(1,`hsla(${s.hue},90%,95%,${opacity})`);
        ctx.beginPath(); ctx.moveTo(s.x-s.len, s.y); ctx.lineTo(s.x, s.y);
        ctx.strokeStyle=grad; ctx.lineWidth=s.width; ctx.stroke();
      });

      /* Subtle mouse cursor glow */
      const cg = ctx.createRadialGradient(mouseX,mouseY,0,mouseX,mouseY,160);
      cg.addColorStop(0,'rgba(201,168,76,0.06)');
      cg.addColorStop(1,'transparent');
      ctx.fillStyle=cg; ctx.fillRect(0,0,W,H);

      /* Bottom warm vignette */
      const vig = ctx.createLinearGradient(0,H*0.55,0,H);
      vig.addColorStop(0,'transparent');
      vig.addColorStop(1,'rgba(30,10,5,0.28)');
      ctx.fillStyle=vig; ctx.fillRect(0,0,W,H);
    }
    tick();
  })();
  </script>

</body>
</html>
