<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mes Réservations — Travelia</title>
  <meta name="description" content="Consultez vos réservations et vos billets dans une interface moderne." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #c9a84c;
      --gold2: #e8c97e;
      --ink: #080c18;
      --white: #f5f0e8;
      --serif: 'Cormorant Garamond', serif;
      --sans: 'Inter', sans-serif;
      --grotesk: 'Space Grotesk', sans-serif;
      --panel: rgba(10, 15, 30, 0.75);
      --gbord: rgba(255,255,255,0.08);
      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    html, body {
      min-height: 100vh;
      font-family: var(--sans);
      color: var(--white);
      background: var(--ink);
      overflow-x: hidden;
    }

    /* ─── CINEMATIC BACKGROUND ─── */
    .page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        linear-gradient(to bottom, rgba(8,12,24,0.55) 0%, rgba(8,12,24,0.3) 40%, rgba(8,12,24,0.6) 100%);
    }
    .page-bg img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -1;
      filter: brightness(0.75) saturate(0.9);
    }

    /* ─── NAV ─── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 72px;
      background: rgba(8,10,22,0.6);
      backdrop-filter: blur(28px) saturate(160%);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: background 0.4s var(--ease);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--white);
    }
    .nav-logo-mark {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 600;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 20px rgba(201,168,76,0.4);
    }
    .nav-logo-text {
      font-family: var(--grotesk);
      font-size: 1.15rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .nav-links { display: flex; gap: 2.5rem; align-items: center; }
    .nav-link {
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: color 0.3s;
      position: relative;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0; right: 0;
      height: 1px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s var(--ease);
    }
    .nav-link:hover, .nav-link.active { color: var(--white); }
    .nav-link.active::after, .nav-link:hover::after { transform: scaleX(1); }
    
    .nav-link.active-gold { 
      color: var(--gold) !important; 
      font-weight: 600; 
      border-left: 1px solid rgba(201,168,76,0.3);
      padding-left: 1.4rem;
      margin-left: 0.4rem;
    }
    .nav-link.active-gold::after { display: none; }

    .trip-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
      color: var(--ink);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 0.55rem 1.3rem;
      border-radius: 100px;
      transition: all 0.3s var(--ease);
      box-shadow: 0 4px 20px rgba(201,168,76,0.35);
      text-decoration: none;
    }
    .trip-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(201,168,76,0.5);
    }
    /* ─── MODALS ─── */
    .payment-modal-overlay {
      position: fixed; inset: 0; z-index: 9999; display: none; align-items: center; justify-content: center; padding: 24px;
      background: rgba(3, 7, 18, 0.7); backdrop-filter: blur(28px) saturate(180%);
    }
    .payment-modal-overlay.active { display: flex; }
    .payment-modal-box {
      background: rgba(10, 15, 30, 0.95); border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 32px; box-shadow: 0 50px 100px rgba(0, 0, 0, 0.7);
      padding: 44px; color: #fff; overflow-y: auto; max-height: 88vh;
    }
    .payment-modal-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 28px; }
    .payment-modal-title { margin: 0; font-family: var(--serif); font-size: 2.6rem; font-weight: 500; color: #fff; }
    .payment-modal-title em { color: var(--gold); font-style: italic; }
    .payment-modal-close {
      width: 44px; height: 44px; border: none; border-radius: 50%; cursor: pointer; color: #fff;
      background: rgba(255, 255, 255, 0.1); display: flex; align-items: center; justify-content: center;
    }
    
    /* ─── PAGE CONTENT ─── */
    .page-content {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem 8rem;
    }

    /* ─── HERO HEADER ─── */
    .page-eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }
    .page-eyebrow::before { content: '✦ '; }
    .page-h1 {
      font-family: var(--serif);
      font-size: clamp(3rem, 7vw, 5rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--white);
      margin-bottom: 0.6rem;
    }
    .page-h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .page-lead {
      font-size: 1rem;
      color: rgba(255,255,255,0.5);
      font-weight: 300;
      margin-bottom: 2.5rem;
      max-width: 500px;
      line-height: 1.7;
    }
    .new-res-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 1.8rem;
      border-radius: 100px;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      color: var(--ink);
      font-size: 0.78rem;
      font-weight: 700;
      text-decoration: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: all 0.3s var(--ease);
      box-shadow: 0 4px 20px rgba(201,168,76,0.25);
      margin-bottom: 3rem;
    }
    .new-res-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(201,168,76,0.45); }

    /* ─── RESERVATION CARDS ─── */
    .res-list { display: flex; flex-direction: column; gap: 1.5rem; }

    .res-card {
      background: rgba(10, 14, 30, 0.75);
      border: 1px solid var(--gbord);
      border-radius: 24px;
      backdrop-filter: blur(24px);
      padding: 2rem 2.2rem;
      transition: all 0.4s var(--ease);
      position: relative;
      overflow: hidden;
    }
    .res-card:hover {
      transform: translateY(-4px);
      border-color: rgba(201,168,76,0.2);
      box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }
    .res-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,168,76,0.3), transparent);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .res-card:hover::before { opacity: 1; }

    .res-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }
    .res-card-left { display: flex; align-items: center; gap: 1rem; }
    .res-icon {
      width: 44px; height: 44px;
      border-radius: 12px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .res-title {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--white);
    }
    .res-date {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.4);
      margin-top: 0.2rem;
      letter-spacing: 0.05em;
    }
    .res-dots {
      display: flex; gap: 0.3rem;
      color: rgba(255,255,255,0.2);
      font-size: 1.1rem;
      line-height: 1;
    }

    /* STATUS PILL */
    .status-pill {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.9rem;
      border-radius: 100px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .status-pill.confirme {
      background: rgba(16,185,129,0.12);
      color: #10b981;
      border: 1px solid rgba(16,185,129,0.25);
    }
    .status-pill.attente {
      background: rgba(245,158,11,0.12);
      color: #f59e0b;
      border: 1px solid rgba(245,158,11,0.25);
    }
    .status-pill.annule {
      background: rgba(239,68,68,0.1);
      color: #ef4444;
      border: 1px solid rgba(239,68,68,0.2);
    }

    /* ─── BILLETS INSIDE ─── */
    .billet-wrap {
      border-top: 1px solid var(--gbord);
      padding-top: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin-bottom: 1.5rem;
    }
    .billet-row {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      flex-wrap: wrap;
    }
    .billet-city {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--white);
      min-width: 80px;
    }
    .billet-city small {
      display: block;
      font-family: var(--sans);
      font-size: 0.68rem;
      color: rgba(255,255,255,0.4);
      font-weight: 400;
      letter-spacing: 0.05em;
      margin-top: 0.15rem;
    }
    .billet-route {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      min-width: 120px;
    }
    .billet-line {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      position: relative;
    }
    .billet-line::after {
      content: '▶';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gold);
      font-size: 0.55rem;
    }
    .billet-type-tag {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold2);
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.2);
      padding: 0.2rem 0.6rem;
      border-radius: 100px;
    }
    .billet-prix {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--gold);
      margin-left: auto;
      white-space: nowrap;
    }

    .no-billets {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.3);
      font-style: italic;
      padding: 0.5rem 0;
    }

    /* ─── ACTIONS ─── */
    .res-actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }
    .res-action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s var(--ease);
      cursor: pointer;
      border: none;
      font-family: var(--grotesk);
    }
    .res-action-btn.modifier {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      color: var(--gold2);
    }
    .res-action-btn.modifier:hover {
      background: rgba(201,168,76,0.1);
      border-color: var(--gold);
      color: var(--gold);
    }
    .res-action-btn.supprimer {
      background: rgba(239,68,68,0.07);
      border: 1px solid rgba(239,68,68,0.15);
      color: #ef4444;
    }
    .res-action-btn.supprimer:hover {
      background: rgba(239,68,68,0.15);
      border-color: rgba(239,68,68,0.35);
    }

    /* ─── EMPTY STATE ─── */
    .empty-state {
      text-align: center;
      padding: 6rem 2rem;
    }
    .empty-state-icon { font-size: 4rem; margin-bottom: 1.5rem; opacity: 0.4; }
    .empty-state h3 {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 300;
      color: var(--white);
      margin-bottom: 0.5rem;
    }
    .empty-state p { color: rgba(255,255,255,0.4); font-size: 0.9rem; }

    /* Entrance animations */
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .res-card {
      animation: fadeSlideUp 0.5s var(--ease) both;
    }
    {% for i in 1..20 %}
    .res-card:nth-child({{ i }}) { animation-delay: {{ (i - 1) * 0.07 }}s; }
    {% endfor %}

    /* ─── CALENDAR STYLES ─── */
    .cal-toggle-btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.6rem;
      border-radius: 100px;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.3);
      color: var(--gold2);
      font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: all 0.3s var(--ease);
      margin-bottom: 2.5rem;
    }
    .cal-toggle-btn:hover { background: rgba(201,168,76,0.18); border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

    .res-calendar-card {
      background: rgba(10,14,30,0.8);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      backdrop-filter: blur(24px);
      padding: 1.8rem 2rem;
      margin-bottom: 2.5rem;
      animation: fadeSlideUp 0.4s var(--ease) both;
    }
    .res-calendar-card[hidden] { display: none; }

    .res-cal-top {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1.4rem;
    }
    .res-cal-kicker {
      font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--gold);
    }
    .res-cal-title {
      font-family: var(--serif);
      font-size: 1.8rem; font-weight: 300; color: var(--white);
      margin: 0.3rem 0 0;
    }
    .res-cal-title em { font-style: italic; color: var(--gold); }
    .res-cal-nav-wrap { display: flex; align-items: center; gap: 0.6rem; }
    .res-cal-nav {
      width: 34px; height: 34px; border-radius: 50%;
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.7); font-size: 1.1rem;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    }
    .res-cal-nav:hover { background: rgba(201,168,76,0.15); border-color: var(--gold); color: var(--gold); }
    .res-cal-month-label {
      font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.7);
      min-width: 120px; text-align: center; letter-spacing: 0.05em; text-transform: capitalize;
    }
    .res-cal-weekdays, .res-cal-grid {
      display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
    }
    .res-cal-weekdays { margin-bottom: 4px; }
    .res-cal-weekdays span {
      text-align: center; font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.3); padding: 4px 0;
    }
    .res-cal-day {
      position: relative;
      aspect-ratio: 1;
      border-radius: 10px;
      border: 1px solid transparent;
      background: transparent;
      color: rgba(255,255,255,0.5);
      font-size: 0.8rem; font-weight: 500;
      display: flex; align-items: center; justify-content: center;
      cursor: default; transition: all 0.2s;
    }
    .res-cal-day.is-muted { color: rgba(255,255,255,0.18); }
    .res-cal-day.is-today {
      border-color: rgba(201,168,76,0.4);
      color: var(--gold2);
    }
    .res-cal-day.has-res {
      cursor: pointer;
      border-color: rgba(201,168,76,0.4);
      background: linear-gradient(145deg, rgba(201,168,76,0.2), rgba(255,255,255,0.05));
      color: var(--white);
    }
    .res-cal-day.has-res:hover, .res-cal-day.is-selected {
      transform: translateY(-2px);
      border-color: rgba(201,168,76,0.7);
      background: linear-gradient(145deg, rgba(201,168,76,0.32), rgba(255,255,255,0.08));
      box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }
    .res-cal-count {
      position: absolute; right: 4px; bottom: 4px;
      min-width: 18px; height: 18px; padding: 0 4px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      color: var(--ink); font-size: 0.58rem; font-weight: 900;
      display: flex; align-items: center; justify-content: center;
    }
    .res-cal-details {
      margin-top: 1.2rem; padding-top: 1.2rem;
      border-top: 1px solid rgba(255,255,255,0.07);
    }
    .res-cal-details-title {
      font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: rgba(255,255,255,0.45);
      margin-bottom: 0.8rem;
    }
    .res-cal-pill {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 0.4rem 0.9rem; border-radius: 100px;
      background: rgba(255,255,255,0.07);
      color: rgba(255,255,255,0.75); font-size: 0.78rem;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .res-cal-pill strong { color: var(--gold2); }
  </style>
</head>
<body>

  <!-- CINEMATIC BACKGROUND: airplane wing over clouds -->
  <div class="page-bg">
    <img 
      src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1800&q=85" 
      alt="Premium flights background"
    />
  </div>

  <!-- LIVE CANVAS OVERLAY -->
  <canvas id="live-canvas" style="position:fixed;inset:0;z-index:1;pointer-events:none;width:100%;height:100%;"></canvas>

  <!-- NAV -->
  <nav class="nav">
    <a href="/travelia.html" class="nav-logo">
      <div class="nav-logo-mark">T</div>
      <span class="nav-logo-text">Travelia</span>
    </a>
    <div class="nav-links">
      <a href="{{ path('app_home') }}" class="nav-link">Home</a>
      <a href="{{ path('app_home') }}#panel-1" class="nav-link">Hotels</a>
      <a href="{{ path('app_home') }}#panel-2" class="nav-link">Flights</a>
      <a href="{{ path('app_home') }}#panel-3" class="nav-link">Activities</a>
      <a href="{{ path('app_home') }}#panel-4" class="nav-link">Reviews</a>
    </div>

    {% if app.user %}
      <button id="user-panel-btn" onclick="openUserPanel()" style="
        background:none; border:none; cursor:pointer;
        color:#c9a84c; font-family:'Inter',sans-serif;
        font-size:0.82rem; font-weight:600; letter-spacing:1px;
        text-transform:uppercase; display:flex; align-items:center; gap:0.5rem;
        transition:opacity 0.2s;
      " onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
        <span style="font-size:1rem;">✦</span>
        {{ app.user.prenom }} {{ app.user.nom }}
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" style="opacity:0.5;">
          <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    {% else %}
      <div style="display:flex; align-items:center; gap:1rem;">
        <a href="{{ path('app_login') }}" class="nav-link" style="color:rgba(255,255,255,0.8); font-weight:600; text-transform:uppercase; font-size:0.75rem; letter-spacing:1px;">Connexion</a>
        <a href="{{ path('app_register') }}" class="trip-btn" style="padding:0.6rem 1.4rem; font-size:0.8rem;">Inscription</a>
      </div>
    {% endif %}
  </nav>

  {# ── USER PROFILE PANEL (identical to homepage) ── #}
  {% if app.user %}
  <div id="user-panel-mask" onclick="closeUserPanel()" style="
    display:none; position:fixed; inset:0; z-index:1998;
    background:rgba(0,0,0,0.55); backdrop-filter:blur(4px);
