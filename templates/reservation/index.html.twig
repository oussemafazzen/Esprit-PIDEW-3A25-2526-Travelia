{% extends 'admin_base.html.twig' %}

{% block title %}Gestion des réservations{% endblock %}

{% block stylesheets %}
    <style>
        .page-switch {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            z-index: 2;
            position: relative;
        }

        .switch-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 170px;
            padding: 0.9rem 1.3rem;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.02);
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
            font-size: 0.76rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            transition: all 0.3s var(--ease);
            backdrop-filter: blur(10px);
        }

        .switch-btn.active,
        .switch-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(201, 168, 76, 0.08);
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.15);
        }

        .content-card {
            width: 100%;
            background: var(--panel);
            border: 1px solid var(--gbord);
            border-radius: 28px;
            padding: 2.2rem;
            backdrop-filter: blur(20px);
            margin-top: 1rem;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.6rem;
            gap: 1rem;
        }

        .section-header h2 {
            font-family: var(--serif);
            font-size: 2.4rem;
            font-weight: 400;
            color: #fff;
        }

        .create-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            border-radius: 14px;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            text-transform: uppercase;
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.25);
            transition: transform 0.2s ease;
        }

        .create-btn:hover {
            transform: translateY(-2px);
        }
        
        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.45rem 0.85rem;
            border_radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .status-pill.confirme {
            background: rgba(16, 185, 129, 0.16);
            color: #10b981;
        }

        .status-pill.attente {
            background: rgba(245, 158, 11, 0.16);
            color: #f59e0b;
        }

    </style>
{% endblock %}

{% block body %}
    <div class="page-switch">
        <a href="/billet/" class="switch-btn">Tables billets</a>
        <a href="/reservation/" class="switch-btn active">Tables réservations</a>
    </div>

    <section class="content-card">
        <div class="section-header">
            <h2>Liste des réservations</h2>
            <a href="{{ path('app_reservation_new') }}" class="create-btn lux-modal-trigger" data-modal-title="Créer une réservation">+ Créer nouveau</a>
        </div>

        <div class="data-table-wrap">
            <table class="crud-table">
                <thead>
                    <tr>
                        <th style="width: 8%;">ID</th>
                        <th style="width: 17%;">Date</th>
                        <th style="width: 16%;">Statut</th>
                        <th style="width: 14%;">Paiement</th>
                        <th style="width: 12%;">Client</th>
                        <th style="width: 16%;">Destination</th>
                        <th style="width: 17%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for reservation in reservations %}
                    {% set statutClass =
                        reservation.statut|lower starts with 'confirm'
                            ? 'confirme'
                            : 'attente'
                    %}
                    <tr>
                        <td>{{ reservation.id }}</td>
                        <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : '' }}</td>
                        <td>
                            <span class="status-pill {{ statutClass }}">
                                {{ reservation.statut }}
                            </span>
                        </td>
                        <td>{{ reservation.modalitesPaiement }}</td>
                        <td>{{ reservation.clientId }}</td>
                        <td>{{ reservation.paysDestination }}</td>
                        <td>
                            <div class="crud-actions">
                                <a class="crud-action-btn lux-modal-trigger" data-modal-title="Détails réservation" href="{{ path('app_reservation_show', {'id': reservation.id}) }}">Voir</a>
                                <a class="crud-action-btn lux-modal-trigger" data-modal-title="Modifier réservation" href="{{ path('app_reservation_edit', {'id': reservation.id}) }}">Modifier</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" style="text-align:center; padding:3rem; opacity:0.5;">Aucune réservation trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

{% endblock %}
