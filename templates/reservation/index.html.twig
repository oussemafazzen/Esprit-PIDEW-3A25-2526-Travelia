<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des réservations</title>
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">

    <style>
        .page-switch {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .switch-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 170px;
            padding: 0.9rem 1.3rem;
            border-radius: 14px;
            border: 1px solid rgba(201, 168, 76, 0.35);
            background: rgba(255,255,255,0.02);
            color: var(--gold2);
            text-decoration: none;
            font-size: 0.76rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            transition: all 0.3s var(--ease);
        }

        .switch-btn.active,
        .switch-btn:hover {
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.22);
        }

        .content-card {
            width: 100%;
            background: var(--panel);
            border: 1px solid var(--gbord);
            border-radius: 28px;
            padding: 2.2rem;
            backdrop-filter: blur(20px);
            margin-top: 1rem;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.6rem;
            gap: 1rem;
        }

        .section-header h2 {
            font-family: var(--serif);
            font-size: 2.4rem;
            font-weight: 400;
            color: #fff;
        }

        .create-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            border-radius: 14px;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            text-transform: uppercase;
            box-shadow: 0 8px 25px rgba(201, 168, 76, 0.25);
            transition: transform 0.2s ease;
        }

        .create-btn:hover {
            transform: translateY(-2px);
        }

        .header-actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .view-toggle {
            display: inline-flex;
            gap: 0.5rem;
            padding: 0.35rem;
            border: 1px solid rgba(201, 168, 76, 0.22);
            border-radius: 16px;
            background: rgba(255,255,255,0.03);
        }

        .view-toggle-btn {
            min-height: 42px;
            padding: 0 1rem;
            border: none;
            border-radius: 12px;
            background: transparent;
            color: rgba(255,255,255,0.62);
            cursor: pointer;
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            transition: all 0.2s ease;
        }

        .view-toggle-btn.active,
        .view-toggle-btn:hover {
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            box-shadow: 0 8px 20px rgba(201, 168, 76, 0.18);
        }

        .export-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 1rem 1.5rem;
            border-radius: 14px;
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            background: rgba(255,255,255,0.04);
            color: var(--gold2);
            text-transform: uppercase;
            border: 1px solid rgba(201, 168, 76, 0.35);
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .export-btn:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,0.08);
        }

        .table-tools {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 14px;
            margin-bottom: 1.5rem;
        }

        .table-tools-input,
        .table-tools-select {
            min-height: 52px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.10);
            background: rgba(255,255,255,0.05);
            color: white;
            padding: 0 16px;
            outline: none;
        }

        .table-tools-select option {
            color: #111;
        }

        .table-tools-btn {
            min-height: 52px;
            padding: 0 24px;
            border: none;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            font-weight: 800;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .data-table-wrap {
            width: 100%;
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 18px;
            overflow: hidden;
            background: rgba(255,255,255,0.02);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .data-table thead th {
            text-align: left;
            padding: 1.1rem 1rem;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--gold);
            font-weight: 800;
            background: rgba(255,255,255,0.02);
        }

        .data-table tbody td {
            padding: 1.3rem 1rem;
            border-top: 1px solid rgba(255,255,255,0.05);
            font-size: 1rem;
            color: rgba(255,255,255,0.92);
            vertical-align: middle;
            word-wrap: break-word;
        }

        .data-table tbody tr:hover {
            background: rgba(255,255,255,0.03);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.45rem 0.85rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .status-pill.confirme {
            background: rgba(16, 185, 129, 0.16);
            color: #10b981;
        }

        .status-pill.attente {
            background: rgba(245, 158, 11, 0.16);
            color: #f59e0b;
        }

        .status-pill.retarde {
            background: rgba(245, 158, 11, 0.16);
            color: #fbbf24;
        }

        .status-pill.annule {
            background: rgba(239, 68, 68, 0.16);
            color: #f87171;
        }

        .billet-status-summary {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
            margin-top: 0.55rem;
        }

        .billet-status-summary .status-pill {
            padding: 0.32rem 0.62rem;
            font-size: 0.62rem;
        }

        .action-group {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 80px;
            padding: 0.65rem 0.9rem;
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            color: var(--gold2);
            transition: all 0.2s ease;
        }

        .action-btn:hover {
            background: rgba(255,255,255,0.08);
        }

        .delete-inline-form {
            margin: 0;
        }

        .delete-inline-form .delete-trigger-btn {
            min-width: 100px;
            padding: 0.65rem 0.9rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            background: rgba(239, 68, 68, 0.14);
            color: #ef4444;
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .empty-state {
            padding: 2rem;
            text-align: center;
            color: rgba(255,255,255,0.5);
        }

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 1.5rem;
        }

        .pagination span,
        .pagination a {
            min-width: 42px;
            height: 42px;
            padding: 0 0.85rem;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            color: rgba(255,255,255,0.72);
            text-decoration: none;
            font-size: 0.78rem;
            font-weight: 800;
        }

        .pagination .current {
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            border-color: rgba(201, 168, 76, 0.6);
            color: #111;
            box-shadow: 0 8px 20px rgba(201, 168, 76, 0.18);
        }

        .pagination a:hover {
            border-color: rgba(201, 168, 76, 0.45);
            color: var(--gold2);
        }

        .admin-calendar-panel[hidden],
        .admin-table-panel[hidden] {
            display: none;
        }

        .admin-calendar-panel {
            display: grid;
            grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
            gap: 1.4rem;
        }

        .admin-calendar-card,
        .admin-calendar-details {
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 22px;
            background: rgba(255,255,255,0.03);
            padding: 1.4rem;
        }

        .admin-calendar-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1.2rem;
        }

        .admin-calendar-kicker {
            margin: 0 0 0.45rem;
            color: var(--gold2);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .admin-calendar-title {
            margin: 0;
            font-family: var(--serif);
            font-size: 2.2rem;
            font-weight: 400;
            color: #fff;
        }

        .admin-calendar-actions {
            display: inline-flex;
            align-items: center;
            gap: 0.7rem;
        }

        .admin-calendar-nav {
            width: 42px;
            height: 42px;
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            color: #fff;
            cursor: pointer;
            font-size: 1.15rem;
            transition: all 0.2s ease;
        }

        .admin-calendar-nav:hover {
            background: rgba(201, 168, 76, 0.18);
            color: var(--gold2);
        }

        .admin-calendar-month {
            min-width: 145px;
            text-align: center;
            color: rgba(255,255,255,0.82);
            font-weight: 800;
            text-transform: capitalize;
        }

        .admin-calendar-weekdays,
        .admin-calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.45rem;
        }

        .admin-calendar-weekdays {
            margin-bottom: 0.5rem;
        }

        .admin-calendar-weekdays span {
            color: rgba(255,255,255,0.42);
            font-size: 0.68rem;
            font-weight: 800;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .admin-calendar-day {
            position: relative;
            min-height: 72px;
            padding: 0.65rem;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 15px;
            background: rgba(255,255,255,0.025);
            color: rgba(255,255,255,0.76);
            cursor: default;
            text-align: left;
            transition: all 0.2s ease;
        }

        .admin-calendar-day.is-muted {
            opacity: 0.34;
        }

        .admin-calendar-day.is-today {
            border-color: rgba(232, 201, 122, 0.42);
        }

        .admin-calendar-day.has-reservation {
            cursor: pointer;
            border-color: rgba(201, 168, 76, 0.44);
            background: linear-gradient(145deg, rgba(201, 168, 76, 0.20), rgba(255,255,255,0.04));
        }

        .admin-calendar-day.has-reservation:hover,
        .admin-calendar-day.is-selected {
            transform: translateY(-2px);
            border-color: rgba(232, 201, 122, 0.72);
            background: linear-gradient(145deg, rgba(201, 168, 76, 0.32), rgba(255,255,255,0.06));
        }

        .admin-calendar-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            font-weight: 800;
            font-size: 0.84rem;
        }

        .admin-calendar-day.is-today .admin-calendar-number {
            background: rgba(232, 201, 122, 0.16);
            color: var(--gold2);
        }

        .admin-calendar-count {
            position: absolute;
            right: 0.5rem;
            bottom: 0.5rem;
            min-width: 28px;
            height: 28px;
            padding: 0 0.5rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: #111;
            font-size: 0.72rem;
            font-weight: 900;
        }

        .admin-calendar-details-title {
            margin: 0 0 1rem;
            font-family: var(--serif);
            font-size: 2rem;
            font-weight: 400;
            color: #fff;
        }

        .admin-calendar-empty {
            color: rgba(255,255,255,0.52);
            line-height: 1.6;
        }

        .admin-calendar-reservation-list {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        .admin-calendar-reservation {
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.035);
        }

        .admin-calendar-reservation-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 0.8rem;
        }

        .admin-calendar-reservation-head strong {
            color: var(--gold2);
        }

        .admin-calendar-reservation-meta {
            display: grid;
            gap: 0.45rem;
            color: rgba(255,255,255,0.74);
            font-size: 0.86rem;
        }

        .admin-calendar-reservation-meta span {
            display: flex;
            justify-content: space-between;
            gap: 0.8rem;
        }

        .admin-calendar-reservation-meta b {
            color: rgba(255,255,255,0.44);
            font-weight: 700;
        }

        @media (max-width: 1200px) {
            .data-table-wrap {
                overflow-x: auto;
            }

            .data-table {
                min-width: 1100px;
            }

            .table-tools {
                grid-template-columns: 1fr;
            }

            .admin-calendar-panel {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    {% set billetStatusLabels = {
        'confirme': 'Confirmé',
        'confirmed': 'Confirmé',
        'retarde': 'Retardé',
        'annule': 'Annulé',
        'en_attente': 'En attente'
    } %}
    {% set adminCalendarItems = [] %}
    {% for reservation in calendarReservations|default([]) %}
        {% if reservation.dateReservation %}
            {% set adminCalendarItems = adminCalendarItems|merge([{
                id: reservation.id,
                date: reservation.dateReservation|date('Y-m-d'),
                displayDate: reservation.dateReservation|date('Y-m-d'),
                client: reservation.clientId ?? '',
                destination: reservation.paysDestination ?? 'Non défini',
                status: reservation.statut ?? '',
                payment: reservation.modalitesPaiement ?? '',
                billets: reservation.billets|length,
                billetStatuses: reservation.billets|map(billet => billet.statut)|join(', '),
                showUrl: path('app_reservation_show', {'id': reservation.id})
            }]) %}
        {% endif %}
    {% endfor %}

    <aside class="app-sidebar">
        <div class="logo-area">
            Travel<em>ia</em>
        </div>

        <nav class="nav-menu">
            <a href="{{ path('app_admin_dashboard') }}" class="nav-item">
                <span class="nav-icon">⬚</span>
                Tableau de bord
            </a>

            <a href="#" class="nav-item">
                <span class="nav-icon">🏨</span>
                Hébergements
            </a>

            <a href="{{ path('app_reservation_index') }}" class="nav-item active">
                <span class="nav-icon">📘</span>
                Réservations
            </a>

            <a href="#" class="nav-item">
                <span class="nav-icon">🛶</span>
                Activités
            </a>

            <a href="#" class="nav-item">
                <span class="nav-icon">👥</span>
                Clients
            </a>

            <a href="#" class="nav-item">
                <span class="nav-icon">⚙</span>
                Paramètres
            </a>
        </nav>

        <div class="sidebar-user">
            <div class="user-avatar"></div>
            <div class="user-info">
                <span>Admin</span>
                <small>Accès complet</small>
            </div>
        </div>
    </aside>

    <main class="app-main">
        <div class="glow-bg"></div>

        <header class="header">
            <div class="header-top">
                <div class="header-greeting">
                    <h1>Gestion des <em>réservations</em></h1>
                    <p style="font-size: 0.95rem; opacity: 0.5; margin-top: 0.5rem;">
                        Suivi complet des réservations Travelia.
                    </p>
                </div>
                <div class="date-pill">Admin Dashboard</div>
            </div>
        </header>

        <div class="page-switch">
            <a href="{{ path('app_billet_index') }}" class="switch-btn">Tables billets</a>
            <a href="{{ path('app_reservation_index') }}" class="switch-btn active">Tables réservations</a>
        </div>

        <section class="content-card">
            <div class="section-header">
                <h2>Liste des réservations</h2>
                <div class="header-actions">
                    <div class="view-toggle" aria-label="Changer de vue">
                        <button type="button" class="view-toggle-btn active" data-admin-view="table">Table</button>
                        <button type="button" class="view-toggle-btn" data-admin-view="calendar">Calendrier</button>
                    </div>
                    <a href="{{ path('app_reservation_export_pdf') }}" class="export-btn">Exporter PDF</a>
                    <a href="{{ path('app_reservation_export_excel') }}" class="export-btn">Exporter Excel</a>
                    <a href="{{ path('app_reservation_new') }}" class="create-btn">+ Créer nouveau</a>
                </div>
            </div>

            <div class="admin-table-panel" id="adminReservationTablePanel">
            <form method="get" action="{{ path('app_reservation_index') }}" class="table-tools">
                <input
                    type="text"
                    name="search"
                    value="{{ search|default('') }}"
                    placeholder="Rechercher par statut, paiement, client, destination ou ID..."
                    class="table-tools-input"
                >

                <select name="sort" class="table-tools-select">
                    <option value="id" {{ sort == 'id' ? 'selected' : '' }}>Trier par ID</option>
                    <option value="date" {{ sort == 'date' ? 'selected' : '' }}>Date</option>
                    <option value="statut" {{ sort == 'statut' ? 'selected' : '' }}>Statut</option>
                    <option value="paiement" {{ sort == 'paiement' ? 'selected' : '' }}>Paiement</option>
                    <option value="client" {{ sort == 'client' ? 'selected' : '' }}>Client</option>
                    <option value="destination" {{ sort == 'destination' ? 'selected' : '' }}>Destination</option>
                </select>

                <select name="direction" class="table-tools-select">
                    <option value="DESC" {{ direction == 'DESC' ? 'selected' : '' }}>Descendant</option>
                    <option value="ASC" {{ direction == 'ASC' ? 'selected' : '' }}>Ascendant</option>
                </select>

                <button type="submit" class="table-tools-btn">Appliquer</button>
            </form>

            <div class="data-table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 20%;">Date</th>
                            <th style="width: 16%;">Statut</th>
                            <th style="width: 14%;">Paiement</th>
                            <th style="width: 12%;">Client</th>
                            <th style="width: 16%;">Destination</th>
                            <th style="width: 22%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for reservation in reservations %}
                        {% set statutClass = reservation.statut|lower starts with 'confirm' ? 'confirme' : 'attente' %}
                        <tr>
                            <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : '' }}</td>
                            <td>
                                <span class="status-pill {{ statutClass }}">
                                    {{ reservation.statut }}
                                </span>
                            </td>
                            <td>{{ reservation.modalitesPaiement }}</td>
                            <td>{{ reservation.clientId }}</td>
                            <td>
                                {{ reservation.paysDestination }}

                                {% if reservation.billets is not empty %}
                                    <div class="billet-status-summary" aria-label="Statuts des billets">
                                        {% for billet in reservation.billets %}
                                            {% if billet.statut %}
                                                {% set billetStatusKey = billet.statut|lower|replace({' ': '_', 'é':'e', 'è':'e', 'ê':'e', 'é':'e', 'è':'e', 'ê':'e'}) %}
                                                <span class="status-pill {{ billetStatusKey }}">
                                                    {{ billetStatusLabels[billetStatusKey]|default(billet.statut) }}
                                                </span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="action-group">
                                    <a class="action-btn" href="{{ path('app_reservation_show', {'id': reservation.id}) }}">Voir</a>
                                    <a class="action-btn" href="{{ path('app_reservation_edit', {'id': reservation.id}) }}">Modifier</a>

                                    <form method="post"
                                          action="{{ path('app_reservation_delete', {'id': reservation.id}) }}"
                                          class="delete-inline-form">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                        <button type="button" class="delete-trigger-btn open-delete-modal">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="empty-state">Aucune réservation trouvée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {{ knp_pagination_render(reservations) }}
            </div>

            <div class="admin-calendar-panel" id="adminReservationCalendarPanel" hidden>
                <div class="admin-calendar-card">
                    <div class="admin-calendar-top">
                        <div>
                            <p class="admin-calendar-kicker">Vue calendrier</p>
                            <h3 class="admin-calendar-title">Réservations par date</h3>
                        </div>

                        <div class="admin-calendar-actions" aria-label="Navigation du calendrier">
                            <button type="button" class="admin-calendar-nav" id="adminCalendarPrev" aria-label="Mois précédent">&lsaquo;</button>
                            <div class="admin-calendar-month" id="adminCalendarMonth"></div>
                            <button type="button" class="admin-calendar-nav" id="adminCalendarNext" aria-label="Mois suivant">&rsaquo;</button>
                        </div>
                    </div>

                    <div class="admin-calendar-weekdays" aria-hidden="true">
                        <span>Lun</span>
                        <span>Mar</span>
                        <span>Mer</span>
                        <span>Jeu</span>
                        <span>Ven</span>
                        <span>Sam</span>
                        <span>Dim</span>
                    </div>

                    <div class="admin-calendar-grid" id="adminReservationCalendarGrid"></div>
                </div>

                <aside class="admin-calendar-details" id="adminReservationCalendarDetails">
                    <h3 class="admin-calendar-details-title">Détails</h3>
                    <p class="admin-calendar-empty">Sélectionnez une date dorée pour afficher les réservations de tous les clients.</p>
                </aside>
            </div>

            <script type="application/json" id="admin-reservation-calendar-data">{{ adminCalendarItems|json_encode|raw }}</script>
        </section>
    </main>

    {{ include('partials/delete_modal.html.twig') }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tablePanel = document.getElementById('adminReservationTablePanel');
            const calendarPanel = document.getElementById('adminReservationCalendarPanel');
            const viewButtons = document.querySelectorAll('[data-admin-view]');
            const dataElement = document.getElementById('admin-reservation-calendar-data');
            const calendarGrid = document.getElementById('adminReservationCalendarGrid');
            const calendarMonth = document.getElementById('adminCalendarMonth');
            const calendarPrev = document.getElementById('adminCalendarPrev');
            const calendarNext = document.getElementById('adminCalendarNext');
            const calendarDetails = document.getElementById('adminReservationCalendarDetails');
            const calendarReservations = dataElement ? JSON.parse(dataElement.textContent || '[]') : [];
            const reservationsByDate = calendarReservations.reduce((groups, reservation) => {
                if (!reservation.date) {
                    return groups;
                }

                if (!groups[reservation.date]) {
                    groups[reservation.date] = [];
                }

                groups[reservation.date].push(reservation);
                return groups;
            }, {});

            let currentCalendarDate = new Date();
            let selectedCalendarDate = null;

            function setAdminView(view) {
                if (!tablePanel || !calendarPanel) {
                    return;
                }

                tablePanel.hidden = view !== 'table';
                calendarPanel.hidden = view !== 'calendar';

                viewButtons.forEach((button) => {
                    const isActive = button.dataset.adminView === view;
                    button.classList.toggle('active', isActive);
                    button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                });
            }

            viewButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    setAdminView(button.dataset.adminView);
                });
            });

            function padDatePart(value) {
                return String(value).padStart(2, '0');
            }

            function createDate(year, month, day) {
                return new Date(year, month, day);
            }

            function toDateKey(date) {
                return [
                    date.getFullYear(),
                    padDatePart(date.getMonth() + 1),
                    padDatePart(date.getDate())
                ].join('-');
            }

            function formatDate(dateKey) {
                const parts = dateKey.split('-').map(Number);
                const date = createDate(parts[0], parts[1] - 1, parts[2]);

                return new Intl.DateTimeFormat('fr-FR', {
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric'
                }).format(date);
            }

            function renderCalendarDetails(dateKey) {
                if (!calendarDetails) {
                    return;
                }

                const items = reservationsByDate[dateKey] || [];
                calendarDetails.innerHTML = '';

                const title = document.createElement('h3');
                title.className = 'admin-calendar-details-title';
                title.textContent = items.length > 0 ? formatDate(dateKey) : 'Détails';
                calendarDetails.appendChild(title);

                if (items.length === 0) {
                    const empty = document.createElement('p');
                    empty.className = 'admin-calendar-empty';
                    empty.textContent = calendarReservations.length > 0
                        ? 'Sélectionnez une date dorée pour afficher les réservations de tous les clients.'
                        : 'Aucune réservation datée à afficher dans le calendrier.';
                    calendarDetails.appendChild(empty);
                    return;
                }

                const list = document.createElement('div');
                list.className = 'admin-calendar-reservation-list';

                items.forEach((reservation) => {
                    const card = document.createElement('article');
                    card.className = 'admin-calendar-reservation';

                    const head = document.createElement('div');
                    head.className = 'admin-calendar-reservation-head';

                    const heading = document.createElement('strong');
                    heading.textContent = 'Réservation #' + reservation.id;

                    const link = document.createElement('a');
                    link.className = 'action-btn';
                    link.href = reservation.showUrl;
                    link.textContent = 'Voir';

                    head.appendChild(heading);
                    head.appendChild(link);

                    const meta = document.createElement('div');
                    meta.className = 'admin-calendar-reservation-meta';

                    [
                        ['Date', reservation.displayDate || reservation.date],
                        ['Client', reservation.client || '-'],
                        ['Destination', reservation.destination || 'Non défini'],
                        ['Statut', reservation.status || '-'],
                        ['Paiement', reservation.payment || '-'],
                        ['Billets', reservation.billets || 0],
                        ['Statuts billets', reservation.billetStatuses || '-']
                    ].forEach(([label, value]) => {
                        const row = document.createElement('span');
                        const labelElement = document.createElement('b');
                        const valueElement = document.createElement('em');

                        labelElement.textContent = label;
                        valueElement.textContent = value;
                        valueElement.style.fontStyle = 'normal';

                        row.appendChild(labelElement);
                        row.appendChild(valueElement);
                        meta.appendChild(row);
                    });

                    card.appendChild(head);
                    card.appendChild(meta);
                    list.appendChild(card);
                });

                calendarDetails.appendChild(list);
            }

            function renderAdminCalendar() {
                if (!calendarGrid || !calendarMonth) {
                    return;
                }

                const year = currentCalendarDate.getFullYear();
                const month = currentCalendarDate.getMonth();
                const firstDay = createDate(year, month, 1);
                const mondayOffset = (firstDay.getDay() + 6) % 7;
                const startDate = createDate(year, month, 1 - mondayOffset);
                const todayKey = toDateKey(new Date());

                calendarMonth.textContent = new Intl.DateTimeFormat('fr-FR', {
                    month: 'long',
                    year: 'numeric'
                }).format(firstDay);
                calendarGrid.innerHTML = '';

                for (let index = 0; index < 42; index++) {
                    const dayDate = createDate(
                        startDate.getFullYear(),
                        startDate.getMonth(),
                        startDate.getDate() + index
                    );
                    const dateKey = toDateKey(dayDate);
                    const dayReservations = reservationsByDate[dateKey] || [];
                    const dayButton = document.createElement('button');
                    dayButton.type = 'button';
                    dayButton.className = 'admin-calendar-day';
                    dayButton.setAttribute('aria-label', dayDate.toLocaleDateString('fr-FR'));

                    if (dayDate.getMonth() !== month) {
                        dayButton.classList.add('is-muted');
                    }

                    if (dateKey === todayKey) {
                        dayButton.classList.add('is-today');
                    }

                    if (dateKey === selectedCalendarDate) {
                        dayButton.classList.add('is-selected');
                    }

                    const number = document.createElement('span');
                    number.className = 'admin-calendar-number';
                    number.textContent = dayDate.getDate();
                    dayButton.appendChild(number);

                    if (dayReservations.length > 0) {
                        const count = document.createElement('span');
                        count.className = 'admin-calendar-count';
                        count.textContent = dayReservations.length;
                        dayButton.classList.add('has-reservation');
                        dayButton.appendChild(count);

                        dayButton.addEventListener('click', () => {
                            selectedCalendarDate = dateKey;
                            renderAdminCalendar();
                            renderCalendarDetails(dateKey);
                        });
                    }

                    calendarGrid.appendChild(dayButton);
                }
            }

            if (calendarPrev && calendarNext) {
                calendarPrev.addEventListener('click', () => {
                    currentCalendarDate = createDate(
                        currentCalendarDate.getFullYear(),
                        currentCalendarDate.getMonth() - 1,
                        1
                    );
                    selectedCalendarDate = null;
                    renderAdminCalendar();
                    renderCalendarDetails('');
                });

                calendarNext.addEventListener('click', () => {
                    currentCalendarDate = createDate(
                        currentCalendarDate.getFullYear(),
                        currentCalendarDate.getMonth() + 1,
                        1
                    );
                    selectedCalendarDate = null;
                    renderAdminCalendar();
                    renderCalendarDetails('');
                });
            }

            setAdminView('table');
            renderAdminCalendar();
            renderCalendarDetails('');
        });
    </script>
    <script src="{{ asset('js/admin.js') }}"></script>
</body>
</html>
