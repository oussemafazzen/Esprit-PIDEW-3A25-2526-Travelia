<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travelia Admin — Tableau de bord</title>
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">

    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            z-index: 1;
        }

        .stat-card {
            background: var(--panel);
            border: 1px solid var(--gbord);
            padding: 1.8rem;
            border-radius: 20px;
            backdrop-filter: blur(20px);
            transition: transform 0.4s var(--ease);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: rgba(201, 168, 76, 0.3);
        }

        .stat-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.4);
            margin-bottom: 1rem;
        }

        .stat-value {
            font-family: var(--serif);
            font-size: 2.5rem;
            font-weight: 400;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .stat-trend {
            font-size: 0.75rem;
            color: #10b981;
        }

        .stat-trend.down {
            color: #ef4444;
        }

        .overview-section {
            grid-column: span 4;
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 2rem;
            margin-top: 1rem;
        }

        .traveler-stats {
            background: var(--panel);
            border: 1px solid var(--gbord);
            padding: 2rem;
            border-radius: 24px;
            backdrop-filter: blur(20px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .chart-title {
            width: 100%;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.4);
            margin-bottom: 2rem;
        }

        .circle-wrap {
            position: relative;
            width: 180px;
            height: 180px;
        }

        .circle-svg {
            transform: rotate(-90deg);
            width: 100%;
            height: 100%;
        }

        .circle-bg {
            fill: none;
            stroke: rgba(201, 168, 76, 0.1);
            stroke-width: 12;
        }

        .circle-val {
            fill: none;
            stroke: var(--gold);
            stroke-width: 12;
            stroke-linecap: round;
            stroke-dasharray: 440;
            stroke-dashoffset: 440;
            transition: stroke-dashoffset 2s var(--ease);
        }

        .chart-center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .chart-n {
            font-family: var(--serif);
            font-size: 2.2rem;
            font-weight: 500;
            color: var(--white);
        }

        .chart-l {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            margin-top: 5px;
        }

        .booking-graph {
            background: var(--panel);
            border: 1px solid var(--gbord);
            padding: 2.5rem;
            border-radius: 24px;
            backdrop-filter: blur(20px);
        }

        .graph-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 2.5rem;
        }

        .graph-title h3 {
            font-family: var(--serif);
            font-size: 1.6rem;
            font-weight: 300;
        }

        .graph-controls {
            display: flex;
            gap: 1rem;
        }

        .g-btn {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.4);
            background: none;
            border: none;
            cursor: pointer;
        }

        .g-btn.active {
            color: var(--gold2);
        }

        .svg-graph-lines {
            width: 100%;
            height: 240px;
            overflow: visible;
        }

        .g-line {
            fill: none;
            stroke: var(--gold);
            stroke-width: 3;
            stroke-linecap: round;
            stroke-linejoin: round;
            filter: drop-shadow(0 0 10px rgba(201, 168, 76, 0.4));
        }

        .g-area {
            fill: rgba(201, 168, 76, 0.08);
        }

        .g-points circle {
            fill: var(--gold);
            stroke: var(--ink);
            stroke-width: 3;
        }

        .graph-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 1.5rem;
            font-size: 0.65rem;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .bookings-list {
            grid-column: span 4;
            margin-top: 1.5rem;
        }

        .list-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .list-head h4 {
            font-family: var(--serif);
            font-size: 1.4rem;
            font-weight: 400;
        }

        .booking-item {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 140px;
            padding: 1.2rem 2rem;
            border-radius: 16px;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            margin-bottom: 0.8rem;
            transition: all 0.3s;
            align-items: center;
        }

        .booking-item:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.1);
            transform: translateX(5px);
        }

        .b-cust {
            font-weight: 600;
            font-size: 0.88rem;
        }

        .b-dest {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.5);
        }

        .b-date {
            font-size: 0.75rem;
            color: var(--gold);
        }

        .b-status {
            justify-self: end;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        @media (max-width: 1200px) {
            .dashboard-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .overview-section {
                grid-template-columns: 1fr;
            }

            .booking-item {
                grid-template-columns: 1fr;
                gap: 0.5rem;
            }

            .b-status {
                justify-self: start;
            }
        }
    </style>
</head>
<body>

    {% set totalRevenue = totalRevenue|default(0) %}
    {% set totalReservations = totalReservations|default(0) %}
    {% set pendingReservations = pendingReservations|default(0) %}
    {% set confirmedReservations = confirmedReservations|default(0) %}
    {% set confirmationRate = confirmationRate|default(0) %}
    {% set labels = labels|default(['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim']) %}
    {% set chartData = chartData|default([0, 0, 0, 0, 0, 0, 0]) %}
    {% set recentReservations = recentReservations|default([]) %}

    <aside class="app-sidebar">
        <div class="logo-area">
            Travel<em>ia</em>
        </div>

        <nav class="nav-menu">
            <a href="{{ path('admin_dashboard') }}" class="nav-item active">
                <span class="nav-icon">⬚</span>
                Tableau de bord
            </a>
            <a href="#" class="nav-item">
                <span class="nav-icon">🏨</span>
                Hébergements
            </a>
            <a href="{{ path('app_billet_index') }}" class="nav-item">
                <span class="nav-icon">✈</span>
                Billets
            </a>
            <a href="#" class="nav-item">
                <span class="nav-icon">🛶</span>
                Activités
            </a>
            <a href="{{ path('app_reservation_index') }}" class="nav-item">
                <span class="nav-icon">👥</span>
                Réservations
            </a>
            <a href="#" class="nav-item">
                <span class="nav-icon">⚙</span>
                Paramètres
            </a>
        </nav>

        <div class="sidebar-user">
            <div class="user-avatar"></div>
            <div class="user-info">
                <span>Admin Portal</span>
                <small>Accès complet</small>
            </div>
        </div>
    </aside>

    <main class="app-main">
        <div class="glow-bg"></div>

        <header class="header">
            <div class="header-top">
                <div class="header-greeting">
                    <h1>Bienvenue, <em>Admin</em></h1>
                    <p style="font-size: 0.9rem; opacity: 0.5; margin-top: 0.5rem;">
                        La plateforme Travelia fonctionne avec vos vraies données.
                    </p>
                </div>
                <div class="date-pill">{{ "now"|date("d M, Y — l") }}</div>
            </div>
        </header>

        <div class="dashboard-grid">
            <div class="stat-card">
                <div class="stat-label">Revenus totaux</div>
                <div class="stat-value">{{ totalRevenue|default(0)|number_format(1, ',', ' ') }} DT</div>
                <div class="stat-trend">Billets enregistrés</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Réservations actives</div>
                <div class="stat-value">{{ totalReservations|default(0) }}</div>
                <div class="stat-trend">Toutes les réservations</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">En attente</div>
                <div class="stat-value">{{ pendingReservations|default(0) }}</div>
                <div class="stat-trend down">Statut à traiter</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Taux confirmation</div>
                <div class="stat-value">{{ confirmationRate|default(0) }}%</div>
                <div class="stat-trend">Réservations confirmées</div>
            </div>

            <div class="overview-section">

                <div class="traveler-stats">
                    <div class="chart-title">Statistiques réservations</div>

                    <div class="circle-wrap">
                        <svg class="circle-svg" viewBox="0 0 160 160">
                            <circle class="circle-bg" cx="80" cy="80" r="70"></circle>
                            <circle
                                class="circle-val"
                                cx="80"
                                cy="80"
                                r="70"
                                data-percent="{{ confirmationRate|default(0) }}"
                            ></circle>
                        </svg>

                        <div class="chart-center">
                            <span class="chart-n">{{ confirmationRate|default(0) }}%</span>
                            <span class="chart-l">Confirmées</span>
                        </div>
                    </div>

                    <div style="margin-top:2rem; width:100%;">
                        <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
                            <span style="font-size:0.7rem; opacity:0.4;">Réservations validées</span>
                            <span style="font-size:0.7rem; color:var(--gold);">{{ confirmedReservations|default(0) }}</span>
                        </div>
                        <div style="width:100%; height:2px; background:rgba(255,255,255,0.05);">
                            <div style="width:{{ confirmationRate|default(0) }}%; height:100%; background:var(--gold);"></div>
                        </div>
                    </div>
                </div>

                <div class="booking-graph">
                    <div class="graph-header">
                        <div class="graph-title">
                            <h3>Évolution des réservations</h3>
                            <p style="font-size:0.75rem; opacity:0.3; font-weight:300;">Derniers 7 jours</p>
                        </div>
                        <div class="graph-controls">
                            <button class="g-btn active">S</button>
                        </div>
                    </div>

                    {% set d0 = chartData[0]|default(0) %}
                    {% set d1 = chartData[1]|default(0) %}
                    {% set d2 = chartData[2]|default(0) %}
                    {% set d3 = chartData[3]|default(0) %}
                    {% set d4 = chartData[4]|default(0) %}
                    {% set d5 = chartData[5]|default(0) %}
                    {% set d6 = chartData[6]|default(0) %}

                    {% set maxValue = 1 %}
                    {% for value in [d0, d1, d2, d3, d4, d5, d6] %}
                        {% if value > maxValue %}
                            {% set maxValue = value %}
                        {% endif %}
                    {% endfor %}

                    {% set x0 = 0 %}
                    {% set x1 = 133 %}
                    {% set x2 = 266 %}
                    {% set x3 = 399 %}
                    {% set x4 = 532 %}
                    {% set x5 = 665 %}
                    {% set x6 = 798 %}

                    {% set y0 = 220 - ((d0 / maxValue) * 160) %}
                    {% set y1 = 220 - ((d1 / maxValue) * 160) %}
                    {% set y2 = 220 - ((d2 / maxValue) * 160) %}
                    {% set y3 = 220 - ((d3 / maxValue) * 160) %}
                    {% set y4 = 220 - ((d4 / maxValue) * 160) %}
                    {% set y5 = 220 - ((d5 / maxValue) * 160) %}
                    {% set y6 = 220 - ((d6 / maxValue) * 160) %}

                    <div class="graph-canvas">
                        <svg class="svg-graph-lines" viewBox="0 0 800 240">
                            <path class="g-area"
                                  d="M {{ x0 }},{{ y0 }}
                                     C 70,{{ y0 }} 90,{{ y1 }} {{ x1 }},{{ y1 }}
                                     S 220,{{ y2 }} {{ x2 }},{{ y2 }}
                                     S 350,{{ y3 }} {{ x3 }},{{ y3 }}
                                     S 480,{{ y4 }} {{ x4 }},{{ y4 }}
                                     S 610,{{ y5 }} {{ x5 }},{{ y5 }}
                                     S 740,{{ y6 }} {{ x6 }},{{ y6 }}
                                     L 800,240 L 0,240 Z"></path>

                            <path class="g-line"
                                  d="M {{ x0 }},{{ y0 }}
                                     C 70,{{ y0 }} 90,{{ y1 }} {{ x1 }},{{ y1 }}
                                     S 220,{{ y2 }} {{ x2 }},{{ y2 }}
                                     S 350,{{ y3 }} {{ x3 }},{{ y3 }}
                                     S 480,{{ y4 }} {{ x4 }},{{ y4 }}
                                     S 610,{{ y5 }} {{ x5 }},{{ y5 }}
                                     S 740,{{ y6 }} {{ x6 }},{{ y6 }}"></path>

                            <g class="g-points">
                                <circle cx="{{ x0 }}" cy="{{ y0 }}" r="5"></circle>
                                <circle cx="{{ x1 }}" cy="{{ y1 }}" r="5"></circle>
                                <circle cx="{{ x2 }}" cy="{{ y2 }}" r="5"></circle>
                                <circle cx="{{ x3 }}" cy="{{ y3 }}" r="5"></circle>
                                <circle cx="{{ x4 }}" cy="{{ y4 }}" r="5"></circle>
                                <circle cx="{{ x5 }}" cy="{{ y5 }}" r="5"></circle>
                                <circle cx="{{ x6 }}" cy="{{ y6 }}" r="5"></circle>
                            </g>
                        </svg>

                        <div class="graph-labels">
                            {% for label in labels %}
                                <span>{{ label }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="bookings-list">
                    <div class="list-head">
                        <h4>Réservations récentes</h4>
                    </div>

                    {% for reservation in recentReservations %}
                        <div class="booking-item">
                            <div class="b-cust">Réservation #{{ reservation.id }}</div>
                            <div class="b-dest">{{ attribute(reservation, 'paysDestination')|default('-') }}</div>
                            <div class="b-date">
                                {{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : '' }}
                            </div>
                            <div class="b-status">{{ reservation.statut|default('Inconnu') }}</div>
                        </div>
                    {% else %}
                        <div class="booking-item">
                            <div class="b-cust">Aucune réservation</div>
                            <div class="b-dest">-</div>
                            <div class="b-date">-</div>
                            <div class="b-status">Vide</div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const circle = document.querySelector('.circle-val');
            if (circle) {
                const percent = parseFloat(circle.dataset.percent || '0');
                const safePercent = Math.max(0, Math.min(100, percent));
                const circumference = 440;
                const offset = circumference - ((safePercent / 100) * circumference);

                setTimeout(() => {
                    circle.style.strokeDashoffset = offset;
                }, 400);
            }
        });
    </script>
</body>
</html>