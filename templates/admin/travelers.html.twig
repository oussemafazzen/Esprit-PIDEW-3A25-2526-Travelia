{% extends 'admin_base.html.twig' %}

{% block title %}Travelers | Travelia Admin{% endblock %}

{% block body %}
<style>
    .toolbar { display:flex; justify-content:space-between; margin-bottom: 2rem; }
    .search-box { display:flex; gap:0.5rem; }
    .search-box input { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 0.8rem 1.2rem; border-radius: 100px; color:#fff; width: 300px; outline:none; }
    .search-box input:focus { border-color: #e8c97e; }
    .search-box button { background: #e8c97e; border:none; padding: 0.8rem 1.4rem; border-radius: 100px; font-weight: 600; cursor:pointer; }
    
    .data-table { width:100%; border-collapse: separate; border-spacing: 0; background:rgba(255,255,255,0.02); border-radius:20px; overflow:hidden; border: 1px solid rgba(255,255,255,0.05); }
    .data-table th { text-align: left; padding: 1.2rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; color: rgba(255,255,255,0.4); font-weight: 600; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02); }
    .data-table th a { color: inherit; text-decoration: none; display:flex; align-items:center; gap:0.3rem; }
    .data-table td { padding: 1.2rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.03); color:rgba(255,255,255,0.9); font-size: 0.95rem; }
    .data-table tr:last-child td { border-bottom: none; }
    
    .status-badge { display:inline-block; padding: 4px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 700; }
    .status-actif { background: rgba(16,185,129,0.15); color: #10b981; }
    .status-bloque { background: rgba(239,68,68,0.15); color: #ef4444; }
    
    .action-btn { background: rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; padding: 6px 12px; border-radius: 8px; cursor:pointer; font-size:0.8rem; transition:0.2s; text-decoration:none; display:inline-block; }
    .action-btn:hover { background: rgba(255,255,255,0.1); }
    .action-btn.danger { color: #ef4444; border-color: rgba(239,68,68,0.3); }
    .action-btn.danger:hover { background: rgba(239,68,68,0.1); }
</style>

<h1 style="font-family:'Cormorant Garamond', serif; font-size: 3rem; font-weight: 400; color: #fff; margin:0 0 0.5rem;">Gestion des <em>Voyageurs</em></h1>
<p style="color: rgba(255,255,255,0.5); font-size: 1.1rem; margin-bottom: 2rem;">Gérez les comptes clients, leurs statuts et informations personnelles.</p>

<div class="toolbar">
    <form method="get" class="search-box">
        <input type="text" name="q" value="{{ search }}" placeholder="Rechercher (Nom, Email)...">
        <button type="submit">Rechercher</button>
    </form>
</div>

{% for message in app.flashes('success') %}
    <div style="background:rgba(16,185,129,0.1); border:1px solid #10b981; color:#10b981; padding:15px; border-radius:12px; margin-bottom:1.5rem; font-size:0.95rem;">
        {{ message }}
    </div>
{% endfor %}

<table class="data-table">
    <thead>
        <tr>
            <th><a href="?sort=nom&direction={{ direction == 'ASC' ? 'DESC' : 'ASC' }}">Client {{ sortBy == 'nom' ? (direction == 'ASC' ? '▲' : '▼') : '⇅' }}</a></th>
            <th><a href="?sort=email&direction={{ direction == 'ASC' ? 'DESC' : 'ASC' }}">Email {{ sortBy == 'email' ? (direction == 'ASC' ? '▲' : '▼') : '⇅' }}</a></th>
            <th><a href="?sort=date_creation&direction={{ direction == 'ASC' ? 'DESC' : 'ASC' }}">Inscription {{ sortBy == 'date_creation' ? (direction == 'ASC' ? '▲' : '▼') : '⇅' }}</a></th>
            <th>Statut</th>
            <th style="text-align:right;">Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for client in clients %}
        <tr>
            <td>
                <div style="font-weight:600; color:#fff;">{{ client.nom }} {{ client.prenom }}</div>
                <div style="font-size:0.8rem; color:rgba(255,255,255,0.4);">ID: {{ client.id }}</div>
            </td>
            <td>{{ client.email }}</td>
            <td>{{ client.dateCreation ? client.dateCreation|date('d/m/Y') : '' }}</td>
            <td>
                <span class="status-badge {{ client.statut == 'ACTIF' ? 'status-actif' : 'status-bloque' }}">
                    {{ client.statut }}
                </span>
            </td>
            <td style="text-align:right;">
                <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                    <form method="post" action="{{ path('app_admin_client_toggle_status', {'id': client.id}) }}" style="margin:0;">
                        <button class="action-btn">{{ client.statut == 'ACTIF' ? 'Bloquer' : 'Débloquer' }}</button>
                    </form>
                    <form method="post" action="{{ path('app_admin_client_delete', {'id': client.id}) }}" style="margin:0;" onsubmit="return confirm('Sûr de supprimer ?');">
                        <button class="action-btn danger">Supprimer</button>
                    </form>
                </div>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="5" style="text-align:center; padding: 3rem; color:rgba(255,255,255,0.4);">Aucun voyageur trouvé.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
