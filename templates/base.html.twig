<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% block title %}Travelia — Luxury Travel Platform{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="{{ asset('css/horizon.css') }}" />
    {% block stylesheets %}{% endblock %}
</head>
<body>

    <!-- Live canvas particle FX -->
    <canvas id="live-canvas"></canvas>

    <!-- NAV -->
    <nav class="nav" id="nav">
        <div class="nav-logo">
            <div class="nav-logo-mark">T</div>
            <span class="nav-logo-text">Travelia</span>
        </div>

        <div class="nav-links">
            <a href="{{ path('app_home') }}#hero" class="nav-link active" data-section="0">Home</a>
            <a href="{{ path('app_home') }}#hotels" class="nav-link" data-section="1">Hotels</a>
            <a href="{{ path('app_home') }}#flights" class="nav-link" data-section="2">Flights</a>
            <a href="{{ path('app_home') }}#activities" class="nav-link" data-section="3">Activities</a>
            <a href="{{ path('app_home') }}#reviews" class="nav-link" data-section="4">Reviews</a>
        </div>

        <div class="auth-nav">
            {% if app.user %}
                <div class="profile-dropdown-container">
                    <button class="trip-btn" id="userMenuTrigger">
                        <span class="trip-icon">✦</span>
                        {{ app.user.prenom }}
                        <span class="dropdown-arrow">▾</span>
                    </button>
                    <div class="profile-dropdown-menu" id="profileDropdown">
                        <a href="{{ path('app_profile') }}" class="dropdown-item">
                            <span class="menu-icon">👤</span>
                            Profil
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="{{ path('app_logout') }}" class="dropdown-item logout">
                            <span class="menu-icon">⏻</span>
                            Déconnexion
                        </a>
                    </div>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="nav-link">Connexion</a>
                <a href="{{ path('app_register') }}" class="trip-btn">Inscription</a>
            {% endif %}
        </div>
    </nav>

    <main class="scroll-wrap" id="scroll-wrap">
        {% block body %}{% endblock %}
    </main>


    <script src="{{ asset('js/horizon-3d.js') }}"></script>
    <script>
        (function() {
            const initDropdown = () => {
                const trigger = document.getElementById('userMenuTrigger');
                const dropdown = document.getElementById('profileDropdown');
                
                if (!trigger || !dropdown) return;

                // Remove existing listener by cloning (simplest way to clear anonymous/multiple listeners)
                const newTrigger = trigger.cloneNode(true);
                trigger.parentNode.replaceChild(newTrigger, trigger);

                const toggleDropdown = (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    dropdown.classList.toggle('show');
                };

                newTrigger.addEventListener('click', toggleDropdown);

                // Close when clicking outside - only add once to document
                if (!window.dropdownClickRegistered) {
                    document.addEventListener('click', (e) => {
                        const activeDropdown = document.getElementById('profileDropdown');
                        const activeTrigger = document.getElementById('userMenuTrigger');
                        if (activeDropdown && activeDropdown.classList.contains('show') && 
                            !activeDropdown.contains(e.target) && !activeTrigger.contains(e.target)) {
                            activeDropdown.classList.remove('show');
                        }
                    });
                    window.dropdownClickRegistered = true;
                }
            };

            document.addEventListener('DOMContentLoaded', initDropdown);
            document.addEventListener('turbo:load', initDropdown);
        })();
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
