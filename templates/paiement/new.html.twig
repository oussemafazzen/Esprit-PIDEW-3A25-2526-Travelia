        function initPaymentDynamics() {
            const methodSelect = document.getElementById('paiement_methodePaiement');
            const cardFields = document.getElementById('dynamic-card-fields');
            const paypalFields = document.getElementById('dynamic-paypal-fields');

            if (!methodSelect) return;

            function updateUI() {
                const method = methodSelect.value;
                if (method === 'Visa' || method === 'MasterCard' || method === 'American express') {
                    cardFields.style.display = 'block';
                    paypalFields.style.display = 'none';
                } else if (method === 'PayPal') {
                    cardFields.style.display = 'none';
                    paypalFields.style.display = 'block';
                } else {
                    cardFields.style.display = 'none';
                    paypalFields.style.display = 'none';
                }
            }

            methodSelect.addEventListener('change', updateUI);
            updateUI(); // initial run
        }

        // Initialize on first load
        initPaymentDynamics();

        // ── Currency Converter (rates injected by PHP Controller, no client API call) ──
        const BASE_AMOUNT = {{ form.vars.value.montant }};

        // Rates fetched server-side by PaiementController::fetchExchangeRates()
        const exchangeRates = {{ exchangeRates|json_encode|raw }};

        const currencySymbols = {
            EUR: '€', USD: '$', GBP: '£', TND: 'TND ', MAD: 'MAD ',
