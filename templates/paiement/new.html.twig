<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Paiement Sécurisé — Travelia</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="{{ asset('hotel.css') }}?v=17" />
    
    <style>
        body {
            background-image: var(--view-bg);
            background-size: cover;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 3rem 0;
            box-sizing: border-box;
            overflow-y: auto;
            box-sizing: border-box;
        }

        .payment-container {
            width: 90%;
            max-width: 650px;
            margin: auto;
            background: transparent; /* Crystal clear as requested */
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 30px;
            padding: 5rem;
            color: #fff;
            animation: fadeIn 1s ease-out;
            text-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .payment-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .payment-header h1 {
            font-family: var(--serif);
            font-size: 3.5rem;
            font-weight: 400;
            margin-bottom: 1rem;
            letter-spacing: -1px;
        }

        .payment-header p {
            font-family: var(--grotesk);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 4px;
            opacity: 0.7;
        }

        .summary-box {
            background: rgba(255,255,255,0.05); /* Very thin ghost layer */
            border-radius: 20px;
            padding: 2.5rem;
            margin-bottom: 4rem;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.8rem;
            font-family: var(--grotesk);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.6);
        }
        .summary-row b { color: #fff; font-weight: 600; }

        .total-row {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .total-row .label { font-family: var(--grotesk); font-size: 0.8rem; opacity: 0.8; text-transform: uppercase; letter-spacing: 2px; }
        .total-row .price { font-family: var(--serif); font-size: 3rem; color: #fff; line-height: 1; }

        .form-glass { display: flex; flex-direction: column; gap: 2.5rem; }
        .form-group label {
            color: rgba(255,255,255,0.9); font-family: var(--grotesk); font-size: 0.75rem; 
            text-transform: uppercase; letter-spacing: 3px; display: block; margin-bottom: 1rem; font-weight: 700;
        }
        .form-group input, .form-group select {
            width: 100%; padding: 1.3rem; border-radius: 12px;
            background: rgba(255,255,255,0.08); /* Transparent input */
            border: 1px solid rgba(255,255,255,0.25);
            color: #fff; font-family: var(--sans); font-size: 1.1rem;
            transition: all 0.4s var(--ease);
        }
        .form-group input:focus, .form-group select:focus {
            background: rgba(255,255,255,0.15); border-color: #fff; outline: none; transform: scale(1.01);
        }
        .form-group select option { background: #fff; color: #000; }

        .payment-btn {
            margin-top: 2rem; width: 100%; padding: 1.5rem;
            background: #fff;
            color: #000; border: none; border-radius: 15px;
            font-size: 1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 4px;
            cursor: pointer; transition: all 0.4s var(--ease);
        }
        .payment-btn:hover { 
            transform: translateY(-5px); 
            background: var(--gold2);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        /* ── Currency Converter ── */
        .currency-converter {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        .currency-label {
            font-family: var(--grotesk);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.5);
            margin-bottom: 0.8rem;
        }
        .currency-row {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .currency-select {
            flex: 1;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            font-family: var(--grotesk);
            font-size: 0.85rem;
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
            transition: all 0.3s ease;
        }
        .currency-select:focus { outline: none; border-color: #fff; background: rgba(255,255,255,0.15); }
        .currency-select option { background: #1a1a2e; color: #fff; }
        .currency-result {
            font-family: var(--serif);
            font-size: 2rem;
            color: #fff;
            white-space: nowrap;
            min-width: 130px;
            text-align: right;
            transition: all 0.4s ease;
        }
        .currency-loading {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.4);
            font-family: var(--grotesk);
            text-transform: uppercase;
            letter-spacing: 1px;
            animation: pulse 1s infinite;
        }
        @keyframes pulse { 0%,100% { opacity:0.4; } 50% { opacity:1; } }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 2rem;
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
        }
        /* SUCCESS MODAL CRYSTAL STYLE */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(20px);
            display: none; /* Controlled by JS */
            align-items: center; justify-content: center;
            z-index: 2000;
            animation: fadeInOverlay 0.5s ease;
        }
        @keyframes fadeInOverlay { from { opacity: 0; } to { opacity: 1; } }

        .success-modal {
            width: 90%; max-width: 500px;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 30px;
            padding: 4rem 3rem;
            text-align: center;
            color: #fff;
            box-shadow: 0 50px 100px rgba(0,0,0,0.4);
            animation: modalPop 0.6s cubic-bezier(0.19, 1, 0.22, 1);
        }
        @keyframes modalPop { 
            from { opacity: 0; transform: scale(0.8) translateY(20px); } 
            to { opacity: 1; transform: scale(1) translateY(0); } 
        }

        .success-icon {
            width: 80px; height: 80px;
            background: #fff; color: #000;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem; margin: 0 auto 2.5rem;
            box-shadow: 0 10px 30px rgba(255,255,255,0.3);
        }

        .success-modal h2 { font-family: var(--serif); font-size: 2.5rem; margin-bottom: 1.5rem; letter-spacing: -1px; }
        .success-modal p { font-family: var(--sans); font-size: 1rem; line-height: 1.6; opacity: 0.9; margin-bottom: 2.5rem; }
        .success-modal b { color: var(--gold2); font-weight: 600; }

        .modal-btn {
            background: #fff; color: #000;
            padding: 1.2rem 3rem; border: none; border-radius: 50px;
            font-family: var(--grotesk); font-weight: 800; font-size: 0.9rem;
            text-transform: uppercase; letter-spacing: 2px;
            cursor: pointer; transition: 0.4s var(--ease);
        }
        .modal-btn:hover { background: var(--gold2); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    </style>
</head>
