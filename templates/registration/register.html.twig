<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Travelia — Inscription</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/horizon.css?v=5" />
  <style>
    body { margin:0; padding:0; background:#050814; color:#fff; font-family:'Inter', sans-serif; display:flex; flex-direction:column; min-height:100vh; overflow-x:hidden; }
    .stars-bg { position:fixed; top:0; left:0; width:100%; height:100%; z-index:-1; background: radial-gradient(circle at 50% 50%, #0a0f1e 0%, #030408 100%); }
    
    .nav { position:fixed; top:0; width:100%; padding:1rem 2.5rem; display:flex; justify-content:space-between; align-items:center; z-index:100; box-sizing:border-box; background:linear-gradient(to bottom, rgba(5,8,20,0.8), transparent); }
    .nav-logo { display:flex; align-items:center; gap:0.6rem; text-decoration:none; color:white; }
    .nav-logo-mark { background:#e8c97e; color:#000; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:600; }
    .nav-logo-text { font-family:'Space Grotesk',sans-serif; font-size:1.3rem; font-weight:700; letter-spacing:-0.5px; }
    .nav-links { display:flex; gap:2.5rem; }
    .nav-link { color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.85rem; font-weight:500; text-transform:uppercase; letter-spacing:1px; transition:0.3s; }
    .nav-link:hover { color:#fff; }
    .trip-btn { background:#e8c97e; border:none; border-radius:100px; padding:0.6rem 1.4rem; font-size:0.8rem; font-weight:600; color:#000; cursor:pointer; text-decoration:none; text-transform:uppercase; }
    
    .auth-container { flex:1; display:flex; align-items:center; justify-content:center; padding: 100px 20px; }
    .auth-box { width:100%; max-width:600px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:3rem; backdrop-filter:blur(20px); text-align:center; box-shadow:0 30px 60px rgba(0,0,0,0.5); }
    .auth-title { font-family:'Cormorant Garamond', serif; font-size:2.8rem; color:#fff; margin:0 0 2rem; font-weight:400; }
    
    .auth-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; text-align:left; }
    .full-width { grid-column: 1 / -1; }
    
    .auth-field label { display:none; }
    .auth-field input, .auth-field select { width:100%; box-sizing:border-box; background:rgba(0,0,0,0.2); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:0.8rem 1rem; color:#fff; font-size:0.95rem; outline:none; transition:border-color 0.3s; color-scheme:dark; }
    .auth-field input:focus, .auth-field select:focus { border-color:#e8c97e; }
    .form-error { color: #ef4444; font-size: 0.8rem; margin-top: 4px; }
    
    .auth-submit { grid-column: 1 / -1; width:100%; background:#e8c97e; color:#000; border:none; padding:1rem; border-radius:12px; font-weight:700; font-size:1rem; text-transform:uppercase; letter-spacing:1px; cursor:pointer; transition:transform 0.2s, background 0.2s; margin-top:1rem; }
    .auth-submit:hover { transform:translateY(-2px); background:#f4d890; }
    
    .auth-footer { margin-top:2rem; font-size:0.9rem; color:rgba(255,255,255,0.5); }
    .auth-footer a { color:#e8c97e; text-decoration:none; font-weight:600; }

    /* Face Capture Section */
    .face-capture-section {
      grid-column: 1 / -1;
      background: rgba(232,201,126,0.05);
      border: 1px solid rgba(232,201,126,0.2);
      border-radius: 16px;
      padding: 1.5rem;
      margin-top: 0.5rem;
      text-align: center;
    }
    .face-capture-title { font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:#e8c97e; margin:0 0 0.4rem; font-weight:400; }
    .face-capture-subtitle { color:rgba(255,255,255,0.5); font-size:0.82rem; margin-bottom:1rem; }
    #reg-video-container { position:relative; width:100%; max-width:280px; margin:0 auto 1rem; border-radius:12px; overflow:hidden; background:#000; display:none; }
    #reg-video { width:100%; display:block; border-radius:12px; }
    #reg-canvas { position:absolute; top:0; left:0; width:100%; height:100%; }
    #reg-face-status { font-size:0.85rem; margin-bottom:0.8rem; min-height:1.2em; color:rgba(255,255,255,0.6); }
    #reg-face-status.scanning { color:#e8c97e; }
    #reg-face-status.success { color:#4ade80; }
    #reg-face-status.error { color:#f87171; }
    .face-reg-actions { display:flex; gap:0.6rem; justify-content:center; flex-wrap:wrap; }
    .face-reg-btn {
      padding:0.65rem 1.4rem;
      border-radius:10px;
      font-size:0.82rem;
      font-weight:600;
      cursor:pointer;
      border:none;
      transition:all 0.2s;
      font-family:'Inter',sans-serif;
    }
    #reg-start-cam { background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.7); border:1px solid rgba(255,255,255,0.15) !important; }
    #reg-start-cam:hover { background:rgba(255,255,255,0.12); }
    #reg-capture-btn { background:#e8c97e; color:#000; display:none; }
    #reg-capture-btn:hover { background:#f4d890; }
    #reg-reset-btn { background:rgba(239,68,68,0.1); color:#f87171; border:1px solid rgba(239,68,68,0.2) !important; display:none; }
    #face-encoded-badge { display:none; align-items:center; gap:0.5rem; background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.3); border-radius:8px; padding:0.5rem 1rem; font-size:0.82rem; color:#4ade80; margin-bottom:0.8rem; justify-content:center; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .face-loading { display:inline-block; width:12px; height:12px; border:2px solid rgba(232,201,126,0.3); border-top-color:#e8c97e; border-radius:50%; animation:spin 0.8s linear infinite; vertical-align:middle; margin-right:4px; }
  </style>
</head>
<body>
  <div class="stars-bg"></div>

  <!-- NAV -->
  <nav class="nav">
    <a href="{{ path('app_home') }}" class="nav-logo">
      <div class="nav-logo-mark">T</div>
      <span class="nav-logo-text">Travelia</span>
    </a>
    <div class="nav-links">
      <a href="{{ path('app_home') }}" class="nav-link">Home</a>
    </div>
    <div style="display:flex; align-items:center; gap: 1rem;">
      <a href="{{ path('app_login') }}" class="nav-link">Connexion</a>
      <a href="{{ path('app_register') }}" class="trip-btn">Inscription</a>
    </div>
  </nav>

  <div class="auth-container">
    <div class="auth-box">
      <h1 class="auth-title">Inscription</h1>

      {{ form_start(registrationForm, {'attr': {'class': 'auth-form-grid'}}) }}
          
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.nom) }}
              <div class="form-error">{{ form_errors(registrationForm.nom) }}</div>
          </div>
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.prenom) }}
              <div class="form-error">{{ form_errors(registrationForm.prenom) }}</div>
          </div>
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.email) }}
              <div class="form-error">{{ form_errors(registrationForm.email) }}</div>
          </div>
          
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.password.first) }}
              <div class="form-error">{{ form_errors(registrationForm.password.first) }}</div>
          </div>
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.password.second) }}
          </div>

          <div class="auth-field full-width">
              {{ form_widget(registrationForm.telephone) }}
              <div class="form-error">{{ form_errors(registrationForm.telephone) }}</div>
          </div>
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.nationalite) }}
              <div class="form-error">{{ form_errors(registrationForm.nationalite) }}</div>
          </div>
          <div class="auth-field full-width">
              {{ form_widget(registrationForm.date_naissance) }}
              <div class="form-error">{{ form_errors(registrationForm.date_naissance) }}</div>
          </div>

          <!-- Hidden face encoding field -->
          <input type="hidden" name="face_encoding" id="face_encoding_input">

          <!-- Face Capture Section (Optional) -->
          <div class="face-capture-section full-width">
            <div id="face-encoded-badge">✓ Visage enregistré avec succès</div>
            <p class="face-capture-title">🎭 Reconnaissance Faciale <span style="font-size:0.75rem;color:rgba(255,255,255,0.4);">(optionnel)</span></p>
            <p class="face-capture-subtitle">Enregistrez votre visage pour vous connecter sans mot de passe lors de vos prochaines visites.</p>
            <div id="reg-video-container">
              <video id="reg-video" autoplay muted playsinline></video>
              <canvas id="reg-canvas"></canvas>
            </div>
            <div id="reg-face-status"></div>
            <div class="face-reg-actions">
              <button type="button" class="face-reg-btn" id="reg-start-cam">📷 Activer la caméra</button>
              <button type="button" class="face-reg-btn" id="reg-capture-btn">Capturer mon visage</button>
              <button type="button" class="face-reg-btn" id="reg-reset-btn">↺ Recommencer</button>
            </div>
          </div>

          <button type="submit" class="auth-submit">S'inscrire</button>
      {{ form_end(registrationForm) }}

      <div class="auth-footer">
        Déjà un compte ? <a href="{{ path('app_login') }}">Connexion</a>
      </div>
    </div>
  </div>

  <!-- face-api.js — served locally, no CDN needed -->
  <script src="/face-api.min.js"></script>
  <script>
    const MODELS_URL = '/models';
    let modelsLoaded = false;
    let regStream = null;
    let faceEncoded = false;

    const startCamBtn   = document.getElementById('reg-start-cam');
    const captureBtn    = document.getElementById('reg-capture-btn');
    const resetBtn      = document.getElementById('reg-reset-btn');
    const regVideo      = document.getElementById('reg-video');
    const regCanvas     = document.getElementById('reg-canvas');
    const regContainer  = document.getElementById('reg-video-container');
    const regStatus     = document.getElementById('reg-face-status');
    const encodedBadge  = document.getElementById('face-encoded-badge');
    const hiddenInput   = document.getElementById('face_encoding_input');

    function setRegStatus(msg, type='') {
      regStatus.innerHTML = msg;
      regStatus.className = type;
    }

    async function loadModels() {
      if (modelsLoaded) return;
      setRegStatus('Chargement des modèles IA…', 'scanning');
      try {
        await Promise.all([
          faceapi.nets.tinyFaceDetector.loadFromUri(MODELS_URL),
          faceapi.nets.faceLandmark68Net.loadFromUri(MODELS_URL),
          faceapi.nets.faceRecognitionNet.loadFromUri(MODELS_URL),
        ]);
        modelsLoaded = true;
      } catch(e) {
        throw new Error('models_failed');
      }
    }

    startCamBtn.addEventListener('click', async () => {
      startCamBtn.disabled = true;

      // Step 1: Load AI models
      try {
        setRegStatus('Chargement des modèles IA… (connexion internet requise)', 'scanning');
        await loadModels();
      } catch(e) {
        setRegStatus('❌ Impossible de charger les modèles IA. Vérifiez votre connexion internet.', 'error');
        startCamBtn.disabled = false;
        return;
      }

      // Step 2: Access camera
      try {
        setRegStatus('Accès à la caméra…', 'scanning');
        regStream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'user', width: { ideal: 320 }, height: { ideal: 240 } }
        });
        regVideo.srcObject = regStream;
        await new Promise(r => { regVideo.onloadedmetadata = r; });
        regCanvas.width  = regVideo.videoWidth;
        regCanvas.height = regVideo.videoHeight;
        regContainer.style.display = 'block';
        captureBtn.style.display = 'inline-block';
        startCamBtn.style.display = 'none';
        setRegStatus('✓ Caméra active. Positionnez votre visage et cliquez sur Capturer.', 'scanning');
      } catch(e) {
        console.error('Camera error:', e.name, e.message);
        if (e.name === 'NotAllowedError' || e.name === 'PermissionDeniedError') {
          setRegStatus('🔒 Permission caméra refusée.<br><small>Cliquez sur l\'icône 🎥 dans la barre d\'adresse du navigateur → Autoriser.</small>', 'error');
        } else if (e.name === 'NotFoundError' || e.name === 'DevicesNotFoundError') {
          setRegStatus('❌ Aucune caméra détectée sur cet appareil.', 'error');
        } else if (e.name === 'NotReadableError' || e.name === 'TrackStartError') {
          setRegStatus('❌ La caméra est déjà utilisée par une autre application. Fermez-la et réessayez.', 'error');
        } else {
          setRegStatus('❌ Erreur caméra : ' + e.name + '. Réessayez ou utilisez un autre navigateur.', 'error');
        }
        startCamBtn.disabled = false;
      }
    });

    captureBtn.addEventListener('click', async () => {
      captureBtn.disabled = true;
      setRegStatus('Analyse…', 'scanning');
      try {
        const detection = await faceapi
          .detectSingleFace(regVideo, new faceapi.TinyFaceDetectorOptions({ inputSize: 320, scoreThreshold: 0.5 }))
          .withFaceLandmarks()
          .withFaceDescriptor();

        if (!detection) {
          setRegStatus('Aucun visage détecté. Repositionnez-vous.', 'error');
          captureBtn.disabled = false;
          return;
        }

        const descriptor = Array.from(detection.descriptor);
        hiddenInput.value = JSON.stringify(descriptor);
        faceEncoded = true;

        // Stop camera
        if (regStream) { regStream.getTracks().forEach(t => t.stop()); regStream = null; }
        regContainer.style.display = 'none';
        captureBtn.style.display = 'none';
        resetBtn.style.display = 'inline-block';
        encodedBadge.style.display = 'flex';
        setRegStatus('Votre visage a été enregistré.', 'success');
      } catch(e) {
        setRegStatus('Erreur lors de la capture. Réessayez.', 'error');
        captureBtn.disabled = false;
      }
    });

    resetBtn.addEventListener('click', () => {
      hiddenInput.value = '';
      faceEncoded = false;
      resetBtn.style.display = 'none';
      encodedBadge.style.display = 'none';
      regContainer.style.display = 'none';
      captureBtn.style.display = 'none';
      startCamBtn.style.display = 'inline-block';
      startCamBtn.disabled = false;
      setRegStatus('');
    });
  </script>
</body>
</html>
