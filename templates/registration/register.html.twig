{% extends 'base.html.twig' %}

{% block title %}Inscription — Travelia{% endblock %}

{% block stylesheets %}
<style>
    .auth-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(40px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 24px;
        padding: 3rem;
        max-width: 500px;
        margin: 100px auto;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    }
    .auth-title {
        font-family: var(--serif);
        font-size: 2.5rem;
        font-weight: 300;
        text-align: center;
        margin-bottom: 2rem;
        color: var(--white);
    }
    .form-group {
        margin-bottom: 1.2rem;
    }
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0.8rem 1.2rem;
        color: #fff;
        font-size: 0.9rem;
        transition: 0.3s;
    }
    .form-control:focus {
        border-color: var(--gold);
        background: rgba(255, 255, 255, 0.1);
    }
    .error-list {
        color: #ef4444;
        font-size: 0.75rem;
        margin-top: 0.3rem;
        list-style: none;
        padding-left: 0.5rem;
    }
    select.form-control option {
        background: var(--ink);
        color: #fff;
    }
</style>
{% endblock %}

{% block body %}
<section class="panel" style="display: block; overflow-y: auto;">
    <div class="auth-card">
        <h1 class="auth-title">Inscription</h1>

        <div style="margin-bottom: 2rem; text-align: center;">
            <a href="{{ path('connect_google') }}" class="trip-btn" style="background: #fff; color: #1f1f1f; border: none; padding: 0.8rem 2.5rem; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 12px; text-decoration: none; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.2); border-radius: 12px;">
                <svg width="18" height="18" viewBox="0 0 18 18">
                    <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z" fill="#4285F4"/>
                    <path d="M9 18c2.43 0 4.467-.806 5.956-2.184L12.048 13.558c-.806.54-1.836.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z" fill="#34A853"/>
                    <path d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.347 6.173 0 7.548 0 9c0 1.452.347 2.827.957 4.039l3.007-2.332z" fill="#FBBC05"/>
                    <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z" fill="#EA4335"/>
                </svg>
                S'inscrire avec Google
            </a>
            <div style="display: flex; align-items: center; justify-content: center; margin: 1.5rem 0; gap: 1rem;">
                <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
                <span style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.4;">ou via email</span>
                <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
            </div>
        </div>

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="form-group">
                {{ form_row(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.prenom, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.password.first, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.password.second, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                <div style="display: flex; gap: 10px;">
                    <div style="flex: 0 0 130px;">
                        {{ form_widget(registrationForm.phone_prefix, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    <div style="flex: 1;">
                        {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>
                {{ form_errors(registrationForm.telephone) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.nationalite, {'attr': {'class': 'form-control'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(registrationForm.date_naissance, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 2rem;">
                <input type="hidden" name="face_encoding" id="face_encoding">
                <button type="button" id="btn-face-register" class="cta-btn full" style="background: rgba(255, 255, 255, 0.1); border: 1px solid var(--gold); color: var(--gold2); display: flex; align-items: center; justify-content: center; gap: 10px;">
                    <i class="fas fa-camera"></i> Enregistrer mon visage
                </button>
                <div id="face-status" style="display: none; font-size: 0.85rem; text-align: center; margin-bottom: 5px;">
                    <span id="face-status-text" style="color: rgba(255,255,255,0.7);"></span>
                    <span id="face-status-check" style="color: #10b981; display: none;">✓</span>
                </div>
                <input type="file" id="face-file-input" accept="image/*" style="display: none;">

                <button type="submit" class="cta-btn full">S'inscrire</button>
                <a href="{{ path('app_home') }}" class="cta-btn full" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6);">Retour à l'accueil</a>
            </div>
        {{ form_end(registrationForm) }}
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const btnFace = document.getElementById('btn-face-register');
        const fileInput = document.getElementById('face-file-input');
        const statusDiv = document.getElementById('face-status');
        const statusText = document.getElementById('face-status-text');
        const statusCheck = document.getElementById('face-status-check');
        const encodingInput = document.getElementById('face_encoding');

        // Loading models from a reliable mirror
        const MODEL_URL = 'https://raw.githubusercontent.com/justadudewhohacks/face-api.js/master/weights/';

        btnFace.addEventListener('click', () => {
            fileInput.click();
        });

        fileInput.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            statusDiv.style.display = 'block';
            statusCheck.style.display = 'none';
            statusText.innerText = 'Chargement des modèles...';
            statusText.style.color = 'rgba(255,255,255,0.7)';

            try {
                // Check if models are loaded
                if (!faceapi.nets.ssdMobilenetv1.params) {
                    await Promise.all([
                        faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_URL),
                        faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
                        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
                    ]);
                }

                statusText.innerText = 'Détection du visage en cours..';
                
                const img = await faceapi.bufferToImage(file);
                const detection = await faceapi.detectSingleFace(img).withFaceLandmarks().withFaceDescriptor();

                if (detection) {
                    encodingInput.value = JSON.stringify(Array.from(detection.descriptor));
                    statusText.innerText = 'Visage détecté avec succès !';
                    statusText.style.color = '#10b981';
                    statusCheck.style.display = 'inline';
                    btnFace.style.borderColor = '#10b981';
                } else {
                    statusText.innerText = 'Aucun visage détecté. Réessayez.';
                    statusText.style.color = '#ef4444';
                }
            } catch (err) {
                console.error(err);
                statusText.innerText = 'Erreur lors de la détection.';
                statusText.style.color = '#ef4444';
            }
        });
    });
</script>
{% endblock %}
