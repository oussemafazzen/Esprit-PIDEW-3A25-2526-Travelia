{% extends 'admin_base.html.twig' %}

{% block title %}Reservation index{% endblock %}

{% block body %}
    <div class="crud-header-actions" style="margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; gap: 2rem;">
            <h2>Reservation List</h2>
            <form action="{{ path('app_reservationhebergement_index') }}" method="get" style="display: flex; gap: 0.5rem; align-items: center;">
                <div style="position: relative;">
                    <input type="text" name="search" value="{{ currentSearch }}" placeholder="Rechercher par hébergement..." 
                        style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 0.6rem 1rem; border-radius: 8px; color: white; width: 300px; font-family: var(--sans); font-size: 0.9rem;">
                    {% if currentSearch %}
                        <a href="{{ path('app_reservationhebergement_index') }}" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.3); text-decoration: none;">✕</a>
                    {% endif %}
                </div>
                <button type="submit" style="background: var(--gold); border: none; padding: 0.6rem 1.2rem; border-radius: 8px; color: var(--ink); font-weight: 700; cursor: pointer; font-size: 0.85rem; text-transform: uppercase;">Rechercher</button>
            </form>
        </div>
        
        <div class="sort-container">
            <span class="sort-label">Trier Par:</span>
            <div class="sort-options">
                <a href="{{ path('app_reservationhebergement_index', { 'sort_by': 'nom_hebergement', 'search': currentSearch }) }}" 
                   class="sort-pill {% if currentSort == 'nom_hebergement' %}active{% endif %}">
                    Hébergement
                </a>
                <a href="{{ path('app_reservationhebergement_index', { 'sort_by': 'statut', 'search': currentSearch }) }}" 
                   class="sort-pill {% if currentSort == 'statut' %}active{% endif %}">
                    Statut
                </a>
                {% if currentSort %}
                    <a href="{{ path('app_reservationhebergement_index', { 'search': currentSearch }) }}" class="sort-reset" title="Réinitialiser">↺</a>
                {% endif %}
            </div>
        </div>
    </div>

    <table class="crud-table">
        <thead>
            <tr>
                <th>Id</th>
                <th style="color: var(--gold);">Hebergement</th>
                <th>Date Debut</th>
                <th>Date Fin</th>
                <th>Personnes</th>
                <th>Statut</th>
                <th>Client Id</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for reservationhebergement in reservationhebergements %}
            <tr>
                <td>{{ reservationhebergement.idReservationHebergement }}</td>
                <td><strong style="color: white; font-weight: 600; letter-spacing: 0.02em;">{{ reservationhebergement.idHebergement ? reservationhebergement.idHebergement.nom : '' }}</strong></td>
                <td><span style="color: var(--gold2);">{{ reservationhebergement.dateDebut ? reservationhebergement.dateDebut|date('Y-m-d') : '' }}</span></td>
                <td><span style="color: var(--gold2);">{{ reservationhebergement.dateFin ? reservationhebergement.dateFin|date('Y-m-d') : '' }}</span></td>
                <td>{{ reservationhebergement.nombrePersonnes }}</td>
                <td>
                    <span class="status-badge {% if reservationhebergement.statut|lower == 'confirmé' or reservationhebergement.statut|lower == 'confirme' %}confirmed{% elseif reservationhebergement.statut|lower == 'annulé' or reservationhebergement.statut|lower == 'annule' %}cancelled{% else %}pending{% endif %}">
                        {{ reservationhebergement.statut }}
                    </span>
                </td>
                <td>{{ reservationhebergement.idClient }}</td>
                <td>
                    <div class="crud-actions">
                        <a class="crud-action-btn lux-modal-trigger" data-modal-title="Reservation Details" href="{{ path('app_reservationhebergement_show', {'idReservationHebergement': reservationhebergement.idReservationHebergement}) }}">View</a>
                        <a class="crud-action-btn lux-modal-trigger" data-modal-title="Edit Reservation" href="{{ path('app_reservationhebergement_edit', {'idReservationHebergement': reservationhebergement.idReservationHebergement}) }}">Edit</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" style="text-align: center; padding: 4rem; opacity: 0.4;">No records found. Click 'Create new' to add an entry.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
