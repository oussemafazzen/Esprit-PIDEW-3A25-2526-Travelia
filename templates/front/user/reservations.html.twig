{% extends 'base.html.twig' %}

{% block title %}Mes réservations - Travelia{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/horizon.css') }}?v=24">
    <link rel="stylesheet" href="{{ asset('css/flights-results.css') }}?v=24">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">

    <style>
        .form-modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 6000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background: rgba(3, 7, 18, 0.40);
            backdrop-filter: blur(10px);
        }

        .form-modal-overlay.active {
            display: flex;
        }

        .form-modal-box {
            width: min(760px, 100%);
            max-height: 88vh;
            overflow-y: auto;
            overflow-x: hidden;
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.10);
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(26px) saturate(160%);
            -webkit-backdrop-filter: blur(26px) saturate(160%);
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
            padding: 30px 28px 24px;
            color: #fff;
        }

        .form-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 22px;
        }

        .form-modal-title {
            margin: 0;
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.2rem, 4vw, 3.4rem);
            font-weight: 500;
            line-height: 1;
            color: #fff;
        }

        .form-modal-close {
            width: 52px;
            height: 52px;
            border: none;
            border-radius: 999px;
            cursor: pointer;
            font-size: 1.4rem;
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
            transition: all 0.2s ease;
        }

        .form-modal-close:hover {
            background: rgba(255, 255, 255, 0.14);
            transform: scale(1.04);
        }

        .js-open-new-modal {
            display: none !important;
        }

        .form-modal-body {
            width: 100%;
        }

        .form-modal-body form {
            width: 100%;
        }

        .form-modal-body form > div {
            width: 100%;
            margin-bottom: 16px;
        }

        .form-modal-body label {
            display: block;
            margin-bottom: 8px;
            color: rgba(255,255,255,0.92);
            font-weight: 700;
            font-size: 0.98rem;
        }

        .form-modal-body input,
        .form-modal-body select,
        .form-modal-body textarea {
            width: 100%;
            min-height: 56px;
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(255,255,255,0.08);
            color: #fff;
            padding: 0 18px;
            outline: none;
            box-sizing: border-box;
            font-size: 1rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
        }

        .form-modal-body textarea {
            min-height: 120px;
            padding: 14px 18px;
            resize: vertical;
        }

        .form-modal-body input:focus,
        .form-modal-body select:focus,
        .form-modal-body textarea:focus {
            border-color: rgba(201, 168, 76, 0.45);
            box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.08);
        }

        .form-modal-body option {
            color: #111;
        }

        .form-modal-body button.premium-flight-book-btn {
            min-width: 180px;
        }

        .flatpickr-calendar {
            background: rgba(17, 25, 40, 0.82) !important;
            border: 1px solid rgba(255,255,255,0.10) !important;
            box-shadow: 0 20px 50px rgba(0,0,0,0.35) !important;
            backdrop-filter: blur(18px) !important;
            -webkit-backdrop-filter: blur(18px) !important;
            border-radius: 22px !important;
            overflow: hidden !important;
            color: #fff !important;
            padding: 10px !important;
        }

        .flatpickr-months,
        .flatpickr-weekdays,
        .flatpickr-days,
        .dayContainer,
        .flatpickr-rContainer,
        .flatpickr-month {
            background: transparent !important;
        }

        .flatpickr-current-month,
        .flatpickr-current-month .flatpickr-monthDropdown-months,
        .flatpickr-current-month input.cur-year {
            color: #fff !important;
            background: transparent !important;
            font-weight: 700;
        }

        span.flatpickr-weekday {
            background: transparent !important;
            color: rgba(255,255,255,0.60) !important;
            font-weight: 600;
        }

        .flatpickr-day {
            color: #fff !important;
            border: none !important;
            border-radius: 12px !important;
            background: transparent !important;
        }

        .flatpickr-day:hover {
            background: rgba(255,255,255,0.08) !important;
        }

        .flatpickr-day.today {
            border: 1px solid rgba(215, 184, 90, 0.55) !important;
            color: #f2d47a !important;
        }

        .flatpickr-day.selected,
        .flatpickr-day.startRange,
        .flatpickr-day.endRange {
            background: linear-gradient(135deg, #d7b85a, #e7c86e) !important;
            color: #111 !important;
            box-shadow: 0 6px 18px rgba(201, 168, 76, 0.25);
        }

        .flatpickr-day.prevMonthDay,
        .flatpickr-day.nextMonthDay {
            color: rgba(255,255,255,0.24) !important;
        }

        .flatpickr-prev-month,
        .flatpickr-next-month {
            fill: rgba(255,255,255,0.85) !important;
            color: rgba(255,255,255,0.85) !important;
        }

        .flatpickr-prev-month:hover svg,
        .flatpickr-next-month:hover svg {
            fill: #f2d47a !important;
        }

        .choices {
            margin-bottom: 0 !important;
        }

        .choices__inner {
            min-height: 56px !important;
            border-radius: 18px !important;
            border: 1px solid rgba(255,255,255,0.12) !important;
            background: rgba(255,255,255,0.08) !important;
            color: #fff !important;
            padding: 13px 48px 13px 18px !important;
            font-size: 1rem !important;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.03) !important;
        }

        .is-focused .choices__inner,
        .is-open .choices__inner {
            border-color: rgba(201, 168, 76, 0.45) !important;
            box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.08) !important;
        }

        .choices[data-type*="select-one"]::after {
            border-color: rgba(255,255,255,0.85) transparent transparent !important;
            right: 18px !important;
            margin-top: -2px !important;
        }

        .choices[data-type*="select-one"].is-open::after {
            border-color: transparent transparent rgba(255,255,255,0.85) !important;
            margin-top: -7px !important;
        }

        .choices__list--single {
            padding: 0 !important;
            color: #fff !important;
        }

        .choices__placeholder {
            color: rgba(255,255,255,0.45) !important;
            opacity: 1 !important;
        }

        .choices__list--dropdown,
        .choices__list[aria-expanded] {
            margin-top: 8px !important;
            border-radius: 18px !important;
            border: 1px solid rgba(255,255,255,0.10) !important;
            background: rgba(17, 25, 40, 0.92) !important;
            backdrop-filter: blur(18px) !important;
            -webkit-backdrop-filter: blur(18px) !important;
            box-shadow: 0 20px 50px rgba(0,0,0,0.35) !important;
            overflow: hidden !important;
        }

        .choices__list--dropdown .choices__item,
        .choices__list[aria-expanded] .choices__item {
            color: #fff !important;
            padding: 12px 16px !important;
            font-size: 0.98rem !important;
            background: transparent !important;
        }

        .choices__list--dropdown .choices__item--selectable.is-highlighted,
        .choices__list[aria-expanded] .choices__item--selectable.is-highlighted {
            background: rgba(215, 184, 90, 0.18) !important;
            color: #f5d77c !important;
        }

        .choices__item--disabled {
            color: rgba(255,255,255,0.35) !important;
        }

        .delete-modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 7000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background: rgba(3, 7, 18, 0.76);
            backdrop-filter: blur(8px);
        }

        .delete-modal-overlay.is-open {
            display: flex;
        }

        .delete-modal-box {
            width: min(560px, 100%);
            border-radius: 28px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: linear-gradient(180deg, rgba(4, 9, 28, 0.97), rgba(3, 8, 24, 0.99));
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
            padding: 34px 30px 28px;
            text-align: center;
            color: #fff;
        }

        .delete-modal-icon {
            width: 68px;
            height: 68px;
            margin: 0 auto 18px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffd54a;
            font-size: 2.2rem;
        }

        .delete-modal-title {
            margin: 0 0 12px;
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.2rem, 4vw, 3.2rem);
            font-weight: 500;
            line-height: 1;
            color: #ffffff;
        }

        .delete-modal-text {
            margin: 0 auto;
            max-width: 420px;
            font-size: 1.02rem;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.72);
        }

        .delete-modal-actions {
            margin-top: 28px;
            display: flex;
            justify-content: center;
            gap: 18px;
            flex-wrap: wrap;
        }

        .delete-modal-cancel,
        .delete-modal-confirm {
            min-width: 160px;
            height: 58px;
            border-radius: 18px;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .delete-modal-cancel {
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        }

        .delete-modal-confirm {
            background: linear-gradient(135deg, #b71c1c, #d32f2f);
            color: #ffffff;
            box-shadow: 0 12px 30px rgba(183, 28, 28, 0.28);
        }

        .delete-modal-cancel:hover,
        .delete-modal-confirm:hover {
            transform: translateY(-2px);
        }

        .reservation-calendar-card {
            margin-bottom: 18px;
            padding: 22px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.10);
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(22px) saturate(150%);
            -webkit-backdrop-filter: blur(22px) saturate(150%);
            box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
        }

        .reservation-calendar-card[hidden] {
            display: none;
        }

        .reservation-calendar-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 18px;
        }

        .reservation-calendar-kicker {
            margin: 0 0 6px;
            color: #e8c97a;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .reservation-calendar-title {
            margin: 0;
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 500;
            line-height: 1;
            color: #ffffff;
        }

        .reservation-calendar-title span {
            color: #e8c97a;
            font-style: italic;
        }

        .reservation-calendar-actions {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .reservation-calendar-nav {
            width: 42px;
            height: 42px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            cursor: pointer;
            font-size: 1.15rem;
            transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
        }

        .reservation-calendar-nav:hover {
            transform: translateY(-1px);
            background: rgba(232, 201, 122, 0.16);
            color: #e8c97a;
        }

        .reservation-calendar-month {
            min-width: 150px;
            color: rgba(255, 255, 255, 0.86);
            font-weight: 800;
            text-align: center;
            text-transform: capitalize;
        }

        .reservation-calendar-weekdays,
        .reservation-calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 8px;
        }

        .reservation-calendar-weekdays {
            margin-bottom: 8px;
        }

        .reservation-calendar-weekdays span {
            color: rgba(255, 255, 255, 0.45);
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-align: center;
            text-transform: uppercase;
        }

        .reservation-calendar-day {
            position: relative;
            min-height: 74px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.045);
            color: rgba(255, 255, 255, 0.78);
            cursor: default;
            padding: 10px;
            text-align: left;
            transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .reservation-calendar-day.is-muted {
            opacity: 0.32;
        }

        .reservation-calendar-day.is-today {
            border-color: rgba(232, 201, 122, 0.46);
        }

        .reservation-calendar-day.has-reservation {
            cursor: pointer;
            border-color: rgba(232, 201, 122, 0.44);
            background: linear-gradient(145deg, rgba(201, 168, 76, 0.24), rgba(255, 255, 255, 0.07));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 12px 26px rgba(0, 0, 0, 0.18);
        }

        .reservation-calendar-day.has-reservation:hover,
        .reservation-calendar-day.is-selected {
            transform: translateY(-2px);
            border-color: rgba(232, 201, 122, 0.76);
            background: linear-gradient(145deg, rgba(201, 168, 76, 0.36), rgba(255, 255, 255, 0.09));
        }

        .reservation-calendar-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            font-size: 0.85rem;
            font-weight: 800;
        }

        .reservation-calendar-day.is-today .reservation-calendar-number {
            background: rgba(232, 201, 122, 0.18);
            color: #f2d47a;
        }

        .reservation-calendar-count {
            position: absolute;
            right: 8px;
            bottom: 8px;
            min-width: 26px;
            height: 26px;
            padding: 0 8px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #c9a84c, #e8c97a);
            color: #0a0d1a;
            font-size: 0.72rem;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(201, 168, 76, 0.24);
        }

        .reservation-calendar-details {
            margin-top: 18px;
            padding-top: 18px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .reservation-calendar-details-title {
            margin: 0 0 10px;
            color: rgba(255, 255, 255, 0.88);
            font-weight: 800;
        }

        .reservation-calendar-details-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .reservation-calendar-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 36px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            color: rgba(255, 255, 255, 0.82);
            font-size: 0.82rem;
        }

        .reservation-calendar-pill strong {
            color: #e8c97a;
        }

        .reservation-calendar-empty-text {
            margin: 0;
            color: rgba(255, 255, 255, 0.56);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .reservation-badge--status {
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(255, 255, 255, 0.08);
            color: rgba(255, 255, 255, 0.82);
        }

        .reservation-badge--confirme,
        .reservation-badge--confirmed {
            background: rgba(16, 185, 129, 0.18);
            color: #6ee7b7;
        }

        .reservation-badge--retarde {
            background: rgba(245, 158, 11, 0.18);
            color: #fbbf24;
        }

        .reservation-badge--annule {
            background: rgba(239, 68, 68, 0.18);
            color: #f87171;
        }

        .reservation-disruption-alert {
            margin-top: 8px;
            padding: 10px 12px;
            border-radius: 14px;
            border: 1px solid rgba(245, 158, 11, 0.22);
            background: rgba(245, 158, 11, 0.10);
            color: #f8d47a;
            font-size: 0.78rem;
            line-height: 1.45;
        }

        .reservation-disruption-alert--annule {
            border-color: rgba(239, 68, 68, 0.26);
            background: rgba(239, 68, 68, 0.12);
            color: #fecaca;
        }

        .reservation-flight-meta {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .reservation-meta-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .reservation-meta-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px 16px;
            font-size: 0.88rem;
            line-height: 1.45;
            color: rgba(255, 255, 255, 0.88);
        }

        .reservation-meta-k {
            display: block;
            font-size: 0.68rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(232, 201, 122, 0.85);
            font-weight: 800;
            margin-bottom: 2px;
        }

        .reservation-meta-foot {
            margin: 10px 0 0;
            font-size: 0.72rem;
            line-height: 1.4;
            color: rgba(255, 255, 255, 0.48);
        }

        @media (max-width: 640px) {
            .form-modal-overlay,
            .delete-modal-overlay {
                padding: 14px;
            }

            .form-modal-box,
            .delete-modal-box {
                padding: 20px 16px;
                border-radius: 22px;
            }

            .form-modal-title {
                font-size: 2.2rem;
            }

            .form-modal-close {
                width: 46px;
                height: 46px;
            }

            .form-modal-body input,
            .form-modal-body select,
            .form-modal-body textarea {
                min-height: 52px;
            }

            .form-modal-body button.premium-flight-book-btn,
            .delete-modal-cancel,
            .delete-modal-confirm {
                width: 100%;
            }

            .delete-modal-actions {
                flex-direction: column;
            }

            .reservation-calendar-card {
                padding: 16px;
                border-radius: 20px;
            }

            .reservation-calendar-top {
                flex-direction: column;
            }

            .reservation-calendar-actions {
                width: 100%;
                justify-content: space-between;
            }

            .reservation-calendar-month {
                min-width: 0;
                flex: 1;
            }

            .reservation-calendar-weekdays,
            .reservation-calendar-grid {
                gap: 5px;
            }

            .reservation-calendar-day {
                min-height: 54px;
                border-radius: 12px;
                padding: 6px;
            }

            .reservation-calendar-count {
                right: 5px;
                bottom: 5px;
                min-width: 21px;
                height: 21px;
                padding: 0 6px;
                font-size: 0.64rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
{% set cityMap = {
    'PAR': 'Paris',
    'TUN': 'Tunis',
    'NYC': 'New York',
    'LON': 'London',
    'ROM': 'Rome',
    'MAD': 'Madrid',
    'BER': 'Berlin',
    'DXB': 'Dubai',
    'IST': 'Istanbul',
    'ALG': 'Alger',
    'BAH': 'Bahreïn',
    'BAK': 'Bakou'
} %}
{% set billetStatusLabels = {
    'confirme': 'Confirmé',
    'confirmed': 'Confirmé',
    'retarde': 'Retardé',
    'annule': 'Annulé',
    'en_attente': 'En attente'
} %}
{% set reservationCalendarItems = [] %}
{% for reservation in reservations %}
    {% if reservation.dateReservation %}
        {% set reservationCalendarItems = reservationCalendarItems|merge([{
            id: reservation.id,
            date: reservation.dateReservation|date('Y-m-d'),
            destination: reservation.paysDestination ?? reservation.pays ?? 'Destination non définie',
            status: reservation.statut ?? '',
            billets: reservation.billets|length
        }]) %}
    {% endif %}
{% endfor %}

<canvas id="live-canvas"></canvas>

{% include 'front/_site_nav.html.twig' with { active_nav: 'reservations' } %}

<div class="reservations-page">
    <section class="reservations-wrapper">
        <div class="reservations-header">
            <div class="reservations-tag">✦ Espace utilisateur</div>
            <h1 class="reservations-title">
                Mes <span>réservations</span>
            </h1>
            <p class="reservations-subtitle">
                Consultez vos réservations et vos billets dans une interface moderne.
            </p>

            <div style="margin-top: 18px; display:flex; gap:12px; flex-wrap:wrap;">
                <button type="button"
                        class="premium-flight-book-btn"
                        id="toggleReservationCalendar"
                        aria-controls="reservationCalendarSection"
                        aria-expanded="false">
                    Calendrier
                </button>

                <button type="button" class="premium-flight-book-btn js-open-new-modal">
                    + Nouvelle réservation
                </button>
            </div>
        </div>

        <section class="reservation-calendar-card" id="reservationCalendarSection" aria-labelledby="reservationCalendarTitle" hidden>
            <div class="reservation-calendar-top">
                <div>
                    <p class="reservation-calendar-kicker">Calendrier</p>
                    <h2 class="reservation-calendar-title" id="reservationCalendarTitle">
                        Dates <span>réservées</span>
                    </h2>
                </div>

                <div class="reservation-calendar-actions" aria-label="Navigation du calendrier">
                    <button type="button" class="reservation-calendar-nav" id="reservationCalendarPrev" aria-label="Mois précédent">
                        &lsaquo;
                    </button>
                    <div class="reservation-calendar-month" id="reservationCalendarMonth"></div>
                    <button type="button" class="reservation-calendar-nav" id="reservationCalendarNext" aria-label="Mois suivant">
                        &rsaquo;
                    </button>
                </div>
            </div>

            <div class="reservation-calendar-weekdays" aria-hidden="true">
                <span>Lun</span>
                <span>Mar</span>
                <span>Mer</span>
                <span>Jeu</span>
                <span>Ven</span>
                <span>Sam</span>
                <span>Dim</span>
            </div>

            <div class="reservation-calendar-grid" id="reservationCalendarGrid"></div>

            <div class="reservation-calendar-details" id="reservationCalendarDetails">
                <p class="reservation-calendar-empty-text">
                    Sélectionnez une date dorée pour voir les réservations correspondantes.
                </p>
            </div>
        </section>

        <script type="application/json" id="reservation-calendar-data">{{ reservationCalendarItems|json_encode|raw }}</script>

        <div class="reservations-list">
            {% if reservations is not empty %}
                {% for reservation in reservations %}
                    {% set reservationDestination = reservation.paysDestination ?? reservation.pays ?? '' %}
                    {% set totalPrice = 0 %}

                    {% for billet in reservation.billets %}
                        {% set totalPrice = totalPrice + (billet.prix ?? 0) %}
                    {% endfor %}

                    <div class="reservation-box">
                        <div class="reservation-left">
                            <div class="reservation-icon">✈</div>

                            <div class="reservation-meta">
                                <h3>Réservation #{{ reservation.id }}</h3>
                                <p>
                                    {% if reservation.dateReservation %}
                                        {{ reservation.dateReservation|date('d/m/Y') }}
                                    {% endif %}
                                </p>
                            </div>
                        </div>

                        <div class="reservation-center">
                            {% if reservation.billets is not empty %}
                                {% for billet in reservation.billets %}
                                    {% set departCode = billet.bookedOriginCode is not empty ? billet.bookedOriginCode : 'TUN' %}
                                    {% set arriveeCode = billet.bookedDestinationCode is not empty ? billet.bookedDestinationCode : (reservation.paysDestination ?? reservation.pays ?? 'Destination') %}
                                    {% set transportType = billet.typeTransport ?? 'avion' %}
                                    {% set billetStatusRaw = billet.statut ?? '' %}
                                    {% set billetStatusKey = billetStatusRaw|lower|replace({' ': '_', 'é':'e', 'è':'e', 'ê':'e', 'Ã©':'e', 'Ã¨':'e', 'Ãª':'e'}) %}

                                    <div class="reservation-route-block">
                                        <div class="reservation-route">
                                            <div class="reservation-city">
                                                <strong>{{ cityMap[departCode] ?? departCode }}</strong>
                                            </div>

                                            <div class="reservation-line-wrap">
                                                <div class="reservation-line"></div>
                                                <div class="reservation-plane">
                                                    {% if transportType|lower == 'train' %}
                                                        🚆
                                                    {% elseif transportType|lower == 'bus' %}
                                                        🚌
                                                    {% elseif transportType|lower == 'bateau' %}
                                                        ⛴
                                                    {% else %}
                                                        ✈
                                                    {% endif %}
                                                </div>
                                            </div>

                                            <div class="reservation-city">
                                                <strong>{{ cityMap[arriveeCode] ?? arriveeCode }}</strong>
                                            </div>
                                        </div>

                                        <div class="reservation-route-info">
                                            {% if billet.dateDepart %}
                                                <span>{{ billet.dateDepart|date('d M Y') }}</span>
                                            {% endif %}

                                            <span class="reservation-badge">
                                                {{ transportType }}
                                            </span>

                                            {% if billetStatusRaw %}
                                                <span class="reservation-badge reservation-badge--status reservation-badge--{{ billetStatusKey }}">
                                                    {{ billetStatusLabels[billetStatusKey]|default(billetStatusRaw) }}
                                                </span>
                                            {% endif %}
                                        </div>

                                        {% set depDt = billet.dateDepart %}
                                        {% set arrDt = billet.dateArrivee %}
                                        {% set hasSnapshot = billet.bookedTripType is not empty %}
                                        {% set tc = billet.bookedTravelClass|default('') %}
                                        {% set classLabels = {
                                            'business': 'Business',
                                            'first': 'Première',
                                            'premium_economy': 'Premium Economy',
                                            'economy': 'Économique'
                                        } %}
                                        {% set classDisplay = tc ? (classLabels[tc]|default(tc|capitalize)) : '—' %}
                                        {% set fareRaw = billet.bookedFareLabel|default('') %}
                                        {% set fareDisplay = fareRaw ? (fareRaw == 'Eco' ? 'Éco' : fareRaw) : '—' %}
                                        {% set stops = billet.bookedStopsCount %}
                                        {% if stops is null %}
                                            {% set stopsLabel = '—' %}
                                        {% elseif stops == 0 %}
                                            {% set stopsLabel = 'Direct' %}
                                        {% elseif stops == 1 %}
                                            {% set stopsLabel = '1 escale' %}
                                        {% else %}
                                            {% set stopsLabel = stops ~ ' escales' %}
                                        {% endif %}
                                        {% set bdur = billet.bookedDurationMinutes %}
                                        {% if bdur is not null and bdur > 0 %}
                                            {% set durLabel = (bdur // 60) ~ ' h ' ~ (bdur % 60) ~ ' min' %}
                                        {% else %}
                                            {% set durLabel = '—' %}
                                        {% endif %}
                                        {% set tripKindLabel = billet.bookedTripType == 'return' ? 'Aller-retour' : (billet.bookedTripType == 'one_way' ? 'Aller simple' : '—') %}

                                        <div class="reservation-flight-meta">
                                            <div class="reservation-meta-badges">
                                                <span class="reservation-badge">{{ tripKindLabel }}</span>
                                                <span class="reservation-badge">{{ stopsLabel }}</span>
                                                <span class="reservation-badge">Classe : {{ classDisplay }}</span>
                                                <span class="reservation-badge">Tarif : {{ fareDisplay }}</span>
                                            </div>
                                            <div class="reservation-meta-grid">
                                                <div>
                                                    <span class="reservation-meta-k">Départ</span>
                                                    {% if depDt %}
                                                        {{ depDt|date('d M Y, H:i') }}
                                                    {% else %}
                                                        —
                                                    {% endif %}
                                                </div>
                                                <div>
                                                    <span class="reservation-meta-k">Arrivée (segment)</span>
                                                    {% if arrDt %}
                                                        {{ arrDt|date('d M Y, H:i') }}
                                                    {% else %}
                                                        —
                                                    {% endif %}
                                                </div>
                                                <div>
                                                    <span class="reservation-meta-k">Retour (date choisie)</span>
                                                    {% if billet.bookedReturnDate %}
                                                        {{ billet.bookedReturnDate|date('d M Y') }}
                                                    {% elseif billet.bookedTripType == 'return' %}
                                                        —
                                                    {% else %}
                                                        N/A
                                                    {% endif %}
                                                </div>
                                                <div>
                                                    <span class="reservation-meta-k">Durée du vol (réservation)</span>
                                                    {{ durLabel }}
                                                </div>
                                            </div>
                                            {% if not hasSnapshot %}
                                                <p class="reservation-meta-foot">
                                                    Ancien billet : détail de réservation non enregistré. Les prochains paiements incluront l’historique complet.
                                                </p>
                                            {% endif %}
                                        </div>

                                        {% if billetStatusKey == 'retarde' %}
                                            <div class="reservation-disruption-alert">
                                                Perturbation détectée : ce vol est retardé.
                                            </div>
                                        {% elseif billetStatusKey == 'annule' %}
                                            <div class="reservation-disruption-alert reservation-disruption-alert--annule">
                                                Perturbation détectée : ce vol a été annulé.
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="reservation-empty">
                                    Aucun billet
                                </div>
                            {% endif %}
                        </div>

                        <div class="reservation-right" style="display:flex; flex-direction:column; justify-content:space-between; align-items:flex-end; min-height:140px;">
                            <div>
                                <div class="reservation-price">
                                    {% if totalPrice > 0 %}
                                        {{ totalPrice }} DT
                                    {% else %}
                                        --
                                    {% endif %}
                                </div>

                                {% if reservation.statut is defined and reservation.statut %}
                                    <div class="reservation-status {{ reservation.statut|lower|replace({' ': '_', 'é':'e', 'è':'e', 'ê':'e'}) }}">
                                        {{ reservation.statut }}
                                    </div>
                                {% endif %}
                            </div>

                            <div style="margin-top: 16px; display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
                                <a
                                    href="{{ path('app_user_reservation_edit', {'id': reservation.id}) }}"
                                    class="premium-flight-book-btn">
                                    Modifier
                                </a>

                                <form id="delete-form-{{ reservation.id }}"
                                      method="post"
                                      action="{{ path('app_user_reservation_delete', {'id': reservation.id}) }}"
                                      style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_reservation_' ~ reservation.id) }}">

                                    <button type="button"
                                            class="premium-flight-book-btn js-open-delete-modal"
                                            data-form-id="delete-form-{{ reservation.id }}">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="reservation-box">
                    <div class="reservation-left">
                        <div class="reservation-icon">✈</div>
                        <div class="reservation-meta">
                            <h3>Aucune réservation</h3>
                            <p>Vous n’avez pas encore de réservation enregistrée.</p>
                        </div>
                    </div>

                    <div class="reservation-center">
                        <div class="reservation-empty">
                            Aucun billet
                        </div>
                    </div>

                    <div class="reservation-right" style="display:flex; flex-direction:column; justify-content:flex-end; align-items:flex-end; min-height:140px;">
                        <div class="reservation-price">--</div>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
</div>

<div class="form-modal-overlay" id="formModal">
    <div class="form-modal-box">
        <div class="form-modal-header">
            <h2 class="form-modal-title" id="formModalTitle">Formulaire</h2>
            <button type="button" class="form-modal-close" id="closeFormModal">✕</button>
        </div>

        <div class="form-modal-body" id="formModalContent"></div>
    </div>
</div>

<div class="delete-modal-overlay" id="deleteModalOverlay" aria-hidden="true">
    <div class="delete-modal-box" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <div class="delete-modal-icon">⚠</div>

        <h2 class="delete-modal-title" id="deleteModalTitle">
            Confirmer la suppression
        </h2>

        <p class="delete-modal-text">
            Êtes-vous sûr de vouloir supprimer définitivement cet élément ?
        </p>

        <div class="delete-modal-actions">
            <button type="button" class="delete-modal-cancel" id="deleteModalCancel">
                Annuler
            </button>

            <button type="button" class="delete-modal-confirm" id="deleteModalConfirm">
                Supprimer
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

    <script>
        (function () {
            const formModal = document.getElementById('formModal');
            const formModalContent = document.getElementById('formModalContent');
            const formModalTitle = document.getElementById('formModalTitle');
            const closeFormModal = document.getElementById('closeFormModal');

            const newButton = document.querySelector('.js-open-new-modal');
            const calendarToggle = document.getElementById('toggleReservationCalendar');
            const calendarSection = document.getElementById('reservationCalendarSection');

            const deleteModal = document.getElementById('deleteModalOverlay');
            const deleteCancelBtn = document.getElementById('deleteModalCancel');
            const deleteConfirmBtn = document.getElementById('deleteModalConfirm');
            const deleteButtons = document.querySelectorAll('.js-open-delete-modal');

            let activeDeleteFormId = null;

            if (calendarToggle && calendarSection) {
                calendarToggle.addEventListener('click', function () {
                    const isHidden = calendarSection.hasAttribute('hidden');

                    if (isHidden) {
                        calendarSection.removeAttribute('hidden');
                        calendarToggle.setAttribute('aria-expanded', 'true');
                    } else {
                        calendarSection.setAttribute('hidden', 'hidden');
                        calendarToggle.setAttribute('aria-expanded', 'false');
                    }
                });
            }

            const calendarDataElement = document.getElementById('reservation-calendar-data');
            const calendarGrid = document.getElementById('reservationCalendarGrid');
            const calendarMonth = document.getElementById('reservationCalendarMonth');
            const calendarPrev = document.getElementById('reservationCalendarPrev');
            const calendarNext = document.getElementById('reservationCalendarNext');
            const calendarDetails = document.getElementById('reservationCalendarDetails');
            const calendarReservations = calendarDataElement ? JSON.parse(calendarDataElement.textContent || '[]') : [];
            const reservationsByDate = calendarReservations.reduce((groups, reservation) => {
                if (!reservation.date) {
                    return groups;
                }

                if (!groups[reservation.date]) {
                    groups[reservation.date] = [];
                }

                groups[reservation.date].push(reservation);
                return groups;
            }, {});

            let calendarCurrentDate = new Date();
            let selectedCalendarDate = null;

            function padDatePart(value) {
                return String(value).padStart(2, '0');
            }

            function toDateKey(date) {
                return [
                    date.getFullYear(),
                    padDatePart(date.getMonth() + 1),
                    padDatePart(date.getDate())
                ].join('-');
            }

            function createCalendarDate(year, month, day) {
                return new Date(year, month, day);
            }

            function formatDisplayDate(dateKey) {
                const parts = dateKey.split('-').map(Number);
                const date = createCalendarDate(parts[0], parts[1] - 1, parts[2]);

                return new Intl.DateTimeFormat('fr-FR', {
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric'
                }).format(date);
            }

            function renderCalendarDetails(dateKey) {
                if (!calendarDetails) {
                    return;
                }

                const items = reservationsByDate[dateKey] || [];
                calendarDetails.innerHTML = '';

                if (items.length === 0) {
                    const emptyText = document.createElement('p');
                    emptyText.className = 'reservation-calendar-empty-text';
                    emptyText.textContent = calendarReservations.length > 0
                        ? 'Sélectionnez une date dorée pour voir les réservations correspondantes.'
                        : 'Aucune réservation datée à afficher pour le moment.';
                    calendarDetails.appendChild(emptyText);
                    return;
                }

                const title = document.createElement('p');
                title.className = 'reservation-calendar-details-title';
                title.textContent = items.length > 1
                    ? items.length + ' réservations le ' + formatDisplayDate(dateKey)
                    : '1 réservation le ' + formatDisplayDate(dateKey);

                const list = document.createElement('div');
                list.className = 'reservation-calendar-details-list';

                items.forEach((reservation) => {
                    const pill = document.createElement('span');
                    pill.className = 'reservation-calendar-pill';

                    const label = document.createElement('strong');
                    label.textContent = '#' + reservation.id;

                    const meta = document.createElement('span');
                    const destination = reservation.destination || 'Destination non définie';
                    const status = reservation.status ? ' - ' + reservation.status : '';
                    const billets = reservation.billets > 0 ? ' - ' + reservation.billets + ' billet(s)' : '';
                    meta.textContent = destination + status + billets;

                    pill.appendChild(label);
                    pill.appendChild(meta);
                    list.appendChild(pill);
                });

                calendarDetails.appendChild(title);
                calendarDetails.appendChild(list);
            }

            function renderReservationCalendar() {
                if (!calendarGrid || !calendarMonth) {
                    return;
                }

                const year = calendarCurrentDate.getFullYear();
                const month = calendarCurrentDate.getMonth();
                const todayKey = toDateKey(new Date());
                const firstDay = createCalendarDate(year, month, 1);
                const mondayOffset = (firstDay.getDay() + 6) % 7;
                const startDate = createCalendarDate(year, month, 1 - mondayOffset);
                const monthLabel = new Intl.DateTimeFormat('fr-FR', {
                    month: 'long',
                    year: 'numeric'
                }).format(firstDay);

                calendarMonth.textContent = monthLabel;
                calendarGrid.innerHTML = '';

                for (let index = 0; index < 42; index++) {
                    const dayDate = createCalendarDate(
                        startDate.getFullYear(),
                        startDate.getMonth(),
                        startDate.getDate() + index
                    );
                    const dateKey = toDateKey(dayDate);
                    const dayReservations = reservationsByDate[dateKey] || [];
                    const dayButton = document.createElement('button');
                    dayButton.type = 'button';
                    dayButton.className = 'reservation-calendar-day';
                    dayButton.setAttribute('aria-label', dayDate.toLocaleDateString('fr-FR'));

                    if (dayDate.getMonth() !== month) {
                        dayButton.classList.add('is-muted');
                    }

                    if (dateKey === todayKey) {
                        dayButton.classList.add('is-today');
                    }

                    if (dateKey === selectedCalendarDate) {
                        dayButton.classList.add('is-selected');
                    }

                    const number = document.createElement('span');
                    number.className = 'reservation-calendar-number';
                    number.textContent = dayDate.getDate();
                    dayButton.appendChild(number);

                    if (dayReservations.length > 0) {
                        const count = document.createElement('span');
                        count.className = 'reservation-calendar-count';
                        count.textContent = dayReservations.length;
                        dayButton.classList.add('has-reservation');
                        dayButton.appendChild(count);

                        dayButton.addEventListener('click', function () {
                            selectedCalendarDate = dateKey;
                            renderReservationCalendar();
                            renderCalendarDetails(dateKey);
                        });
                    }

                    calendarGrid.appendChild(dayButton);
                }

                if (!selectedCalendarDate) {
                    renderCalendarDetails('');
                }
            }

            if (calendarPrev && calendarNext) {
                calendarPrev.addEventListener('click', function () {
                    calendarCurrentDate = createCalendarDate(
                        calendarCurrentDate.getFullYear(),
                        calendarCurrentDate.getMonth() - 1,
                        1
                    );
                    selectedCalendarDate = null;
                    renderReservationCalendar();
                });

                calendarNext.addEventListener('click', function () {
                    calendarCurrentDate = createCalendarDate(
                        calendarCurrentDate.getFullYear(),
                        calendarCurrentDate.getMonth() + 1,
                        1
                    );
                    selectedCalendarDate = null;
                    renderReservationCalendar();
                });
            }

            renderReservationCalendar();

            function initTraveliaDatepickers(scope = document) {
                const inputs = scope.querySelectorAll('.js-travelia-datepicker');

                inputs.forEach((input) => {
                    if (input.dataset.flatpickrInit === '1') {
                        return;
                    }

                    input.dataset.flatpickrInit = '1';

                    if (typeof flatpickr === 'undefined') {
                        console.error('Flatpickr non chargé');
                        return;
                    }

                    flatpickr(input, {
                        dateFormat: 'Y-m-d',
                        altInput: true,
                        altFormat: 'd/m/Y',
                        allowInput: false,
                        clickOpens: true,
                        disableMobile: true,
                        minDate: 'today',
                        monthSelectorType: 'static',
                        onReady: function(selectedDates, dateStr, instance) {
                            instance.input.setAttribute('readonly', 'readonly');

                            if (instance.altInput) {
                                instance.altInput.setAttribute('readonly', 'readonly');
                                instance.altInput.setAttribute('placeholder', 'Choisir une date');
                                instance.altInput.classList.add('form-control');
                            }
                        }
                    });
                });
            }

            function initTraveliaStatusSelect(scope = document) {
                const selects = scope.querySelectorAll('.js-travelia-status');

                selects.forEach((select) => {
                    if (select.dataset.choicesInit === '1') {
                        return;
                    }

                    select.dataset.choicesInit = '1';

                    if (typeof Choices === 'undefined') {
                        console.error('Choices non chargé');
                        return;
                    }

                    new Choices(select, {
                        searchEnabled: false,
                        itemSelectText: '',
                        shouldSort: false,
                        allowHTML: false,
                        placeholder: true,
                        removeItemButton: false
                    });
                });
            }

            function openFormModal(title, url, formId) {
                formModalTitle.textContent = title;

                fetch(url)
                    .then(response => response.text())
                    .then(html => {
                        formModalContent.innerHTML = html;
                        formModal.classList.add('active');
                        document.body.style.overflow = 'hidden';

                        initTraveliaDatepickers(formModalContent);
                        initTraveliaStatusSelect(formModalContent);

                        const form = document.getElementById(formId);

                        if (form) {
                            form.addEventListener('submit', function (e) {
                                e.preventDefault();

                                fetch(form.action, {
                                    method: 'POST',
                                    body: new FormData(form)
                                })
                                .then(response => response.text())
                                .then(result => {
                                    if (result === 'success') {
                                        window.location.reload();
                                    } else {
                                        formModalContent.innerHTML = result;
                                        initTraveliaDatepickers(formModalContent);
                                        initTraveliaStatusSelect(formModalContent);
                                    }
                                });
                            });
                        }
                    });
            }

            function closeForm() {
                formModal.classList.remove('active');
                formModalContent.innerHTML = '';
                document.body.style.overflow = '';
            }

            if (newButton) {
                newButton.addEventListener('click', function () {
                    openFormModal(
                        'Nouvelle réservation',
                        '{{ path('app_user_reservation_new') }}',
                        'newReservationForm'
                    );
                });
            }

            closeFormModal.addEventListener('click', closeForm);

            formModal.addEventListener('click', function (e) {
                if (e.target === formModal) {
                    closeForm();
                }
            });

            function openDeleteModal(formId) {
                activeDeleteFormId = formId;
                deleteModal.classList.add('is-open');
                deleteModal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }

            function closeDeleteModal() {
                activeDeleteFormId = null;
                deleteModal.classList.remove('is-open');
                deleteModal.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }

            deleteButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const formId = this.getAttribute('data-form-id');
                    openDeleteModal(formId);
                });
            });

            deleteCancelBtn.addEventListener('click', closeDeleteModal);

            deleteModal.addEventListener('click', function (event) {
                if (event.target === deleteModal) {
                    closeDeleteModal();
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    if (formModal.classList.contains('active')) {
                        closeForm();
                    }

                    if (deleteModal.classList.contains('is-open')) {
                        closeDeleteModal();
                    }
                }
            });

            deleteConfirmBtn.addEventListener('click', function () {
                if (!activeDeleteFormId) {
                    return;
                }

                const form = document.getElementById(activeDeleteFormId);

                if (form) {
                    form.submit();
                }
            });
        })();
    </script>
{% endblock %}
