{% extends 'base.html.twig' %}

{% block title %}Nouvelle réservation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/horizon.css') }}?v=24">
    <link rel="stylesheet" href="{{ asset('css/flights-results.css') }}?v=24">
{% endblock %}

{% block body %}
<canvas id="live-canvas"></canvas>

{% include 'front/_site_nav.html.twig' with { active_nav: 'reservations' } %}

<div class="reservations-page">
    <section class="reservations-wrapper">
        <div class="reservations-header">
            <div class="reservations-tag">✦ Espace utilisateur</div>
            <h1 class="reservations-title">Nouvelle <span>réservation</span></h1>
            <p class="reservations-subtitle">Ajoutez une réservation depuis l’espace utilisateur.</p>
        </div>

        <div class="reservation-box" style="display:block;">
            {{ form_start(form) }}
                {{ form_widget(form) }}

                <div style="margin-top: 20px; display:flex; gap:12px; flex-wrap:wrap;">
                    <button type="submit" class="premium-flight-book-btn">Créer</button>
                    <a href="{{ path('app_user_reservations') }}" class="premium-flight-back-btn">Retour</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
</div>
{% endblock %}
