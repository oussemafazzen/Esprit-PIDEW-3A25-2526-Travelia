{% extends 'base.html.twig' %}

{% block title %}Paiement du billet - Travelia{% endblock %}

{% block body %}
<style>
    .payment-page {
        min-height: 100vh;
        color: #fff;
        background: transparent;
        padding: 112px 20px 56px;
    }

    .payment-card {
        max-width: 720px;
        margin: 0 auto;
        border-radius: 28px;
        padding: 32px 28px;
        background: rgba(10, 22, 52, 0.78);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 18px 42px rgba(0,0,0,0.24);
    }

    .payment-title {
        margin: 0 0 12px;
        font-size: 40px;
        font-family: 'Cormorant Garamond', serif;
    }

    .payment-subtitle {
        margin: 0 0 24px;
        color: rgba(255,255,255,0.78);
    }

    .payment-summary {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 24px;
    }

    .payment-summary-item {
        padding: 16px 18px;
        border-radius: 18px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .payment-summary-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255,255,255,0.62);
        margin-bottom: 6px;
    }

    .payment-summary-value {
        font-size: 18px;
        font-weight: 700;
    }

    .payment-pricing-recap {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 22px;
    }

    .promo-field-row {
        margin-bottom: 8px;
    }

    .promo-live-message {
        margin-top: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #f0c86a;
        min-height: 1.25em;
    }

    .promo-live-message.is-muted {
        color: rgba(255, 255, 255, 0.55);
        font-weight: 500;
    }

    .payment-form {
        display: grid;
        gap: 16px;
    }

    .payment-form label {
        display: block;
        margin-bottom: 8px;
        font-size: 14px;
        font-weight: 700;
    }

    .payment-field input,
    .payment-field select {
        width: 100%;
        min-height: 54px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(18, 30, 62, 0.88);
        color: #ffffff;
        padding: 0 16px;
        font-size: 1rem;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .payment-field input:focus {
        border-color: #d9b84f;
        box-shadow: 0 0 0 3px rgba(217, 184, 79, 0.14);
    }

    .payment-select {
        width: 100%;
        min-height: 54px;
        border-radius: 18px;
        border: 1px solid rgba(217, 184, 79, 0.18);
        background:
            linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
            rgba(18, 30, 62, 0.88);
        color: #ffffff;
        padding: 0 52px 0 16px;
        font-size: 1rem;
        font-weight: 600;
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.04),
            0 10px 24px rgba(0,0,0,0.16);
        outline: none;
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        background-image:
            linear-gradient(45deg, transparent 50%, #d9b84f 50%),
            linear-gradient(135deg, #d9b84f 50%, transparent 50%),
            linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
        background-position:
            calc(100% - 22px) calc(50% - 3px),
            calc(100% - 16px) calc(50% - 3px),
            0 0;
        background-size:
            6px 6px,
            6px 6px,
            100% 100%;
        background-repeat: no-repeat;
    }

    .payment-select:hover {
        border-color: rgba(217, 184, 79, 0.38);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.05),
            0 14px 30px rgba(0,0,0,0.22);
    }

    .payment-select:focus {
        border-color: #d9b84f;
        box-shadow:
            0 0 0 3px rgba(217, 184, 79, 0.14),
            0 14px 30px rgba(0,0,0,0.22);
    }

    .payment-select option {
        background: rgba(18, 30, 62, 0.98);
        color: #ffffff;
    }

    .payment-actions {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .payment-method-fields {
        display: grid;
        gap: 14px;
    }

    .payment-method-section {
        display: none;
        gap: 14px;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .payment-method-section.is-active {
        display: grid;
    }

    .payment-note {
        margin: 0;
        color: rgba(255,255,255,0.84);
        line-height: 1.6;
    }

    .payment-errors {
        margin-bottom: 18px;
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(140, 16, 52, 0.28);
        border: 1px solid rgba(255,255,255,0.08);
        color: #fff;
    }

    .payment-errors ul {
        margin: 0;
        padding-left: 18px;
    }

    .payment-btn,
    .payment-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 180px;
        min-height: 54px;
        padding: 0 20px;
        border-radius: 16px;
        border: none;
        text-decoration: none;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .payment-btn {
        cursor: pointer;
        background: linear-gradient(135deg, #d4af37, #e4c96e);
        color: #111;
    }

    .payment-link {
        background: rgba(255,255,255,0.08);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.10);
    }

    @media (max-width: 700px) {
        .payment-summary {
            grid-template-columns: 1fr;
        }

        .payment-btn,
        .payment-link {
            width: 100%;
        }
    }
</style>

{% include 'front/_site_nav.html.twig' with { active_nav: 'flights' } %}

<div class="payment-page">
    <div class="payment-card">
        <h1 class="payment-title">Paiement du billet</h1>
        <p class="payment-subtitle">Vérifiez les détails du vol puis confirmez le paiement.</p>

        {% if payment_errors is defined and payment_errors is not empty %}
            <div class="payment-errors">
                <ul>
                    {% for error in payment_errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <div class="payment-summary">
            <div class="payment-summary-item">
                <div class="payment-summary-label">Trajet</div>
                <div class="payment-summary-value">{{ payment.origin_code }} → {{ payment.destination_code }}</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Référence</div>
                <div class="payment-summary-value">{{ payment.reference }}</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Destination</div>
                <div class="payment-summary-value">{{ payment.destination }}</div>
            </div>
            {% if payment.travel_class_label is defined %}
                <div class="payment-summary-item">
                    <div class="payment-summary-label">Classe</div>
                    <div class="payment-summary-value">{{ payment.travel_class_label }}</div>
                </div>
            {% endif %}
            <div class="payment-summary-item">
                <div class="payment-summary-label">Départ</div>
                <div class="payment-summary-value">{{ payment.selected_date_depart ?: 'Non définie' }}</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Tarif</div>
                <div class="payment-summary-value">{{ (payment.offer_label ?: 'Standard') == 'Eco' ? 'Éco' : (payment.offer_label ?: 'Standard') }}</div>
            </div>
        </div>

        <div class="payment-pricing-recap" id="payment-pricing-recap">
            <div class="payment-summary-item">
                <div class="payment-summary-label">Prix de référence</div>
                <div class="payment-summary-value" id="payment-recap-base">{{ payment.selected_price }} TND</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Remise (code promo)</div>
                <div class="payment-summary-value" id="payment-recap-discount">—</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Total à payer</div>
                <div class="payment-summary-value" id="payment-recap-final">{{ payment.selected_price }} TND</div>
            </div>
            <div class="payment-summary-item">
                <div class="payment-summary-label">Points fidélité (simulation)</div>
                <div class="payment-summary-value" id="payment-recap-points">0 pts</div>
                <div style="margin-top:6px;font-size:12px;color:rgba(255,255,255,0.55);font-weight:500;">1 pt / 10 TND payés après remise</div>
            </div>
        </div>

        <script type="application/json" id="flight-promo-rules">{{ promo_rules_json|default('[]')|raw }}</script>

        <form method="POST" action="{{ path('app_flights_payment_submit') }}" class="payment-form" id="flight-payment-form"
              data-base-price="{{ payment.selected_price }}"
              data-travel-class="{{ payment.travel_class|default('economy') }}">
            <input type="hidden" name="billet_id" value="{{ payment.billet_id }}">
            <input type="hidden" name="reservation_id" value="{{ payment.reservation_id }}">
            <input type="hidden" name="selected_price" value="{{ payment.selected_price }}">
            <input type="hidden" name="selected_date_depart" value="{{ payment.selected_date_depart }}">
            <input type="hidden" name="selected_date_arrivee" value="{{ payment.selected_date_arrivee }}">
            <input type="hidden" name="destination" value="{{ payment.destination }}">
            <input type="hidden" name="reference" value="{{ payment.reference|default('') }}">
            <input type="hidden" name="origin_code" value="{{ payment.origin_code|default('') }}">
            <input type="hidden" name="destination_code" value="{{ payment.destination_code|default('') }}">
            <input type="hidden" name="offer_label" value="{{ payment.offer_label|default('') }}">
            <input type="hidden" name="travel_class" value="{{ payment.travel_class|default('economy') }}">
            <input type="hidden" name="trip_type" value="{{ payment.trip_type|default('return') }}">
            <input type="hidden" name="booked_stops_count" value="{{ payment.booked_stops_count|default('') }}">
            <input type="hidden" name="booked_duration_minutes" value="{{ payment.booked_duration_minutes|default('') }}">
            <input type="hidden" name="booked_return_date" value="{{ payment.booked_return_date|default('') }}">

            <div class="payment-field promo-field-row">
                <label for="promo_code">Code promotionnel</label>
                <input type="text" id="promo_code" name="promo_code" value="{{ payment.promo_code|default('') }}" placeholder="Ex. SPRING10" autocomplete="off">
                <div class="promo-live-message is-muted" id="promo-live-message" aria-live="polite"></div>
            </div>

            <div class="payment-field">
                <label for="payment_method">Mode de paiement</label>
                <select id="payment_method" name="payment_method" class="payment-select">
                    <option value="carte" {{ (payment.payment_method|default('carte')) == 'carte' ? 'selected' : '' }}>Carte bancaire</option>
                    <option value="virement" {{ (payment.payment_method|default('carte')) == 'virement' ? 'selected' : '' }}>Virement bancaire</option>
                    <option value="especes" {{ (payment.payment_method|default('carte')) == 'especes' ? 'selected' : '' }}>Espèces</option>
                </select>
            </div>

            <div class="payment-method-fields">
                <div class="payment-method-section" data-method-section="carte">
                    <div class="payment-field">
                        <label for="cardholder_name">Nom du titulaire</label>
                        <input type="text" id="cardholder_name" name="cardholder_name" value="{{ payment.cardholder_name|default('') }}">
                    </div>
                    <div class="payment-field">
                        <label for="card_number">Numéro de carte</label>
                        <input type="text" id="card_number" name="card_number" inputmode="numeric" value="{{ payment.card_number|default('') }}">
                    </div>
                    <div class="payment-field">
                        <label for="expiry_date">Date d'expiration</label>
                        <input type="text" id="expiry_date" name="expiry_date" placeholder="MM/AA" value="{{ payment.expiry_date|default('') }}">
                    </div>
                    <div class="payment-field">
                        <label for="cvv">CVV</label>
                        <input type="password" id="cvv" name="cvv" inputmode="numeric" value="{{ payment.cvv|default('') }}">
                    </div>
                </div>

                <div class="payment-method-section" data-method-section="virement">
                    <div class="payment-field">
                        <label for="bank_name">Nom de la banque</label>
                        <input type="text" id="bank_name" name="bank_name" value="{{ payment.bank_name|default('') }}">
                    </div>
                    <div class="payment-field">
                        <label for="iban_or_rib">IBAN / RIB</label>
                        <input type="text" id="iban_or_rib" name="iban_or_rib" value="{{ payment.iban_or_rib|default('') }}">
                    </div>
                    <div class="payment-field">
                        <label for="account_holder_name">Nom du titulaire du compte</label>
                        <input type="text" id="account_holder_name" name="account_holder_name" value="{{ payment.account_holder_name|default('') }}">
                    </div>
                </div>

                <div class="payment-method-section" data-method-section="especes">
                    <p class="payment-note">Paiement en espèces à l'agence. Votre réservation sera confirmée après règlement sur place.</p>
                </div>
            </div>

            <div class="payment-actions">
                <button type="submit" class="payment-btn">Payer maintenant</button>
                <a href="{{ path('app_flights_search', { reservation_id: payment.reservation_id }) }}" class="payment-link">Retour aux vols</a>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        const paymentMethodSelect = document.getElementById('payment_method');
        const sections = document.querySelectorAll('[data-method-section]');

        function updatePaymentMethodFields() {
            const method = paymentMethodSelect.value || 'carte';

            sections.forEach((section) => {
                const isActive = section.getAttribute('data-method-section') === method;
                section.classList.toggle('is-active', isActive);
            });
        }

        if (paymentMethodSelect) {
            paymentMethodSelect.addEventListener('change', updatePaymentMethodFields);
            updatePaymentMethodFields();
        }

        const form = document.getElementById('flight-payment-form');
        const rulesEl = document.getElementById('flight-promo-rules');
        const promoInput = document.getElementById('promo_code');
        const liveMsg = document.getElementById('promo-live-message');
        const elBase = document.getElementById('payment-recap-base');
        const elDiscount = document.getElementById('payment-recap-discount');
        const elFinal = document.getElementById('payment-recap-final');
        const elPoints = document.getElementById('payment-recap-points');

        function round2(value) {
            return Math.round(value * 100) / 100;
        }

        function formatTnd(value) {
            return round2(Math.max(0, value)).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' TND';
        }

        function applyPromoPreview(code, base, travelClass, rules) {
            const normalized = (code || '').trim().toUpperCase();
            if (!normalized) {
                return { status: 'none', discount: 0, final: round2(base), message: null };
            }

            const rule = rules.find((item) => item.code === normalized);
            if (!rule) {
                return {
                    status: 'invalid',
                    discount: 0,
                    final: round2(base),
                    message: 'Code promotionnel invalide.',
                };
            }

            if (rule.requiresTravelClass && travelClass !== rule.requiresTravelClass) {
                return {
                    status: 'condition_failed',
                    discount: 0,
                    final: round2(base),
                    message: 'Ce code promotionnel s\'applique uniquement aux réservations en classe Business.',
                };
            }

            let discount = 0;
            if (rule.type === 'percent') {
                discount = round2(base * (Number(rule.percent) / 100));
            } else if (rule.type === 'fixed_tnd') {
                discount = round2(Math.min(Number(rule.amountTnd), base));
            }

            const final = round2(Math.max(0, base - discount));

            return { status: 'applied', discount, final, message: null };
        }

        function updatePricingRecap() {
            if (!form || !rulesEl || !promoInput || !elBase || !elDiscount || !elFinal || !elPoints) {
                return;
            }

            let rules = [];
            try {
                rules = JSON.parse(rulesEl.textContent || '[]');
            } catch (e) {
                rules = [];
            }

            const base = parseFloat(String(form.dataset.basePrice || '').replace(',', '.')) || 0;
            const travelClass = String(form.dataset.travelClass || 'economy');
            const preview = applyPromoPreview(promoInput.value, base, travelClass, rules);

            elBase.textContent = formatTnd(base);

            if (preview.status === 'none') {
                elDiscount.textContent = '—';
                elFinal.textContent = formatTnd(base);
                if (liveMsg) {
                    liveMsg.textContent = '';
                    liveMsg.classList.add('is-muted');
                }
            } else if (preview.status === 'invalid' || preview.status === 'condition_failed') {
                elDiscount.textContent = '—';
                elFinal.textContent = formatTnd(base);
                if (liveMsg) {
                    liveMsg.textContent = preview.message || '';
                    liveMsg.classList.remove('is-muted');
                }
            } else {
                elDiscount.textContent = preview.discount > 0 ? ('− ' + formatTnd(preview.discount)) : '—';
                elFinal.textContent = formatTnd(preview.final);
                if (liveMsg) {
                    liveMsg.textContent = '';
                    liveMsg.classList.add('is-muted');
                }
            }

            const points = Math.floor((preview.final || 0) / 10);
            elPoints.textContent = points + ' pts';
        }

        if (promoInput) {
            promoInput.addEventListener('input', updatePricingRecap);
        }

        updatePricingRecap();
    })();
</script>
{% endblock %}
