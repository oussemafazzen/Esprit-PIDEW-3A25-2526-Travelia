{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof flatpickr === 'undefined') {
                return;
            }

            document.querySelectorAll('.js-travelia-datepicker').forEach((input) => {
                if (input.dataset.flatpickrInit === '1') {
                    return;
                }

                input.dataset.flatpickrInit = '1';

                flatpickr(input, {
                    dateFormat: 'Y-m-d',
                    altInput: true,
                    altFormat: 'd/m/Y',
                    allowInput: false,
                    clickOpens: true,
                    disableMobile: true,
                    minDate: 'today',
                    monthSelectorType: 'static',
                    onReady: function (selectedDates, dateStr, instance) {
                        instance.input.setAttribute('readonly', 'readonly');

                        if (instance.altInput) {
                            instance.altInput.setAttribute('readonly', 'readonly');
                            instance.altInput.setAttribute('placeholder', 'Choisir une date');
                            instance.altInput.classList.add('flight-search-input');
                        }
                    }
                });
            });
        });
    </script>
