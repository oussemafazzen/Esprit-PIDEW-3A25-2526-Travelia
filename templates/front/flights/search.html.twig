                    <label>Date départ</label>
                    <input type="date" name="date_depart" required>
                </div>

                <div class="flight-search-divider"></div>

                <div class="flight-search-field">
                    <label>Date arrivée</label>
                    <input type="date" name="date_arrivee">
                </div>

                <div class="flight-search-divider"></div>

                <div class="flight-search-field">
                    <label>Transport</label>
                    <select name="type_transport" class="flight-search-select">
                        <option value="">Tous</option>
                        <option value="avion">Avion</option>
                        <option value="train">Train</option>
                        <option value="bus">Bus</option>
                        <option value="bateau">Bateau</option>
                    </select>
                </div>

                <div class="flight-search-divider"></div>

                <div class="flight-search-field flight-search-field--small">
                    <label>Who</label>
                    <input type="number" name="passagers" min="1" value="1">
                </div>

                <button type="submit" class="flights-search-btn">
                    Explore
