                        <option value="Tanzanie">
                        <option value="Tchad">
                        <option value="Thaïlande">
                        <option value="Togo">
                        <option value="Tunisie">
                        <option value="Turquie">
                        <option value="Turkménistan">
                        <option value="Ukraine">
                        <option value="Uruguay">
                        <option value="Venezuela">
                        <option value="Vietnam">
                        <option value="Yémen">
                        <option value="Zambie">
                        <option value="Zimbabwe">
                    </datalist>
                </div>

                <div class="booking-field-card booking-date-card">
                    <label class="booking-field-label"><span class="booking-field-icon">✦</span> Dates</label>
                    <div class="date-range-inline">
                        <div class="date-segment">
                            <span class="date-mini-label">Departing</span>
                            {{ form_widget(form.dateDepart, {
                                attr: {
                                    class: 'flight-search-input js-travelia-datepicker',
                                    autocomplete: 'off'
                                }
                            }) }}
                            {{ form_errors(form.dateDepart) }}
                        </div>
                        <div class="date-segment" id="return-date-segment">
                            <span class="date-mini-label">Returning</span>
                            <input
                                type="text"
                                id="date-arrivee-input"
                                name="date_arrivee"
                                value="{{ returnDate }}"
                                class="flight-search-input js-travelia-datepicker"
                                autocomplete="off"
                                placeholder="Choose date"
                            >
                        </div>
                    </div>
                </div>

                <button type="submit" class="booking-search-card">
                    Search flights
                </button>
                </div>

                <div class="booking-secondary-row">
                    <div class="booking-field-card">
                        <label class="booking-field-label" for="{{ form.passagers.vars.id }}"><span class="booking-field-icon">✦</span> Passengers</label>
                        {{ form_widget(form.passagers, {
                            attr: {
                                class: 'flight-search-input',
                                placeholder: '1',
                                min: '1'
                            }
                        }) }}
                        {{ form_errors(form.passagers) }}
                    </div>

                    <div class="booking-field-card booking-field-card--class">
                        <label class="booking-field-label" for="travel-class-input"><span class="booking-field-icon">✦</span> Class</label>
                        <select id="travel-class-input" name="travel_class" class="booking-select native-select-hidden" tabindex="-1" aria-hidden="true">
                            <option value="economy" {{ selectedTravelClass == 'economy' ? 'selected' : '' }}>Economy</option>
                            <option value="business" {{ selectedTravelClass == 'business' ? 'selected' : '' }}>Business</option>
                            <option value="first" {{ selectedTravelClass == 'first' ? 'selected' : '' }}>First Class</option>
                        </select>
                        <div class="premium-select" data-premium-select>
                            <button type="button" class="premium-select-trigger" id="travel-class-trigger" aria-haspopup="listbox" aria-expanded="false">
                                Business
                            </button>
                            <div class="premium-dropdown-panel" id="travel-class-dropdown" role="listbox" aria-labelledby="travel-class-trigger"></div>
                        </div>
                    </div>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof flatpickr !== 'undefined') {
                document.querySelectorAll('.js-travelia-datepicker').forEach((input) => {
                    if (input.dataset.flatpickrInit === '1') {
                        return;
                    }

                    input.dataset.flatpickrInit = '1';

                    flatpickr(input, {
                        dateFormat: 'Y-m-d',
                        altInput: true,
                        altFormat: 'd/m/Y',
                        allowInput: false,
                        clickOpens: true,
                        disableMobile: true,
                        minDate: 'today',
                        monthSelectorType: 'static',
                        onReady: function (selectedDates, dateStr, instance) {
                            instance.input.setAttribute('readonly', 'readonly');

                            if (instance.altInput) {
                                instance.altInput.setAttribute('readonly', 'readonly');
                                instance.altInput.setAttribute('placeholder', 'Choisir une date');
                                instance.altInput.classList.add('flight-search-input');
                            }
                        }
                    });
                });
            }

            const tripInput = document.getElementById('trip-type-input');
            const returnCard = document.getElementById('return-date-segment');
            const returnInput = document.getElementById('date-arrivee-input');
            const tripTabs = document.querySelectorAll('[data-trip-type]');
            const destinationInput = document.getElementById('destination-input');
            const countriesList = document.getElementById('countries-list');
            const destinationDropdown = document.getElementById('destination-dropdown');
            const classSelect = document.getElementById('travel-class-input');
            const classTrigger = document.getElementById('travel-class-trigger');
            const classDropdown = document.getElementById('travel-class-dropdown');
            const classShell = document.querySelector('[data-premium-select]');

            const normalizeText = (value) => String(value || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');

            const closeDropdown = (panel) => {
                if (panel) {
                    panel.classList.remove('is-open');
                }
            };

            const applyTripType = (tripType) => {
                if (tripInput) {
                    tripInput.value = tripType;
                }

                tripTabs.forEach((tab) => {
                    const isActive = tab.dataset.tripType === tripType;
                    tab.classList.toggle('is-active', isActive);
                    tab.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                });

                const showReturn = tripType === 'return';
                if (returnCard) {
                    returnCard.classList.toggle('is-hidden', !showReturn);
                }

                if (returnInput) {
                    returnInput.disabled = !showReturn;
                }

            };

            tripTabs.forEach((tab) => {
                tab.addEventListener('click', () => applyTripType(tab.dataset.tripType || 'return'));
            });

            applyTripType(tripInput ? tripInput.value : 'return');

            if (destinationInput && countriesList && destinationDropdown) {
                const countries = Array.from(countriesList.querySelectorAll('option'))
                    .map((option) => option.value)
                    .filter(Boolean);

                const renderDestinationOptions = () => {
                    const query = normalizeText(destinationInput.value);
                    const matches = countries
                        .filter((country) => normalizeText(country).includes(query))
                        .slice(0, 18);

                    destinationDropdown.innerHTML = '';

                    if (matches.length === 0) {
                        const empty = document.createElement('div');
                        empty.className = 'premium-dropdown-empty';
                        empty.textContent = 'No destination found';
                        destinationDropdown.appendChild(empty);
                    } else {
                        matches.forEach((country) => {
                            const option = document.createElement('button');
                            option.type = 'button';
                            option.className = 'premium-dropdown-option';
                            option.setAttribute('role', 'option');
                            option.textContent = country;
                            option.addEventListener('mousedown', (event) => {
                                event.preventDefault();
                                destinationInput.value = country;
                                destinationInput.dispatchEvent(new Event('input', { bubbles: true }));
                                closeDropdown(destinationDropdown);
                            });
                            destinationDropdown.appendChild(option);
                        });
                    }

                    destinationDropdown.classList.add('is-open');
                };

                destinationInput.addEventListener('focus', renderDestinationOptions);
                destinationInput.addEventListener('input', renderDestinationOptions);
                destinationInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Escape') {
                        closeDropdown(destinationDropdown);
                    }
                });
            }

            if (classSelect && classTrigger && classDropdown && classShell) {
                const syncClassTrigger = () => {
                    const selectedOption = classSelect.options[classSelect.selectedIndex];
                    classTrigger.textContent = selectedOption ? selectedOption.textContent : 'Business';
                };

                Array.from(classSelect.options).forEach((selectOption) => {
                    const option = document.createElement('button');
                    option.type = 'button';
                    option.className = 'premium-dropdown-option';
                    option.setAttribute('role', 'option');
                    option.dataset.value = selectOption.value;
                    option.textContent = selectOption.textContent;

                    if (selectOption.selected) {
                        option.classList.add('is-highlighted');
                    }

                    option.addEventListener('click', () => {
                        classSelect.value = selectOption.value;
                        classSelect.dispatchEvent(new Event('change', { bubbles: true }));
                        classDropdown.querySelectorAll('.premium-dropdown-option').forEach((item) => {
                            item.classList.toggle('is-highlighted', item.dataset.value === selectOption.value);
                        });
                        syncClassTrigger();
                        closeDropdown(classDropdown);
                        classShell.classList.remove('is-open');
                        classTrigger.setAttribute('aria-expanded', 'false');
                    });

                    classDropdown.appendChild(option);
                });

                syncClassTrigger();

                classTrigger.addEventListener('click', () => {
                    const isOpen = classDropdown.classList.toggle('is-open');
                    classShell.classList.toggle('is-open', isOpen);
                    classTrigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
            }

            document.addEventListener('click', (event) => {
                if (destinationDropdown && destinationInput && !destinationDropdown.contains(event.target) && event.target !== destinationInput) {
                    closeDropdown(destinationDropdown);
                }

                if (classDropdown && classShell && !classShell.contains(event.target)) {
                    closeDropdown(classDropdown);
                    classShell.classList.remove('is-open');
                    if (classTrigger) {
                        classTrigger.setAttribute('aria-expanded', 'false');
                    }
                }
            });
        });
    </script>
{% endblock %}
