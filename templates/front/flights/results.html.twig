{% extends 'base.html.twig' %}

{% block title %}Flights Results{% endblock %}

{% block body %}

<style>
    .flights-results-page {
        min-height: 100vh;
        color: #fff;
        background-image:
            linear-gradient(rgba(5, 15, 35, 0.55), rgba(5, 15, 35, 0.72)),
            url('{{ asset('images/avion.jpg') }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .results-navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: rgba(10, 20, 40, 0.88);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .results-navbar-inner {
        max-width: 1380px;
        margin: 0 auto;
        height: 82px;
        padding: 0 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }

    .results-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: #fff;
        font-weight: 700;
        font-size: 18px;
    }

    .results-brand-logo {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #d4af37;
        color: #111;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cormorant Garamond', serif;
        font-weight: 700;
        font-size: 28px;
        line-height: 1;
        box-shadow: 0 6px 16px rgba(0,0,0,0.12);
    }

    .results-nav-links {
        display: flex;
        align-items: center;
        gap: 34px;
    }

    .results-nav-links a {
        text-decoration: none;
        color: rgba(255,255,255,0.76);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        position: relative;
        transition: 0.2s ease;
    }

    .results-nav-links a:hover,
    .results-nav-links a.active {
        color: #fff;
    }

    .results-nav-links a.active::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -10px;
        height: 2px;
        background: #d4af37;
    }

    .results-signin {
        text-decoration: none;
        background: linear-gradient(135deg, #d4af37, #e4c96e);
        color: #111;
        padding: 12px 22px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 8px 18px rgba(0,0,0,0.14);
        white-space: nowrap;
    }

    .results-hero {
        position: relative;
        min-height: 56vh;
        display: flex;
        align-items: flex-end;
        padding: 0 0 42px;
    }

    .results-hero-inner {
        width: 100%;
        max-width: 1380px;
        margin: 0 auto;
        padding: 0 32px;
    }

    .results-label {
        color: #d4af37;
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .results-title {
        margin: 0;
        font-family: 'Cormorant Garamond', serif;
        font-size: 88px;
        font-weight: 400;
        line-height: 0.95;
        color: #fff;
    }

    .results-title span {
        display: block;
        color: #d4af37;
        font-style: italic;
    }

    .results-subtitle {
        margin-top: 16px;
        font-size: 18px;
        color: rgba(255,255,255,0.84);
        max-width: 740px;
    }

    .results-info-bar-wrap {
        margin-top: 34px;
        max-width: 1040px;
    }

    .results-info-bar {
        display: grid;
        grid-template-columns: 1.4fr 1fr 0.7fr auto;
        align-items: center;
        border-radius: 28px;
        overflow: hidden;
        background: rgba(82, 98, 136, 0.28);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 14px 28px rgba(0,0,0,0.12);
    }

    .info-item {
        padding: 24px 28px;
        border-right: 1px solid rgba(255,255,255,0.10);
    }

    .info-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.6);
        margin-bottom: 8px;
    }

    .info-value {
        font-size: 18px;
        font-weight: 600;
        color: #fff;
    }

    .info-action {
        padding: 18px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 150px;
        padding: 18px 28px;
        border-radius: 22px;
        background: linear-gradient(135deg, #d4af37, #e4c96e);
        color: #111;
        text-decoration: none;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 12px 24px rgba(0,0,0,0.15);
    }

    .results-section {
        padding: 34px 0 60px;
    }

    .results-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .alert {
        padding: 16px 20px;
        border-radius: 18px;
        margin-bottom: 16px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        font-size: 16px;
        color: #fff;
    }

    .alert.error {
        background: rgba(120,0,40,0.26);
        border: 1px solid rgba(255,0,0,0.22);
    }

    .alert.info {
        background: rgba(200,160,50,0.08);
        border: 1px solid rgba(200,160,50,0.18);
    }

    .flight-card {
        display: grid;
        grid-template-columns: 1.5fr 0.8fr 0.6fr;
        align-items: center;
        gap: 24px;
        padding: 26px 28px;
        border-radius: 24px;
        margin-bottom: 20px;
        background: rgba(10, 22, 52, 0.74);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 12px 28px rgba(0,0,0,0.12);
    }

    .flight-left {
        font-size: 16px;
        line-height: 1.7;
        color: rgba(255,255,255,0.95);
    }

    .flight-left strong {
        display: inline-block;
        font-size: 28px;
        margin-bottom: 10px;
        color: #fff;
    }

    .flight-middle {
        text-align: center;
    }

    .price {
        color: #d4af37;
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .offer {
        font-size: 18px;
        color: rgba(255,255,255,0.95);
    }

    .flight-right {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .choose-btn {
        background: linear-gradient(135deg, #d4af37, #e4c96e);
        color: #111;
        padding: 14px 24px;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-weight: 800;
        font-size: 14px;
        min-width: 130px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .empty-box {
        padding: 30px;
        border-radius: 20px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        color: #fff;
        text-align: center;
    }

    @media (max-width: 1100px) {
        .results-title {
            font-size: 72px;
        }

        .results-info-bar {
            grid-template-columns: 1fr 1fr;
        }

        .info-action {
            grid-column: 1 / -1;
        }

        .flight-card {
            grid-template-columns: 1fr;
        }

        .flight-middle {
            text-align: left;
        }

        .flight-right {
            justify-content: flex-start;
        }
    }

    @media (max-width: 900px) {
        .results-navbar-inner {
            height: auto;
            padding: 18px 20px;
            flex-wrap: wrap;
        }

        .results-nav-links {
            width: 100%;
            justify-content: center;
            flex-wrap: wrap;
            gap: 18px;
        }

        .results-hero-inner,
        .results-container {
            padding-left: 18px;
            padding-right: 18px;
        }

        .results-title {
            font-size: 58px;
        }
    }

    @media (max-width: 768px) {
        .results-hero {
            min-height: 52vh;
            padding-bottom: 24px;
        }

        .results-title {
            font-size: 50px;
        }

        .results-subtitle {
            font-size: 16px;
        }

        .results-info-bar {
            grid-template-columns: 1fr;
        }

        .info-item {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.10);
        }

        .flight-card {
            padding: 20px;
        }

        .flight-left strong {
            font-size: 24px;
        }

        .price {
            font-size: 24px;
        }

        .choose-btn,
        .back-btn {
            width: 100%;
        }
    }
</style>

<div class="flights-results-page">

    <header class="results-navbar">
        <div class="results-navbar-inner">
            <a href="{{ path('app_home') }}" class="results-brand">
                <div class="results-brand-logo">T</div>
                <div>Travelia</div>
            </a>

            <nav class="results-nav-links">
                <a href="{{ path('app_home') }}">Home</a>
                <a href="#">Hotels</a>
                <a href="{{ path('app_flights_search') }}" class="active">Flights</a>
                <a href="#">Activities</a>
                <a href="#">Reviews</a>
                <a href="{{ path('app_user_reservations') }}">Mes réservations</a>
            </nav>

            <a href="#" class="results-signin">✦ Sign In</a>
        </div>
    </header>

    <section class="results-hero">
        <div class="results-hero-inner">
            <div class="results-label">✦ Flights</div>

            <h1 class="results-title">
                Available
                <span>Flights</span>
            </h1>

            <div class="results-subtitle">
                First-class and business flights to everywhere
            </div>

            <div class="results-info-bar-wrap">
                <div class="results-info-bar">
                    <div class="info-item">
                        <div class="info-label">Where</div>
                        <div class="info-value">{{ destination|default('Non définie') }}</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Date départ</div>
                        <div class="info-value">{{ date_depart|default('Non définie') }}</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Who</div>
                        <div class="info-value">{{ passagers|default(1) }} passager(s)</div>
                    </div>

                    <div class="info-action">
                        <a href="{{ path('app_flights_search', { reservation_id: reservation_id|default(0) }) }}" class="back-btn">
                            ← Retour
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="results-section">
        <div class="results-container">

            {% if api_error is not empty and not used_mock_fallback %}
                <div class="alert error">
                    {{ api_error }}
                </div>
            {% endif %}

            {% if used_mock_fallback %}
                <div class="alert info">
                    Résultats affichés depuis les données locales.
                </div>
            {% endif %}

            {% for flight in flights %}
                <div class="flight-card">
                    <div class="flight-left">
                        {% set originCode = flight.originCode|default('') %}
                        {% set destinationCode = flight.destinationCode|default('') %}
                        {% set routeLabel = flight.originLabel|default('Tunis') %}
                        {% set destinationLabel = flight.destinationLabel|default(flight.destinationCountry|default(destination)) %}
                        {% set durationMinutes = flight.durationMinutes|default(null) %}
                        {% set stopsCount = flight.stopsCount|default(0) %}
                        {% set hasValidCodes = originCode is not empty and destinationCode is not empty and originCode != '---' and destinationCode != '---' %}
                        {% if hasValidCodes %}
                            <strong>{{ originCode }} &rarr; {{ destinationCode }}</strong><br>
                        {% else %}
                            <strong>{{ routeLabel }} &rarr; {{ destinationLabel }}</strong><br>
                        {% endif %}
                        <span style="color: rgba(255,255,255,0.72);">{{ routeLabel }} &rarr; {{ destinationLabel }}</span><br><br>

                        D&eacute;part :
                        {% if flight.dateDepart is not empty %}
                            {{ flight.dateDepart|date('d M Y H:i') }}
                        {% else %}
                            Non d&eacute;finie
                        {% endif %}
                        <br>

                        Arriv&eacute;e :
                        {% if flight.dateArrivee is not empty %}
                            {{ flight.dateArrivee|date('d M Y H:i') }}
                        {% else %}
                            Non d&eacute;finie
                        {% endif %}
                        <br>

                        {% if durationMinutes is not null and durationMinutes > 0 %}
                            {% set durationHours = (durationMinutes // 60) %}
                            {% set durationRemainMinutes = (durationMinutes % 60) %}
                            Dur&eacute;e : {{ durationHours }}h {{ durationRemainMinutes }}min
                            <br>
                        {% endif %}

                        Trajet : {{ stopsCount == 0 ? 'Direct' : stopsCount ~ ' escale(s)' }}<br>
                        {% if flight.cabinClass is defined and flight.cabinClass is not empty %}
                            Classe : {{ flight.cabinClass }}<br>
                        {% elseif flight.offerLabel is defined and flight.offerLabel is not empty %}
                            Classe : {{ flight.offerLabel }}<br>
                        {% endif %}
                        Transport : {{ flight.transport|default('avion') }}<br>
                        R&eacute;f : {{ flight.reference|default('N/A') }}
                    </div>

                    <div class="flight-middle">
                        {% set basePrice = flight.prix|default(0) %}
                        {% set priceTnd = (basePrice * 3.35) %}

                        {% set roundedPriceTnd = priceTnd|round(0, 'floor') %}

                        <div class="price">
                            {{ (priceTnd - roundedPriceTnd) < 0.01 ? priceTnd|number_format(0, '.', ' ') : priceTnd|number_format(2, '.', ' ') }} DT
                        </div>

                        {% if flight.offerLabel is defined and flight.offerLabel is not empty %}
                            <div class="offer">Offre : {{ flight.offerLabel }}</div>
                        {% endif %}
                    </div>

                    <div class="flight-right">
                        <form method="POST" action="{{ path('app_flights_payment_page') }}">
                            <input type="hidden" name="billet_id" value="{{ flight.id|default(0) }}">
                            <input type="hidden" name="reservation_id" value="{{ reservation_id|default(0) }}">
                            <input type="hidden" name="selected_price" value="{{ priceTnd|number_format(2, '.', '') }}">
                            <input type="hidden" name="selected_date_depart" value="{% if flight.dateDepart is not empty %}{{ flight.dateDepart|date('Y-m-d H:i:s') }}{% endif %}">
                            <input type="hidden" name="selected_date_arrivee" value="{% if flight.dateArrivee is not empty %}{{ flight.dateArrivee|date('Y-m-d H:i:s') }}{% endif %}">
                            <input type="hidden" name="reference" value="{{ flight.reference|default('N/A') }}">
                            <input type="hidden" name="origin_code" value="{{ flight.originCode|default('---') }}">
                            <input type="hidden" name="destination_code" value="{{ flight.destinationCode|default('---') }}">
                            <input type="hidden" name="destination" value="{{ flight.destinationCountry|default(destination) }}">
                            <input type="hidden" name="offer_label" value="{{ flight.offerLabel|default('') }}">

                            <button type="submit" class="choose-btn">CHOISIR</button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="empty-box">
                    Aucun vol trouvé.
                </div>
            {% endfor %}
        </div>
    </section>

</div>

{% endblock %}
