<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Travelia — Profil</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/horizon.css?v=5" />
  <style>
    body { background:#050814; color:#fff; font-family:'Inter', sans-serif; display:flex; flex-direction:column; min-height:100vh; overflow-x:hidden; margin:0; }
    .stars-bg { position:fixed; top:0; left:0; width:100%; height:100%; z-index:-1; background: radial-gradient(circle at 50% 50%, #0a0f1e 0%, #030408 100%); }
    .nav { position:fixed; top:0; width:100%; padding:1rem 2.5rem; display:flex; justify-content:space-between; align-items:center; z-index:100; box-sizing:border-box; background:linear-gradient(to bottom, rgba(5,8,20,0.9), transparent); }
    .nav-logo { display:flex; align-items:center; gap:0.6rem; text-decoration:none; color:white; }
    .nav-logo-mark { background:#e8c97e; color:#000; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:600; }
    .nav-logo-text { font-family:'Space Grotesk',sans-serif; font-size:1.3rem; font-weight:700; }
    
    .auth-container { flex:1; display:flex; align-items:center; justify-content:center; padding: 120px 20px 60px; }
    .auth-box { width:100%; max-width:650px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:3rem; backdrop-filter:blur(20px); text-align:center; box-shadow:0 30px 60px rgba(0,0,0,0.5); }
    .auth-title { font-family:'Cormorant Garamond', serif; font-size:2.8rem; color:#fff; margin:0 0 0.5rem; font-weight:400; }
    .auth-subtitle { color:rgba(255,255,255,0.6); margin-bottom: 2.5rem; }
    
    .auth-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; text-align:left; }
    .full-width { grid-column: 1 / -1; }
    
    .auth-field label { display:block; text-transform:uppercase; font-size:0.7rem; color:rgba(255,255,255,0.5); margin-bottom:8px; font-weight:600; letter-spacing:1px; }
    .auth-field input { width:100%; box-sizing:border-box; background:rgba(0,0,0,0.2); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:0.8rem 1rem; color:#fff; font-size:0.95rem; outline:none; transition:border-color 0.3s; color-scheme:dark; }
    .auth-field input:focus { border-color:#e8c97e; }
    
    .auth-submit { grid-column: 1 / -1; width:100%; background:#e8c97e; color:#000; border:none; padding:1rem; border-radius:12px; font-weight:700; font-size:1rem; text-transform:uppercase; letter-spacing:1px; cursor:pointer; transition:transform 0.2s, background 0.2s; margin-top:1rem; }
    .auth-submit:hover { transform:translateY(-2px); background:#f4d890; }
    
    .flash-success { background:rgba(16,185,129,0.1); border:1px solid #10b981; color:#10b981; padding:15px; border-radius:12px; margin-bottom:2rem; font-size:0.95rem; }
  </style>
</head>
<body>
  <div class="stars-bg"></div>
  <nav class="nav">
    <a href="{{ path('app_home') }}" class="nav-logo">
      <div class="nav-logo-mark">T</div>
      <span class="nav-logo-text">Travelia</span>
    </a>
    <a href="{{ path('app_home') }}" style="color:#c9a84c; text-decoration:none; font-weight:600; font-size:0.9rem;">← Retour à l'accueil</a>
  </nav>

  <div class="auth-container">
    <div class="auth-box">
      <h1 class="auth-title">Gestion du <em>Profil</em></h1>
      <p class="auth-subtitle">Mettez à jour vos informations de voyageur Travelia.</p>

      {% for message in app.flashes('success') %}
          <div class="flash-success">{{ message }}</div>
      {% endfor %}

      <form method="post" class="auth-form-grid">
          <div class="auth-field">
              <label>Prénom</label>
              <input type="text" name="prenom" value="{{ user.prenom }}" required>
          </div>
          <div class="auth-field">
              <label>Nom</label>
              <input type="text" name="nom" value="{{ user.nom }}" required>
          </div>
          <div class="auth-field full-width">
              <label>Adresse Email</label>
              <input type="email" name="email" value="{{ user.email }}" required>
          </div>
          <div class="auth-field">
              <label>Téléphone</label>
              <input type="tel" name="telephone" value="{{ user.telephone }}">
          </div>
          <div class="auth-field">
              <label>Date de Naissance</label>
              <input type="date" name="date_naissance" value="{{ user.dateNaissance ? user.dateNaissance|date('Y-m-d') : '' }}">
          </div>
          <div class="auth-field full-width">
              <label>Nationalité</label>
              <input type="text" name="nationalite" value="{{ user.nationalite }}">
          </div>

          <button type="submit" class="auth-submit">Enregistrer les modifications</button>
      </form>
    </div>
  </div>
</body>
</html>
