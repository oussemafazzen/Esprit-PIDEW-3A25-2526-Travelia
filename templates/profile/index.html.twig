{% extends 'base.html.twig' %}

{% block title %}Mon Profil — Travelia{% endblock %}

{% block stylesheets %}
<style>
    .profile-container {
        max-width: 800px;
        margin: 120px auto;
        padding: 0 2rem;
    }
    .profile-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(40px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 32px;
        padding: 4rem;
        box-shadow: 0 40px 100px rgba(0,0,0,0.4);
    }
    .profile-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }
    .profile-title {
        font-family: var(--serif);
        font-size: 2.5rem;
        font-weight: 300;
        margin-bottom: 0.8rem;
    }
    .profile-lead {
        font-size: 0.9rem;
        opacity: 0.5;
        letter-spacing: 0.05em;
    }
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    .form-group.full {
        grid-column: span 2;
    }
    .label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        opacity: 0.4;
    }
    .input {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        color: #fff;
        font-size: 0.95rem;
        transition: 0.3s;
    }
    .input:focus {
        border-color: var(--gold);
        background: rgba(255,255,255,0.06);
        outline: none;
    }
    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        padding: 1.2rem;
        border-radius: 16px;
        margin-bottom: 2.5rem;
        text-align: center;
        font-size: 0.9rem;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .submit-btn {
        margin-top: 2rem;
        width: 100%;
        padding: 1.2rem;
        font-size: 1rem;
    }
</style>
{% endblock %}

{% block body %}
<section class="panel" style="display: block; overflow-y: auto;">
    <div class="profile-container">
        <div class="profile-card">
            <header class="profile-header">
                <h1 class="profile-title">Gestion du <em>Profil</em></h1>
                <p class="profile-lead">Mettez à jour vos informations de voyageur Travelia.</p>
            </header>

            {% for message in app.flashes('success') %}
                <div class="alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            <form method="post">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="label">Prénom</label>
                        <input type="text" name="prenom" value="{{ user.prenom }}" class="input" required>
                    </div>
                    <div class="form-group">
                        <label class="label">Nom</label>
                        <input type="text" name="nom" value="{{ user.nom }}" class="input" required>
                    </div>
                    <div class="form-group full">
                        <label class="label">Adresse Email</label>
                        <input type="email" name="email" value="{{ user.email }}" class="input" required>
                    </div>
                    <div class="form-group">
                        <label class="label">Téléphone</label>
                        <input type="text" name="telephone" value="{{ user.telephone }}" class="input" required>
                    </div>
                    <div class="form-group">
                        <label class="label">Date de Naissance</label>
                        <input type="date" name="date_naissance" value="{{ user.dateNaissance|date('Y-m-d') }}" class="input" required>
                    </div>
                    <div class="form-group full">
                        <label class="label">Nationalité</label>
                        <input type="text" name="nationalite" value="{{ user.nationalite }}" class="input" required>
                    </div>
                </div>

                <button type="submit" class="trip-btn submit-btn">
                    Enregistrer les modifications
                </button>
            </form>
            
            <div style="margin-top: 2rem; text-align: center;">
                <a href="{{ path('app_home') }}" style="font-size: 0.8rem; color: rgba(255,255,255,0.3); text-decoration: none;">← Retour à l'accueil</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
